<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yahi hai </title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-zinc-900">

    <div class="main w-full">
        <div class="form p-10 ">
            <form action="/creat" method="post">
                <input class="bg-zinc-800 px-5 p-y3 block w-full text-white rounded-md outline-none" placeholder="Title" type="text" name="title">
                <textarea class="bg-zinc-800 px-5 p-y3 mt-2 text-white resize-none block w-full rounded-md outline-none" name="detail" placeholder="keep write your Notes"></textarea>
                <input class="mt-2 px-5 py-2 rounded-md bg-blue-600 text-white" type="submit" value="Create Task">
            </form>
        </div>

        <% if(files.length > 0){ %>
            <div class="Tasks p-10 flex gap-3 flex-wrap">
            <% files.forEach((file)=>{%>

            <div class="task px-3 py-4 w-72 bg-zinc-800 text-white rounded-md ">
                <h1 class="text-white text-3xl tracking-tighter"><%= file%></h1>
                <a class="text-blue-600 inline-block mt-3" href="/files/<%=file%>">Read more</a>
                <button class="text-white bg-blue-600 px-2 ml-24 align-right rounded-md" type="delete">Delete</button>
            </div>
            <% }) %>

        </div>
        <% } else {%>
            <h3 class="m-10 text-zinc-600">No Tasks yet</h3>
        <% } %>
    </div>
</body>
</html>