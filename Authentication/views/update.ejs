<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <h3>Update your post</h3>

        <form action="/update/<%= post._id%>" method="post">
            <textarea class="block mt-5 p-3 border-2 border-zinc-800 rounded-md outline-none resize-none bg-transparent w-1/4" name="content" placeholder="What's on your mind"><%= post.content%></textarea>
            <input class="mt-2 w-40 rounded-md text-black-500 bg-yellow-600 px-4 py-2 block" type="submit" value="Update">
        </form>

    </div>
</body>
</html>