<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <nav class="bg-zinc-800 border-1 border-zinc-700">
        <div class="w-full px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                    <h1 class="text-xl text-white font-bold tracking-tighter">Fista<span class="text-blue-500">Gr</span>am</h1>
            </div>
            <div class="flex items-center gap-4">
                <a class="text-sm font-medium text-zinc-300" href="/">Home</a>
                <form action="/logout" method="post" class="m-0">
                    <button type="submit" class="bg-red-600 text-sm text-white font-semibold px-5 py-2 rounded-md">
                        Log Out
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <div class="w-full h-full bg-zinc-900 p-10 text-white">

        <header class="flex flex-col sm:flex-row items-center gap-6 pb-10 border-b border-zinc-800 mb-10">
                <div class="relative group">
                    <div class="h-28 w-28 border-4 border-zinc-700 rounded-full overflow-hidden ring-2 ring-blue-500/20">
                        <img class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" src="/images/uploads/<%= user.profilePic%>" alt="<%= user.name %>'s profile">
                    </div>
                    <a class="absolute bottom-1 right-1 bg-zinc-700 p-1.5 rounded-full text-blue-400 hover:text-blue-300 hover:bg-zinc-600" href="/upload/profile" title="Change profile photo">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                        </svg>
                    </a>
                </div>
                
                <div class="text-center sm:text-left flex-1">
                    <h2 class="text-4xl font-extrabold tracking-tight"><span class="font-light text-zinc-400">Hello,</span> <%= user.name %>👋</h2>
                    <p class="text-zinc-400 mt-1">Welcome back to hamster. Share what's going today! </p>
                </div>
        </header>
        <h3 class="mt-5">Create new post</h3>

        <form action="/post" method="post">
            <textarea class="block mt-5 p-3 border-2 border-zinc-800 rounded-md outline-none resize-none bg-black w-1/4" name="content" placeholder="What's on your mind"></textarea>
            <input class="mt-3 w-40 rounded-md bg-blue-600 px-4 py-2 block" type="submit" value="Create +">
        </form>

        <div class="posts mt-20">
            <h2>Your Posts.</h2>
            <div class="postcontainer flex flex-wrap gap-4">
                <% if(user.posts.length>0){ %>
                    <% user.posts.forEach((post)=>{ %>
                        <div class=" mt-3 post p-5 w-80 bg-zinc-800 border border-zinc-700 rounded-md">
                            <!-- User info -->
                            <div class="flex items-center justify-between mb-4">
                                <h4 class="text-blue-500 font-semibold">@<%= user.name %></h4>
                                <span class="text-xs text-zinc-400">just now</span>
                            </div>

                            <!-- Content -->
                            <p class="text-sm text-zinc-200 mb-4">
                                <%= post.content %>
                            </p>

                            <div class="flex items-center gap-6 text-sm">
                                <a href="/like/<%= post._id %>" class="flex items-center gap-1 text-zinc-400 hover:text-blue-500 cursor-pointer transition">
                                    <% if(post.like.includes(user._id)){ %>
                                        ❤️
                                    <% }else{ %>
                                        🤍
                                    <% } %>
                                     <span><%= post.like.length %></span>
                                </a>
                                <a class="flex items-center gap-1 text-zinc-400 hover:text-green-500 cursor-pointer transition" href="/update/<%= post._id%>">
                                    ✏️ <span>Edit</span>
                                </a>
                                <form action="/delete/<%= post._id %>" method="post">
                                    <button class="flex items-center gap-1 text-red-500 hover:text-green-500 cursor-pointer transition" type="submit" value="delete">
                                        🚮<span>Delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <%})%>
                <%} else {%>
                    <h3 class="text-zinc-400">No posts yet.</h3>
                <%}%>
            </div>
        </div>

    </div>
</body>
</html>