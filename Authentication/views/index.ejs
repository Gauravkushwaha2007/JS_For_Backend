<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HAa</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <form action="/create" method="post">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="text" placeholder="name" name="name">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="password" placeholder="password" name="password">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="number" placeholder="age" name="age">
            <input class="bg-blue-600 rounded-md px-3 py-2 ml-3" type="submit" value="Create User">
        </form>
        
        <div class="mt-5 flex flex-wrap gap-3">
            <form action="logout" method="post">
                <input class="bg-red-600 rounded-md px-3 py-2" type="submit" value="Log Out">
            </form>
            <a class="bg-green-600 rounded-md px-3 py-2 " href="/login">Log in</a>
        </div>
    </div>
</body>
</html>