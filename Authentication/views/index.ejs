<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>X-Hamster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white block justify-center item-center">
        <h2 class="ml-[28rem] text-blue-200 text-4xl font-bold" style="font-family: 'Poppins', sans-serif;">Welcome to Hamster !</h2>
        <div class="mt-5 ml-[28rem] w-[25rem] h-[25rem] bg-zinc-800 border-2 border-zinc-700 p-5 rounded-md">
            <h2 class="mb-5 text-3xl">Create Account</h2>
            <form action="/register" method="post">
                <input class="mt-2 px-3 py-2 rounded-md border-[1px] border-zinc-700 outline-none bg-zinc-800 block w-full" type="text" placeholder="name" name="name">
                <input class="mt-2 px-3 py-2 rounded-md border-[1px] border-zinc-700 outline-none bg-zinc-800 block w-full" type="email" placeholder="email" name="email">
                <input class="mt-2 px-3 py-2 rounded-md border-[1px] border-zinc-700 outline-none bg-zinc-800 block w-full" type="password" placeholder="password" name="password">
                <input class="mt-2 px-3 py-2 rounded-md border-[1px] border-zinc-700 outline-none bg-zinc-800 block w-full" type="number" placeholder="age" name="age">
                <input class="mt-4 w-1/2 bg-blue-600 rounded-md px-3 py-2 " type="submit" value="Create User">
            </form>
            <a class="text-sm text-blue-400" href="/login">Already existing an Account </a>
        </div>
    </div>
</body>
</html>