<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white flex justify-center item-center">
        <div class=" p-5 w-[25rem] h-[18rem] justify-center border-2 border-zinc-700 bg-zinc-800 rounded-md "> 
            <h2 class="mb-5 text-3xl">Login your Account</h2>
            <form action="/login" method="post">
                <input class="px-3 py-2 block w-full mt-3 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="email" placeholder="email" name="email">
                <input class="px-3 py-2 block w-full mt-3 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="password" placeholder="password" name="password">
                <input class=" block width-full mt-3 bg-blue-600 rounded-md px-5 py-2" type="submit" value="Login">
            </form>
            <a class="text-sm text-blue-400" href="/">Don't have an Account </a>
        </div>
    </div>
</body>
</html>