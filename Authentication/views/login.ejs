<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <h2 class="mb-5 text-3xl">Login your Account</h2>
        <form action="/login" method="post">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded-md border-2 border-zinc-700 outline-none bg-zinc-800" type="password" placeholder="password" name="password">
            <input class="bg-blue-600 rounded-md px-3 py-2" type="submit" value="Login">
        </form>
    </div>
</body>
</html>