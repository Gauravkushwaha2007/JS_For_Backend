<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Products | KushNova</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .dropdown-menu { display: none; }
    .dropdown-menu.show { display: block; }
  </style>
</head>

<body class="bg-[#f8f9fa] text-gray-900 antialiased">


  <header class="nav-sticky bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 md:px-6 h-20 flex items-center justify-between gap-4 md:gap-8">
      
      <div class="flex items-center gap-6 shrink-0">
        <a href="/" class="text-2xl font-black tracking-tighter text-emerald-600">APNA<span class="text-black">MART</span></a>
        
        <div class="hidden lg:block border-l border-gray-200 pl-6">
          <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 leading-none mb-1">Delivery in 10-12 mins</p>
          <p class="text-xs font-bold text-gray-900 flex items-center gap-1">
            Bhopal, India <i class="fa-solid fa-caret-down text-[10px] text-emerald-600"></i>
          </p>
        </div>
      </div>

      <div class="flex-1 max-w-2xl relative group">
        <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-emerald-600 transition-colors"></i>
        <input type="text" 
               placeholder="Search for groceries, veggies and more..." 
               class="w-full bg-gray-50 border border-gray-100 rounded-xl py-3 pl-12 pr-4 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-white focus:border-emerald-500 transition-all">
      </div>

      <div class="flex items-center gap-4 md:gap-8 shrink-0">
        
        <a href="/users/profile" class="hidden md:flex items-center gap-2 text-sm font-bold text-gray-700 hover:text-emerald-600 transition-colors">
          <i class="fa-regular fa-circle-user text-xl"></i>
          <span>Account</span>
        </a>

        <a href="/users/cart/products" class="relative group flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md shadow-emerald-600/20">
          <i class="fa-solid fa-cart-shopping text-sm"></i>
          <span class="text-sm font-extrabold tracking-tight">My Cart</span>
          
          <% if(user && user.cart && user.cart.length > 0) { %>
            <span class="absolute -top-2 -right-2 bg-red-500 text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center border-2 border-white shadow-sm">
              <%= user.cart.length %>
            </span>
          <% } else { %>
            <span class="absolute -top-2 -right-2 bg-gray-400 text-white text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center border-2 border-white shadow-sm">
              0
            </span>
          <% } %>
        </a>

      </div>
    </div>
  </header>


  <div class="flex min-h-screen flex-col md:flex-row">

    <div class="w-full md:w-64 bg-white border-b md:border-b-0 md:border-r border-gray-100 p-6 flex-shrink-0">
      <div class="mb-8 flex justify-between items-center md:block">
        <div>
          <h1 class="text-2xl font-black tracking-tight text-black">Apna Mart</h1>
          <p class="text-[10px] uppercase font-bold tracking-widest text-emerald-600 mt-1">
            <%= (user && user.role === 'admin') ? 'Admin Dashboard' : 'Customer Panel' %>
          </p>
        </div>
        <div class="md:hidden flex items-center gap-2">
          <i class="fa-solid fa-circle-user text-xl text-gray-700"></i>
        </div>
      </div>

      <div class="space-y-6">
        <div>
          <p class="font-bold text-[11px] uppercase text-gray-400 mb-2.5 tracking-wider">Navigation</p>
          <div class="space-y-1 text-xs font-medium text-gray-500">
            <a href="/products/allProducts" class="bg-black text-white py-2.5 px-3 rounded-xl font-semibold flex items-center gap-2 shadow-sm shadow-black/10">
              <i class="fa-solid fa-store text-[11px]"></i> Shop Catalogue
            </a>
            
            <a href="/users/cart/products" class="flex items-center justify-between py-2.5 px-3 rounded-xl hover:bg-gray-50 hover:text-black transition-all">
              <div class="flex items-center gap-2">
                <i class="fa-solid fa-basket-shopping text-[11px] opacity-70"></i>
                <span>Your Cart</span>
              </div>
            </a>
          </div>
        </div>

        <div>
          <p class="font-bold text-[11px] uppercase text-gray-400 mb-2.5 tracking-wider">My Account</p>
          <div class="bg-gray-50/60 border border-gray-100 rounded-2xl p-3.5">
            <% if (user) { %>
              <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 rounded-full bg-black text-white font-bold flex items-center justify-center text-xs uppercase">
                  <%= user.name.charAt(0) %>
                </div>
                <div class="min-w-0 ">
                  <p class="text-xs font-bold text-gray-800 truncate"><%= user.name %></p>
                  <p class="text-[10px] text-gray-400 font-medium truncate"><%= user.email %></p>
                </div>
              </div>
              <a href="/users/logout" class="w-full text-center block bg-red-50 hover:bg-red-100 text-red-600 transition py-2 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5">
                <i class="fa-solid fa-right-from-bracket text-[10px]"></i> Log Out
              </a>
            <% } else { %>
              <p class="text-[11px] text-gray-400 mb-3 font-medium">You are browsing as Guest.</p>
              <a href="/users/login" class="w-full text-center block bg-black text-white py-2 rounded-xl text-xs font-bold">
                Log In / Register
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>


    <div class="flex-1 p-6 md:p-10 lg:px-12">
      
      <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-gray-100 pb-6">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <a href="/" class="text-xs font-medium text-gray-400 hover:text-black transition-colors">
              <i class="fa-solid fa-house mr-1"></i> Home
            </a>
            <span class="text-gray-300 text-xs">/</span>
            <span class="text-xs font-semibold text-gray-800">Catalogue</span>
          </div>
          <h2 class="text-3xl font-extrabold tracking-tight text-gray-900">All Products</h2>
        </div>
        
        <div class="flex items-center gap-3 self-start sm:self-auto">
          <div class="bg-emerald-50 text-emerald-700 px-4 py-2 rounded-xl text-xs font-bold border border-emerald-100/60">
            <%= products.length %> Items Available
          </div>
          
          <% if(user && user.role === 'admin'){ %>
            <a href="/products/create" 
               class="bg-black text-white rounded-xl px-4 py-2.5 text-xs font-bold hover:bg-gray-800 transition shadow-md shadow-black/5 flex items-center gap-1.5">
              <i class="fa-solid fa-plus text-[10px]"></i> Create New Product
            </a>
          <% } %>
        </div>
      </div>

      <% if(products.length > 0 ){ %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <% products.forEach((product) => { %>
            
            <div class="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:shadow-gray-200/40 transition-all duration-300 relative flex flex-col">
              
              <% if(user && user.role === 'admin' ){ %>
                <div class="absolute top-3 right-3 z-20">
                  <button onclick="toggleMenu(event, 'menu-<%= product._id %>')" 
                          class="w-8 h-8 flex items-center justify-center bg-white/90 backdrop-blur shadow-sm rounded-full border border-gray-100 hover:bg-white text-gray-600 transition-all">
                    <i class="fa-solid fa-ellipsis-vertical text-xs"></i>
                  </button>
                  
                  <div id="menu-<%= product._id %>" 
                       class="dropdown-menu absolute right-0 mt-1.5 w-36 bg-white border border-gray-100 rounded-xl shadow-xl overflow-hidden ring-1 ring-black/5 z-30">
                      
                      <a href="/products/edit/<%= product._id %>" 
                         class="w-full text-left px-4 py-2.5 text-xs text-gray-700 hover:bg-gray-50 font-medium flex items-center gap-2 border-b border-gray-50">
                          <i class="fa-regular fa-pen-to-square text-gray-400"></i> Edit Item
                      </a>
  
                      <form action="/products/delete/<%= product._id %>" method="post" onsubmit="return confirm('Kya aap sach me is product ko delete karna chahte hain?')">
                          <button type="submit" class="w-full text-left px-4 py-2.5 text-xs text-red-500 hover:bg-red-50 font-semibold flex items-center gap-2">
                              <i class="fa-regular fa-trash-can opacity-80"></i> Delete Item
                          </button>
                      </form>
                  </div>
                </div>
              <% } %>
    
              <div class="h-52 bg-[#fafafa] flex items-center justify-center relative overflow-hidden p-4 border-b border-gray-50">
                <a href="/products/view/<%= product._id %>">
                  <img src="/uploads/<%= product.image %>" 
                       alt="<%= product.name %>" 
                       class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500">
                </a>
                
                <% if(product.discount > 0) { %>
                  <span class="absolute bottom-3 left-3 bg-red-500 text-white text-[9px] font-black px-2 py-1 rounded-lg uppercase tracking-wider shadow-sm">
                    Sale
                  </span>
                <% } %>
              </div>
    
              <div class="p-4 flex-1 flex flex-col justify-between" style="background-color: <%= product.panelColor || '#ffffff' %>;">
                <div class="flex justify-between items-end w-full gap-2">
                    <div class="flex-1 min-w-0">

                      <a href="/products/view/<%= product._id %>">
                        <h3 class="font-bold text-sm leading-snug mb-0.5 truncate" style="color: <%= product.textColor || '#111827' %>;">
                          <%= product.name %>
                        </h3>
                      </a>

                        <p class="text-base font-black tracking-tight opacity-95" style="color: <%= product.textColor || '#111827' %>;">
                          ₹<%= product.price %>
                        </p>

                    </div>

                    <button onclick="addToCart('<%= product._id%>')" 
                            class="w-9 h-9 rounded-full flex items-center justify-center transition-all shadow-md hover:scale-105 active:scale-95 flex-shrink-0" 
                            style="background-color: white; color: <%= product.panelColor || '#000000' %>;"
                            title="Add to cart">
                      <i class="fa-solid fa-plus text-xs"></i>
                    </button>
                </div>
              </div>
            </div>

          <% }) %>
      </div>

      <% } else { %>
        <div class="max-w-md mx-auto text-center py-16 bg-white rounded-3xl border border-gray-100 shadow-sm my-10 px-6">
            <div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-gray-100 text-gray-300">
              <i class="fa-solid fa-box-open text-xl"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-800">No products found in store</h3>
            <p class="text-xs text-gray-400 mt-1 max-w-xs mx-auto">Store empty hai. Naye products add karna shuru karein.</p>
            <% if(user && user.role === 'admin') { %>
              <a href="/products/create" class="inline-flex items-center justify-center bg-black text-white font-semibold text-xs px-5 py-2.5 rounded-xl mt-5 hover:bg-gray-800 transition shadow-sm">
                Create First Product
              </a>
            <% } %>
        </div>
      <% } %>
    </div>

  </div>

  <script>
    async function addToCart (productId){
      let res = await fetch(`/users/cart/add-to-cart/${productId}`,{
          method: "POST"
      });
      let data = await res.json();
      alert(data.message); 
      if(data.success){
        location.reload()
      }
    }
  </script>

  <script>
    function toggleMenu(event, menuId) {
        event.stopPropagation(); 
        const menu = document.getElementById(menuId);
        const isOpen = menu.classList.contains('show');
        closeAllMenus();
        if (!isOpen) {
            menu.classList.add('show');
        }
    }

    function closeAllMenus() {
        document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
    }

    window.onclick = function() {
        closeAllMenus();
    }
  </script>

</body>
</html>