<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register | Apna Mart Supermart</title>
  <!-- Google Fonts for Premium Digital Mart Look -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700;800&family=Archivo+Black&display=swap" rel="stylesheet">
  <!-- FontAwesome for Grocery Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
    }
    /* Premium dark forest green glow suitable for high-end organic/grocery mart */
    .bg-glow {
      background: radial-gradient(circle at 50% 30%, #0d2111 0%, #060c08 65%, #020403 100%);
    }
  </style>
</head>

<body class="bg-[#050906] text-white bg-glow antialiased flex items-center justify-center h-screen px-4">

  <!-- Main Register Card Container -->
  <div class="relative bg-[#0d110e]/70 border border-emerald-950/40 backdrop-blur-xl shadow-[0_4px_30px_rgba(0,0,0,0.5)] p-8 rounded-2xl w-full max-w-sm transition-all duration-300 my-auto">

    <!-- Close / Back to Home Button -->
    <a href="/" class="absolute top-4 right-4 text-zinc-500 hover:text-emerald-400 transition-colors p-2 rounded-xl hover:bg-emerald-950/20 border border-transparent hover:border-emerald-950/40">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </a>

    <!-- Branding Logo & Welcome Header -->
    <div class="text-center mb-6">
      <div class="inline-flex items-center gap-2 mb-3 group cursor-pointer">
        <div class="w-8 h-8 bg-emerald-500 rounded-xl flex items-center justify-center group-hover:rotate-6 transition-transform duration-300 shadow-[0_0_15px_rgba(16,185,129,0.3)]">
          <i class="fa-solid fa-basket-shopping text-black text-sm"></i>
        </div>
        <div class="text-left">
          <h1 class="text-base font-black tracking-tight text-white leading-none">Apna Mart</h1>
          <span class="text-[8px] uppercase font-bold tracking-widest text-emerald-400">Supermart</span>
        </div>
      </div>

      <h2 class="text-white text-2xl font-extrabold tracking-tight mb-1">Create Account</h2>
      <p class="text-zinc-500 text-xs font-medium">Start your fresh grocery journey</p>
    </div>

    <!-- Register Form -->
    <form action="/users/register" method="POST" class="space-y-3.5">

      <!-- Full Name Input Field with Icon -->
      <div class="relative group">
        <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-emerald-400 transition-colors text-xs"></i>
        <input type="text" name="name" placeholder="Full Name" required
          class="w-full bg-zinc-900/50 border border-zinc-800/80 rounded-xl py-3 pl-11 pr-4 text-xs font-medium text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-zinc-900 focus:border-emerald-500 transition-all">
      </div>

      <!-- Email Input Field with Icon -->
      <div class="relative group">
        <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-emerald-400 transition-colors text-xs"></i>
        <input type="email" name="email" placeholder="Email Address" required
          class="w-full bg-zinc-900/50 border border-zinc-800/80 rounded-xl py-3 pl-11 pr-4 text-xs font-medium text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-zinc-900 focus:border-emerald-500 transition-all">
      </div>

      <!-- Password Input Field with Icon -->
      <div class="relative group">
        <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-emerald-400 transition-colors text-xs"></i>
        <input type="password" name="password" placeholder="Password" required
          class="w-full bg-zinc-900/50 border border-zinc-800/80 rounded-xl py-3 pl-11 pr-4 text-xs font-medium text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-zinc-900 focus:border-emerald-500 transition-all">
      </div>

      <!-- Contact/Phone Input Field with Icon -->
      <div class="relative group">
        <i class="fa-solid fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-emerald-400 transition-colors text-xs"></i>
        <input type="text" name="contact" placeholder="Contact Number" required
          class="w-full bg-zinc-900/50 border border-zinc-800/80 rounded-xl py-3 pl-11 pr-4 text-xs font-medium text-white placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-zinc-900 focus:border-emerald-500 transition-all">
      </div>

      <!-- Premium Emerald Register Button -->
      <button class="w-full bg-emerald-500 text-black hover:bg-emerald-400 transition py-3.5 rounded-xl font-bold text-xs uppercase tracking-wider shadow-lg shadow-emerald-500/10 active:scale-[0.98] mt-2">
        Register Now <i class="fa-solid fa-user-plus ml-1 text-[10px]"></i>
      </button>

    </form>

    <!-- Sign In Redirect Link -->
    <p class="text-center text-xs font-medium text-zinc-500 mt-6">
      Already have an account?
      <a href="/users/login" class="text-emerald-400 font-bold hover:underline ml-1">Sign in</a>
    </p>

  </div>

</body>
</html>