<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-[#0a0a0a] flex items-center justify-center h-screen px-4">

  <div class="relative bg-[#111] border border-zinc-800 shadow-2xl p-8 rounded-2xl w-full max-w-sm text-white">

    <a href="/" class="absolute top-4 right-4 text-zinc-500 hover:text-white transition-colors p-2 rounded-full hover:bg-zinc-800/50">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </a>

    <div class="text-center mb-8">
      <h2 class="text-3xl font-semibold mb-1">Create Account</h2>
      <p class="text-zinc-500 text-xs">Start your journey</p>
    </div>

    <form action="/users/register" method="POST" class="space-y-4">

      <input type="text" name="name" placeholder="Full Name"
        class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-800 text-sm text-white focus:border-white focus:ring-1 focus:ring-white outline-none placeholder-zinc-600 transition">

      <input type="email" name="email" placeholder="Email"
        class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-800 text-sm text-white focus:border-white focus:ring-1 focus:ring-white outline-none placeholder-zinc-600 transition">

      <input type="password" name="password" placeholder="Password"
        class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-800 text-sm text-white focus:border-white focus:ring-1 focus:ring-white outline-none placeholder-zinc-600 transition">

      <input type="text" name="contact" placeholder="Contact"
        class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-800 text-sm text-white focus:border-white focus:ring-1 focus:ring-white outline-none placeholder-zinc-600 transition">

      <button class="w-full bg-white text-black hover:bg-zinc-200 transition py-3 rounded-xl font-medium text-sm active:scale-95">
        Register
      </button>

    </form>

    <p class="text-center text-xs text-zinc-500 mt-6">
      Already have an account?
      <a href="/users/login" class="text-white hover:underline">Sign in</a>
    </p>

  </div>

</body>
</html>