    /* --- फुल स्क्रीन ज़ूम पैनल (Overlay) --- */
    .full-page-zoom-panel {
      position: fixed;
      right: 5%;
      top: 20%;
      width: 320px;
      height: 320px;
      border-radius: 24px;
      border: 1px solid rgba(16, 185, 129, 0.2);
      background-color: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(8px); /* ग्लासमोर्फिज़्म इफ़ेक्ट */
      box-shadow: 0 25px 50px -12px rgba(4, 120, 87, 0.15);
      z-index: 100;
      background-repeat: no-repeat;
      pointer-events: none; /* माउस इसके आर-पार जा सके, कोई रुकावट न हो */
      opacity: 0;
      transform: scale(0.9) translateX(20px);
      transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* जब यूजर इमेज पर होवर करे तब ये पैनल स्मूथली सामने आए */
    .img-hover-active .full-page-zoom-panel {
      opacity: 1;
      transform: scale(1) translateX(0);
    }

    /* मोबाइल स्क्रीन्स पर यह पैनल स्क्रीन के बीच में नीचे दिखेगा ताकि लेआउट बिगड़े नहीं */
    @media (max-width: 768px) {
      .full-page-zoom-panel {
        right: 50%;
        transform: scale(0.9) translateX(50%);
        bottom: 5%;
        top: auto;
        width: 260px;
        height: 260px;
      }
      .img-hover-active .full-page-zoom-panel {
        transform: scale(1) translateX(50%);
      }
    }
  </style>
