<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <div class="w-64 bg-white shadow-md p-6">
      <h1 class="text-2xl font-bold mb-6">Scatch</h1>

      <nav class="space-y-4 text-gray-700">
        <a href="/products" class="block hover:text-blue-500">All Products</a>
        <a href="/products/create" class="block text-blue-500 font-semibold">Create new product</a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-10">

      <div class="max-w-3xl bg-white p-8 rounded-xl shadow">

        <h2 class="text-2xl font-semibold mb-6">Create New Product</h2>
        <form action="<%= product? '/products/edit/'+ product._id : '/products/create'%>" method="post" class="space-y-6" enctype="multipart/form-data">
          <!-- Product Details -->
          <div>
            <h3 class="font-semibold mb-3 text-gray-700">Product Details</h3>

            <!-- Image -->
            <% if(product && product.image){ %>
              <img 
                src="/uploads/<%= product.image %>" 
                class="w-32 mb-4 rounded"
              />
            <% } %>         
            <input type="file" name="image"
              class="mb-4 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 
              file:rounded file:border-0 file:text-sm file:font-semibold 
              file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />

            <div class="grid grid-cols-2 gap-4">
              <input type="text" name="name" placeholder="Product Name"
                value="<%= product? product.name: '' %>"
                class="p-3 border rounded w-full" required>

              <input type="number" name="price" placeholder="Product Price"
                value="<%= product? product.price: ''%>"
                class="p-3 border rounded w-full" required>
            </div>

            <input type="number" name="discount" placeholder="Discount Price"
              value="<%= product? product.discount: '' %>"
              class="p-3 border rounded w-full mt-4">
          </div>

          <!-- Panel Details -->
          <div>
            <h3 class="font-semibold mb-3 text-gray-700">Panel Details</h3>

            <div class="grid grid-cols-2 gap-4">
              <input type="text" name="bgColor" placeholder="Background Color (e.g. #ffffff)"
                class="p-3 border rounded w-full" value="<%= product? product.bgColor: '' %>">

              <input type="text" name="panelColor" placeholder="Panel Color"
                class="p-3 border rounded w-full" value="<%= product? product.panelColor: '' %>">
            </div>

            <input type="text" name="textColor" placeholder="Text Color"
              class="p-3 border rounded w-full mt-4" value="<%= product? product.textColor: '' %>">
          </div>
          <!-- Description -->
          <textarea name="description">Enter Description </textarea>
          <!-- Submit -->
          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded font-semibold">
            <%= product? "Update Product": "Create New Product"%>
          </button>

        </form>

      </div>

    </div>

  </div>

</body>
</html>