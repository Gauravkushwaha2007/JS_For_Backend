<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Basket | Apna Mart</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
  </style>
</head>

<body class="bg-[#f8f9fa] text-gray-900 antialiased">

  <%- include('partials/header') %>

  <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between border-b border-gray-200 pb-5 mb-10 gap-4">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Shopping Cart</h1>
        <p class="text-sm text-gray-500 mt-1">Review your selected items before checking out.</p>
      </div>
      <a href="/products/allProducts"
        class="inline-flex items-center justify-center bg-white text-gray-700 border border-gray-300 px-5 py-2.5 rounded-xl font-medium text-sm hover:bg-gray-50 shadow-sm transition-all duration-200 gap-2 group">
        <i class="fa-solid fa-arrow-left text-xs text-gray-400 group-hover:-translate-x-1 transition-transform"></i>
        Continue Shopping
      </a>
    </div>

    <% if(products.length > 0 ){ %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">

      <div class="lg:col-span-2 space-y-5">
        <% let total = 0; %>
        <% products.forEach((item) => { %>
          <% if (!item.product) { return; } %>
          <% 
            const subTotal = item.product.price * item.quantity;
            total += subTotal;
          %>

        <div id="product-<%= item.product._id %>"
            class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col sm:flex-row gap-5 items-start sm:items-center relative hover:shadow-lg hover:shadow-gray-100/80 transition-all duration-300">
          
          <a href="/products/view/<%= item.product._id %>" class="w-28 h-28 sm:w-24 sm:h-24 overflow-hidden rounded-xl bg-gray-50 flex-shrink-0 border border-gray-100 shadow-inner group block">
            <img src="/uploads/<%= item.product.image %>" class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105" alt="<%= item.product.name %>">
          </a>

          <div class="flex-1 w-full">
            <div class="flex justify-between items-start">
              
              <a href="/products/view/<%= item.product._id %>" class="block hover:opacity-80 transition-opacity flex-1 pr-2">
                <h2 class="text-lg font-bold text-gray-900 line-clamp-1 leading-tight hover:text-[#24963f] transition-colors"><%= item.product.name %></h2>
                <p class="text-xs text-gray-400 mt-1 max-w-md line-clamp-1">Premium quality edition • <%= item.product.description || 'Modern usability and comfortable build.' %></p>
              </a>

              <button onclick="removeToCart('<%= item.product._id %>')" class="p-2 text-gray-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors duration-200 shrink-0" title="Remove item">
                <i class="fa-regular fa-trash-can text-lg"></i>
              </button>
            </div>

            <div class="mt-4 pt-4 border-t border-gray-50 flex items-center justify-between flex-wrap gap-4">
              
              <div class="flex items-center border border-gray-200 rounded-xl bg-gray-50/50 p-1 shadow-sm">
                <button onclick="descreaseQty('<%= item.product._id %>')" class="w-8 h-8 rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-gray-100 active:scale-95 transition flex items-center justify-center font-medium shadow-sm">
                  <i class="fa-solid fa-minus text-xs"></i>
                </button>
                <span id="quantityNumber-<%= item.product._id %>" class="font-bold text-sm text-gray-800 w-10 text-center"><%= item.quantity %></span>
                <button onclick="increaseQty('<%= item.product._id %>')" class="w-8 h-8 rounded-lg bg-black text-white hover:bg-gray-800 active:scale-95 transition flex items-center justify-center font-medium shadow-sm">
                  <i class="fa-solid fa-plus text-xs"></i>
                </button>
              </div>

              <div class="flex items-center gap-6 text-right">
                <div>
                  <span class="block text-[10px] uppercase font-bold tracking-wider text-gray-400">Price</span>
                  <span class="font-medium text-sm text-gray-500">₹<%= item.product.price %></span>
                </div>
                <div>
                  <span class="block text-[10px] uppercase font-bold tracking-wider text-gray-400">Subtotal</span>
                  <span id="subtotal-<%= item.product._id %>" class="font-bold text-base text-gray-900">₹<%= subTotal %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

      <div class="lg:sticky lg:top-8 space-y-6">
        
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 pb-4 border-b border-gray-100 mb-5">Order Summary</h2>
          <div class="space-y-3.5 text-sm">
            <div class="flex justify-between text-gray-500">
              <span>Total Items</span>
              <span class="font-medium text-gray-900"><%= products.length %></span>
            </div>
            <div class="flex justify-between text-gray-500">
              <span>Shipping Fee</span>
              <span class="text-emerald-600 font-semibold bg-emerald-50 px-2 py-0.5 rounded text-xs">FREE</span>
            </div>
            <div class="flex justify-between text-gray-500">
              <span>Platform Convenience Fee</span>
              <span class="font-medium text-gray-900">₹20</span>
            </div>
          </div>
          <div class="my-5 border-t border-dashed border-gray-200"></div>
          <div class="flex justify-between items-baseline">
            <h3 class="text-base font-medium text-gray-800">Total Payable</h3>
            <h3 id="grand-total" class="text-2xl font-black text-gray-900 tracking-tight">₹<%= total + 20 %></h3>
          </div>
        </div>

        <form action="/users/cart/checkout" method="POST" onsubmit="showLoader(event)" class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xs font-black uppercase tracking-wider text-gray-400">Delivery Address</h3>
            <a href="/users/profile" class="text-[#24963f] hover:text-[#1e7e34] text-xs font-bold transition-colors">
              <i class="fa-solid fa-plus mr-1"></i> Add New
            </a>
          </div>
          
          <div class="space-y-3">
            <% if (user && user.addresses && user.addresses.length > 0) { %>
              <% 
                let defaultAddr = user.addresses.find(a => a.isDefault) || user.addresses[0]; 
                let otherAddresses = user.addresses.filter(a => a._id.toString() !== defaultAddr._id.toString());
              %>

              <label class="border rounded-xl p-3.5 flex items-start gap-3 cursor-pointer transition-all relative overflow-hidden border-[#24963f] bg-[#24963f]/[0.02]" 
                     id="label-<%= defaultAddr._id %>">
                <input type="radio" 
                       name="address" 
                       value="<%= defaultAddr.flatNo %>, <%= defaultAddr.area %>, <%= defaultAddr.city %> - <%= defaultAddr.pincode %>" 
                       class="mt-1 accent-[#24963f] h-4 w-4 shrink-0"
                       checked
                       required
                       onclick="highlightAddress('<%= defaultAddr._id %>')">
                
                <div class="text-xs min-w-0">
                  <span class="inline-block font-black uppercase text-[9px] tracking-wider px-2 py-0.5 bg-emerald-500 text-white rounded mb-1.5">
                    <i class="fa-solid <%= defaultAddr.title === 'Home' ? 'fa-house' : defaultAddr.title === 'Office' ? 'fa-briefcase' : 'fa-location-dot' %> mr-1 text-[10px]"></i>
                    <%= defaultAddr.title %> (Default)
                  </span>
                  <p class="font-bold text-gray-800 truncate"><%= defaultAddr.flatNo %></p>
                  <p class="text-gray-500 truncate mt-0.5"><%= defaultAddr.area %></p>
                  <p class="text-[10px] text-gray-400 font-medium mt-1"><%= defaultAddr.city %>, <%= defaultAddr.pincode %></p>
                </div>
              </label>

              <% if (otherAddresses.length > 0) { %>
                <div class="pt-1">
                  <button type="button" onclick="toggleCheckoutAddresses(event)" class="w-full flex items-center justify-between px-3 py-2 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl text-xs font-bold text-gray-600 transition-all">
                    <span class="flex items-center gap-1.5">
                      <i class="fa-solid fa-map-location-dot text-gray-400"></i>
                      Choose Other Address (<%= otherAddresses.length %>)
                    </span>
                    <i id="addressArrow" class="fa-solid fa-chevron-down text-[9px] transition-transform duration-300"></i>
                  </button>

                  <div id="otherAddressesList" class="hidden mt-3 space-y-3">
                    <% otherAddresses.forEach((addr) => { %>
                      <label class="border border-gray-100 rounded-xl p-3.5 flex items-start gap-3 cursor-pointer transition-all relative overflow-hidden bg-gray-50/50 hover:bg-gray-50" 
                             id="label-<%= addr._id %>">
                        <input type="radio" 
                               name="address" 
                               value="<%= addr.flatNo %>, <%= addr.area %>, <%= addr.city %> - <%= addr.pincode %>" 
                               class="mt-1 accent-[#24963f] h-4 w-4 shrink-0"
                               onclick="highlightAddress('<%= addr._id %>')">
                        
                        <div class="text-xs min-w-0">
                          <span class="inline-block font-black uppercase text-[9px] tracking-wider px-2 py-0.5 bg-gray-200 text-gray-700 rounded mb-1.5">
                            <i class="fa-solid <%= addr.title === 'Home' ? 'fa-house' : addr.title === 'Office' ? 'fa-briefcase' : 'fa-location-dot' %> mr-1 text-[10px]"></i>
                            <%= addr.title %>
                          </span>
                          <p class="font-bold text-gray-800 truncate"><%= addr.flatNo %></p>
                          <p class="text-gray-500 truncate mt-0.5"><%= addr.area %></p>
                          <p class="text-[10px] text-gray-400 font-medium mt-1"><%= addr.city %>, <%= addr.pincode %></p>
                        </div>
                      </label>
                    <% }) %>
                  </div>
                </div>
              <% } %>

            <% } else { %>
              <div class="text-center py-6 border border-dashed border-red-200 bg-red-50/30 rounded-xl">
                <p class="text-xs font-bold text-red-500">No saved addresses found!</p>
                <a href="/users/profile" class="mt-3 inline-block bg-black text-white text-[10px] font-black px-4 py-2 rounded-xl uppercase tracking-wider hover:bg-gray-800 transition-colors">
                  Create Address First
                </a>
              </div>
            <% } %>
          </div>

          <div class="my-5 border-t border-gray-100"></div>
          
          <% if (user && user.addresses && user.addresses.length > 0) { %>
            <button type="button" onclick="openOrderModal()" class="w-full bg-[#24963f] hover:bg-[#1e7e34] text-white py-3.5 rounded-xl font-black text-sm tracking-wide transition-all shadow-md shadow-emerald-700/10 active:scale-[0.99] flex items-center justify-center gap-2">
              <i class="fa-solid fa-arrow-right-to-bracket text-xs"></i> Order Now
            </button>
          <% } else { %>
            <button type="button" disabled class="w-full bg-gray-200 text-gray-400 py-3.5 rounded-xl font-black text-sm cursor-not-allowed text-center">
              Please Add an Address to Order
            </button>
          <% } %>
        </form>

        <div class="flex items-center justify-center gap-4 text-[11px] text-gray-400 font-medium">
          <span class="flex items-center gap-1"><i class="fa-solid fa-shield-halved text-emerald-500"></i> 100% Secure</span>
          <span>•</span>
          <span class="flex items-center gap-1"><i class="fa-solid fa-arrow-rotate-left"></i> Easy Returns</span>
        </div>
      </div>

    </div>

    <% } else { %>
      <div class="max-w-md mx-auto bg-white rounded-3xl border border-gray-100 p-10 text-center shadow-sm my-10">
        <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-gray-100">
          <i class="fa-solid fa-basket-shopping text-2xl text-gray-300"></i>
        </div>
        <h2 class="text-xl font-bold text-gray-900">Your cart is empty</h2>
        <p class="text-sm text-gray-400 mt-2 max-w-xs mx-auto">Looks like you haven't added anything yet. Let's find something incredible for you.</p>
        <a href="/products/allProducts" class="inline-flex items-center justify-center bg-black text-white font-semibold text-sm px-6 py-3 rounded-xl mt-6 hover:bg-gray-800 transition shadow-md shadow-gray-900/10 gap-2">
          Start Shopping <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>
    <% } %>

  </div>

  <div id="orderConfirmModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeOrderModal()"></div>
    
    <div class="bg-white rounded-3xl border border-gray-100 max-w-md w-full p-6 shadow-2xl relative z-10 animate-[fadeIn_0.2s_ease-out]">
      <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center mb-4 border border-emerald-100">
        <i class="fa-solid fa-cart-shopping text-xl text-[#24963f]"></i>
      </div>
      
      <h3 class="text-xl font-black text-gray-900 tracking-tight">Confirm Your Order</h3>
      <p class="text-xs text-gray-500 mt-1">Please review your order details before final placement.</p>
      
      <div class="my-4 border-t border-gray-100"></div>
      
      <div class="space-y-3 bg-gray-50 p-4 rounded-xl text-xs font-medium text-gray-600 mb-6">
        <div class="flex justify-between items-center">
          <span>Total Payable Amount:</span>
          <span id="modalTotalAmount" class="font-black text-base text-gray-900"></span>
        </div>
        <div class="border-t border-dashed border-gray-200 my-2"></div>
        <div>
          <span class="block text-[10px] uppercase font-bold text-gray-400 tracking-wider mb-1">Delivering To:</span>
          <p id="modalAddressText" class="text-gray-800 font-bold leading-relaxed line-clamp-2"></p>
        </div>
      </div>
      
      <div class="grid grid-cols-2 gap-3">
        <button type="button" onclick="closeOrderModal()" class="py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold text-xs rounded-xl transition-all text-center">
          Cancel
        </button>
        <button type="button" onclick="submitFinalOrder(event)" class="py-3 bg-[#24963f] hover:bg-[#1e7e34] text-white font-black text-xs rounded-xl shadow-md shadow-emerald-700/10 transition-all text-center flex items-center justify-center gap-1.5">
          <i class="fa-solid fa-circle-check text-[10px]"></i> Place Order
        </button>
      </div>
    </div>
  </div>

  <script>
    // 🏠 ADDRESS SELECTION HIGHLIGHTER
    function highlightAddress(selectedId) {
      document.querySelectorAll('form label').forEach(lbl => {
        lbl.classList.remove('border-[#24963f]', 'bg-[#24963f]/[0.02]');
        lbl.classList.add('border-gray-100');
      });
      const currentLabel = document.getElementById('label-' + selectedId);
      if (currentLabel) {
        currentLabel.classList.remove('border-gray-100');
        currentLabel.classList.add('border-[#24963f]', 'bg-[#24963f]/[0.02]');
        
        const radioInput = currentLabel.querySelector('input[type="radio"]');
        if (radioInput) radioInput.checked = true;
      }
    }

    // 🗺️ TOGGLE ACCORDION ADDRESSES
    function toggleCheckoutAddresses(event) {
      event.preventDefault();
      const list = document.getElementById('otherAddressesList');
      const arrow = document.getElementById('addressArrow');
      if (list && arrow) {
        list.classList.toggle('hidden');
        arrow.classList.toggle('rotate-180');
      }
    }

    // 🎯 OPEN ORDER OVERLAY MODAL
    function openOrderModal() {
      const modal = document.getElementById('orderConfirmModal');
      const grandTotalEl = document.getElementById('grand-total');
      const finalTotalText = grandTotalEl ? grandTotalEl.innerText : '₹0';
      
      const selectedAddressInput = document.querySelector('input[name="address"]:checked');
      
      if (!selectedAddressInput) {
        alert("Please select a delivery address first!");
        return;
      }
      
      document.getElementById('modalTotalAmount').innerText = finalTotalText;
      document.getElementById('modalAddressText').innerText = selectedAddressInput.value;
      
      if (modal) modal.classList.remove('hidden');
    }

    // ❌ CLOSE OVERLAY MODAL
    function closeOrderModal() {
      const modal = document.getElementById('orderConfirmModal');
      if (modal) modal.classList.add('hidden');
    }

    // 🚀 SUBMIT FINAL ORDER ACTION
    function submitFinalOrder(event) {
      const checkoutForm = document.querySelector('form[action="/users/cart/checkout"]');
      if (checkoutForm) {
        event.target.disabled = true;
        event.target.innerHTML = `<i class="fa-solid fa-spinner animate-spin mr-1"></i> Placing...`;
        checkoutForm.submit();
      }
    }
  </script>

  <%- include('partials/header-scripts') %>
  <%- include('partials/updateQty') %>
  <%- include('partials/cartPage/removeToCart') %>
  <%- include('partials/loader') %>

</body>
</html>