<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart | KushNova</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>

<body class="bg-[#f8f9fa] text-gray-900 antialiased">

  <header class="nav-sticky bg-white border-b border-gray-100 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 md:px-6 h-20 flex items-center justify-between gap-4">
        
        <div class="flex items-center gap-6 shrink-0">
          <a href="/" class="text-2xl font-black tracking-tighter text-[#24963f]">APNA<span class="text-black">MART</span></a>
          
          <div class="hidden lg:block border-l border-gray-200 pl-6">
            <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 leading-none mb-1">Delivery in 10-12 mins</p>
            <p class="text-xs font-bold text-gray-900 flex items-center gap-1">
              Bhopal, India <i class="fa-solid fa-caret-down text-[10px] text-[#24963f]"></i>
            </p>
          </div>
        </div>

        <div class="flex-1 max-w-xl relative group mx-2">
          <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-[#24963f] transition-colors"></i>
          <input type="text" 
                placeholder='Search for "milk", "bread" or "veggies"...' 
                class="w-full bg-gray-50 border border-gray-100 rounded-xl py-3 pl-12 pr-4 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-[#24963f]/20 focus:bg-white focus:border-[#24963f] transition-all">
        </div>

        <div class="flex items-center gap-4 shrink-0">
          
          <% if(user){ %>
            <div class="relative inline-block text-left group">
              <button type="button" class="flex items-center gap-2 py-2.5 px-3.5 bg-gray-50 hover:bg-gray-100 border border-gray-100 rounded-xl transition-all duration-200">
                <div class="w-6 h-6 rounded-lg bg-[#24963f] text-white flex items-center justify-center text-[10px] font-black uppercase shadow-sm">
                  <%= user.name ? user.name.substring(0, 2) : 'A' %>
                </div>
                <span class="text-xs font-bold text-gray-700 hidden sm:block">My Account</span>
                <i class="fa-solid fa-chevron-down text-[9px] text-gray-400 group-hover:rotate-180 transition-transform duration-200"></i>
              </button>

              <div class="absolute right-0 w-56 mt-2 origin-top-right bg-white border border-gray-100 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.08)] opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-150 z-50">
                <div class="p-4 border-b border-gray-50">
                  <span class="inline-block text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded <%= user.role === 'admin' ? 'bg-red-50 text-red-600 border border-red-100' : 'bg-emerald-50 text-emerald-600 border border-emerald-100' %>">
                    <%= user.role ? user.role : 'Customer' %>
                  </span>
                  <p class="text-sm font-extrabold text-gray-900 truncate mt-1.5"><%= user.name %></p>
                  <p class="text-xs text-gray-400 truncate"><%= user.email %></p>
                </div>
                
                <div class="p-2 space-y-0.5">
                  <% if(user.role === 'admin') { %>
                    <a href="/products/allProducts" class="flex items-center gap-3 px-3 py-2.5 text-xs font-bold text-gray-600 hover:bg-gray-50 hover:text-[#24963f] rounded-xl transition-all">
                      <i class="fa-solid fa-boxes-stacked text-sm opacity-70"></i> Dashboard / Catalog
                    </a>
                    <a href="/products/create" class="flex items-center gap-3 px-3 py-2.5 text-xs font-bold text-gray-600 hover:bg-gray-50 hover:text-[#24963f] rounded-xl transition-all">
                      <i class="fa-solid fa-plus text-sm opacity-70"></i> Add New Item
                    </a>
                  <% } %>
                  <a href="/users/orders" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-gray-600 hover:bg-emerald-50 hover:text-emerald-600 rounded-xl transition-all">
                    <i class="fa-solid fa-clock-rotate-left text-[11px] opacity-70"></i> My Orders
                  </a>
                </div>

                <div class="p-2 border-t border-gray-50 bg-gray-50/50 rounded-b-2xl">
                  <a href="/users/logout" class="flex items-center gap-3 px-3 py-2.5 text-xs font-extrabold text-red-500 hover:bg-red-50 rounded-xl transition-all">
                    <i class="fa-solid fa-arrow-right-from-bracket text-sm"></i> Secure Logout
                  </a>
                </div>
              </div>
            </div>
          <% } else { %>
            <a href="/users/login" class="text-xs font-bold text-gray-600 hover:text-[#24963f] transition-colors">Login</a>
          <% } %>

          <% if(user && user.cart && user.cart.length > 0) { %>
            <% 
              let totalCartPrice = 0;
              if (user.cart && user.cart.length > 0) {
                user.cart.forEach(item => {
                  totalCartPrice += Number(item.price || 0);
                });
              }
            %>
            <a href="/users/cart/products" class="flex items-center gap-3 bg-[#24963f] hover:bg-[#1e7e34] text-white px-4 py-2.5 rounded-xl transition-all shadow-md shadow-emerald-700/20">
              <div class="flex flex-col text-left">
                <span class="text-[10px] font-black uppercase tracking-wider text-emerald-200 leading-none"><%= user.cart.length %> Items</span>
                <span class="text-xs font-black mt-0.5"><%= totalCartPrice > 0 ? '₹' + totalCartPrice : 'View Bill' %></span>
              </div>
              <div class="h-6 w-[1px] bg-white/20"></div>
              <div class="flex items-center gap-1.5 font-extrabold text-xs tracking-tight">
                <i class="fa-solid fa-basket-shopping"></i>
                <span class="hidden sm:inline">View Basket</span>
              </div>
            </a>
          <% } else { %>
            <a href="/users/cart/products" class="flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 px-5 py-3 rounded-xl transition-all font-extrabold text-xs uppercase tracking-wider border border-gray-200/20">
              <i class="fa-solid fa-basket-shopping text-sm text-gray-400"></i>
              <span>Cart</span>
            </a>
          <% } %>

        </div>
      </div>
  </header>

  <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between border-b border-gray-200 pb-5 mb-10 gap-4">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Shopping Cart</h1>
        <p class="text-sm text-gray-500 mt-1">Review your selected items before checking out.</p>
      </div>
      <a href="/products/allProducts"
        class="inline-flex items-center justify-center bg-white text-gray-700 border border-gray-300 px-5 py-2.5 rounded-xl font-medium text-sm hover:bg-gray-50 shadow-sm transition-all duration-200 gap-2 group">
        <i class="fa-solid fa-arrow-left text-xs text-gray-400 group-hover:-translate-x-1 transition-transform"></i>
        Continue Shopping
      </a>
    </div>

    <% if(products.length > 0 ){ %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">

      <!-- Left Column: Products List -->
      <div class="lg:col-span-2 space-y-5">

        <% let total = 0; %>

        <% products.forEach((item) => { %>
          <% if (!item.product) { return; } %>
          <% 
            const subTotal = item.product.price * item.quantity;
            total += subTotal;
          %>

          <div id="product-<%= item.product._id %>"
              class="bg-white rounded-2xl border border-gray-100 p-5 flex flex-col sm:flex-row gap-5 items-start sm:items-center relative hover:shadow-lg hover:shadow-gray-100/80 transition-all duration-300">
            
            <div class="w-28 h-28 sm:w-24 sm:h-24 overflow-hidden rounded-xl bg-gray-50 flex-shrink-0 border border-gray-100 shadow-inner">
              <img 
                src="/uploads/<%= item.product.image %>" 
                class="w-full h-full object-cover object-center transition-transform duration-500 hover:scale-105"
                alt="<%= item.product.name %>"
              >
            </div>

            <div class="flex-1 w-full">
              <div class="flex justify-between items-start">
                <div>
                  <h2 class="text-lg font-bold text-gray-900 line-clamp-1 leading-tight">
                    <%= item.product.name %>
                  </h2>
                  <p class="text-xs text-gray-400 mt-1 max-w-md line-clamp-1">
                    Premium quality edition • <%= item.product.description || 'Modern usability and comfortable build.' %>
                  </p>
                </div>

                <button 
                  onclick="removeToCart('<%= item.product._id %>')"
                  class="p-2 text-gray-400 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors duration-200"
                  title="Remove item"
                >
                  <i class="fa-regular fa-trash-can text-lg"></i>
                </button>
              </div>

              <div class="mt-4 pt-4 border-t border-gray-50 flex items-center justify-between flex-wrap gap-4">
                
                <div class="flex items-center border border-gray-200 rounded-xl bg-gray-50/50 p-1 shadow-sm">
                  <button
                    onclick="descreaseQty('<%= item.product._id %>')"
                    class="w-8 h-8 rounded-lg bg-white border border-gray-200 text-gray-600 hover:bg-gray-100 active:scale-95 transition flex items-center justify-center font-medium shadow-sm"
                  >
                    <i class="fa-solid fa-minus text-xs"></i>
                  </button>

                  <span id="quantityNumber-<%= item.product._id %>" class="font-bold text-sm text-gray-800 w-10 text-center">
                    <%= item.quantity %>
                  </span>

                  <button
                    onclick="increaseQty('<%= item.product._id %>')"
                    class="w-8 h-8 rounded-lg bg-black text-white hover:bg-gray-800 active:scale-95 transition flex items-center justify-center font-medium shadow-sm"
                  >
                    <i class="fa-solid fa-plus text-xs"></i>
                  </button>
                </div>

                <div class="flex items-center gap-6 text-right">
                  <div>
                    <span class="block text-[10px] uppercase font-bold tracking-wider text-gray-400">Price</span>
                    <span class="font-medium text-sm text-gray-500">₹<%= item.product.price %></span>
                  </div>
                  <div>
                    <span class="block text-[10px] uppercase font-bold tracking-wider text-gray-400">Subtotal</span>
                    <span id="subtotal-<%= item.product._id %>" class="font-bold text-base text-gray-900">
                      ₹<%= subTotal %>
                    </span>
                  </div>
                </div>

              </div>
            </div>
          </div>

        <% }) %>

      </div>

      <!-- Right Column: Order Summary & Saved Address Selection -->
      <div class="lg:sticky lg:top-8 space-y-6">
        
        <!-- Order Summary Card -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 pb-4 border-b border-gray-100 mb-5">
            Order Summary
          </h2>

          <div class="space-y-3.5 text-sm">
            <div class="flex justify-between text-gray-500">
              <span>Total Items</span>
              <span class="font-medium text-gray-900"><%= products.length %></span>
            </div>

            <div class="flex justify-between text-gray-500">
              <span>Shipping Fee</span>
              <span class="text-emerald-600 font-semibold bg-emerald-50 px-2 py-0.5 rounded text-xs">
                FREE
              </span>
            </div>

            <div class="flex justify-between text-gray-500">
              <span>Platform Convenience Fee</span>
              <span class="font-medium text-gray-900">₹20</span>
            </div>
          </div>

          <div class="my-5 border-t border-dashed border-gray-200"></div>

          <div class="flex justify-between items-baseline">
            <h3 class="text-base font-medium text-gray-800">Total Payable</h3>
            <h3 id="finalTotal" class="text-2xl font-black text-gray-900 tracking-tight">
              ₹<%= total + 20 %>
            </h3>
          </div>
        </div>

        <!-- 📍 Saved Address Selection & Checkout Form -->
        <form action="/users/cart/checkout" method="POST" class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xs font-black uppercase tracking-wider text-gray-400">Select Delivery Address</h3>
            <a href="/users/profile" class="text-[#24963f] hover:text-[#1e7e34] text-xs font-bold transition-colors">
              <i class="fa-solid fa-plus mr-1"></i> Add New
            </a>
          </div>
          
          <!-- Address Selection Cards Grid -->
          <div class="space-y-3 max-h-[280px] overflow-y-auto pr-1">
            <% if (user && user.addresses && user.addresses.length > 0) { %>
              <% user.addresses.forEach((addr, index) => { %>
                
                <label class="border rounded-xl p-3.5 flex items-start gap-3 cursor-pointer transition-all relative overflow-hidden bg-gray-50/50 hover:bg-gray-50
                              <%= index === 0 ? 'border-[#24963f] bg-[#24963f]/[0.02]' : 'border-gray-100' %>" 
                       id="label-<%= addr._id %>">
                  
                  <input type="radio" 
                         name="address" 
                         value="<%= addr.flatNo %>, <%= addr.area %>, <%= addr.city %> - <%= addr.pincode %>" 
                         class="mt-1 accent-[#24963f] h-4 w-4 shrink-0"
                         <%= index === 0 ? 'checked' : '' %>
                         required
                         onclick="highlightAddress('<%= addr._id %>')">
                  
                  <div class="text-xs min-w-0">
                    <span class="inline-block font-black uppercase text-[9px] tracking-wider px-2 py-0.5 bg-gray-200 text-gray-700 rounded mb-1.5">
                      <i class="fa-solid <%= addr.title === 'Home' ? 'fa-house' : addr.title === 'Office' ? 'fa-briefcase' : 'fa-location-dot' %> mr-1 text-[10px]"></i>
                      <%= addr.title %>
                    </span>
                    <p class="font-bold text-gray-800 truncate"><%= addr.flatNo %></p>
                    <p class="text-gray-500 truncate mt-0.5"><%= addr.area %></p>
                    <p class="text-[10px] text-gray-400 font-medium mt-1"><%= addr.city %>, <%= addr.pincode %></p>
                  </div>
                </label>

              <% }) %>
            <% } else { %>
              <!-- Alert if No Address Found -->
              <div class="text-center py-6 border border-dashed border-red-200 bg-red-50/30 rounded-xl">
                <p class="text-xs font-bold text-red-500">No saved addresses found!</p>
                <a href="/users/profile" class="mt-3 inline-block bg-black text-white text-[10px] font-black px-4 py-2 rounded-xl uppercase tracking-wider hover:bg-gray-800 transition-colors">
                  Create Address First
                </a>
              </div>
            <% } %>
          </div>

          <div class="my-5 border-t border-gray-100"></div>
          
          <!-- Submit Button (Enabled only if addresses exist) -->
          <% if (user && user.addresses && user.addresses.length > 0) { %>
            <button type="submit" class="w-full bg-[#24963f] hover:bg-[#1e7e34] text-white py-3.5 rounded-xl font-black text-sm tracking-wide transition-all shadow-md shadow-emerald-700/10 active:scale-[0.99] flex items-center justify-center gap-2">
              <i class="fa-solid fa-bolt text-xs"></i> Confirm & Place Order
            </button>
          <% } else { %>
            <button type="button" disabled class="w-full bg-gray-200 text-gray-400 py-3.5 rounded-xl font-black text-sm cursor-not-allowed text-center">
              Please Add an Address to Order
            </button>
          <% } %>
        </form>

        <!-- Trust Badges -->
        <div class="flex items-center justify-center gap-4 text-[11px] text-gray-400 font-medium">
          <span class="flex items-center gap-1"><i class="fa-solid fa-shield-halved text-emerald-500"></i> 100% Secure</span>
          <span>•</span>
          <span class="flex items-center gap-1"><i class="fa-solid fa-arrow-rotate-left"></i> Easy Returns</span>
        </div>
      </div>

    </div>

    <% } else { %>

      <div class="max-w-md mx-auto bg-white rounded-3xl border border-gray-100 p-10 text-center shadow-sm my-10">
        <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-gray-100">
          <i class="fa-solid fa-basket-shopping text-2xl text-gray-300"></i>
        </div>

        <h2 class="text-xl font-bold text-gray-900">Your cart is empty</h2>
        <p class="text-sm text-gray-400 mt-2 max-w-xs mx-auto">
          Looks like you haven't added anything yet. Let's find something incredible for you.
        </p>

        <a href="/products/allProducts"
          class="inline-flex items-center justify-center bg-black text-white font-semibold text-sm px-6 py-3 rounded-xl mt-6 hover:bg-gray-800 transition shadow-md shadow-gray-900/10 gap-2">
          Start Shopping
          <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
      </div>

    <% } %>

  </div>

  <script>
    // Selected Address Radio border styling toggler
    function highlightAddress(selectedId) {
      document.querySelectorAll('form label').forEach(lbl => {
        lbl.classList.remove('border-[#24963f]', 'bg-[#24963f]/[0.02]');
        lbl.classList.add('border-gray-100');
      });
      const currentLabel = document.getElementById('label-' + selectedId);
      if (currentLabel) {
        currentLabel.classList.remove('border-gray-100');
        currentLabel.classList.add('border-[#24963f]', 'bg-[#24963f]/[0.02]');
      }
    }

    async function removeToCart(productId) {
      try {
        let res = await fetch(`/users/cart/remove-product/${productId}`, { method: 'POST' });
        let data = await res.json();
        if(data.success) { location.reload(); }
      } catch(error) { console.log(error); }
    }

    async function increaseQty(productId) {
      let res = await fetch(`/users/cart/update/increaseQty/${productId}`, { method: 'POST' });
      let data = await res.json();
      if(data.success) { location.reload(); }
    }

    async function descreaseQty(productId) {
      let res = await fetch(`/users/cart/update/descreaseQty/${productId}`, { method: 'POST' });
      let data = await res.json();
      if(data.success) { location.reload(); }
    }
  </script>

</body>
</html>