<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Order Control Center | Kushwaha Kirana Store</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    /* हाइड स्क्रॉलबार */
    .scrollbar-none::-webkit-scrollbar { display: none; }
    .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>

<body class="bg-[#fafafa] text-gray-950 antialiased">

  <!-- MASTER FLEX FRAMEWORK -->
  <div class="min-h-screen flex flex-col">
    
    <!-- Include Admin Sidebar -->
    <%- include('partials/adminSidebar')%>
    
    <!-- FIXED MAIN ROUTER: md:ml-64 keeps content clear of the desktop sidebar, min-w-0 prevents data blowouts -->
    <main class="flex-1 w-full min-w-0 p-5 sm:p-8 lg:p-12 md:ml-64 transition-all duration-300">
      
      <!-- HEADER ZONE -->
      <div class="mb-8 pb-5 border-b border-zinc-200/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-2 mb-1.5 text-[11px] font-medium text-gray-400">
            <span>Admin Control Panel</span>
            <span class="text-gray-300">/</span>
            <span class="font-semibold text-red-600">Order Routing Center</span>
          </div>
          <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-gray-900">
            Live Order Control Console
          </h2>
        </div>
        
        <div>
          <span class="inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-xl bg-red-50 text-red-700 border border-red-100">
            <span class="w-1.5 h-1.5 rounded-full bg-red-600 animate-ping"></span>
            Real-Time Monitor Active
          </span>
        </div>
      </div>

      <!-- KPI METRIC GRID -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white border border-zinc-100 p-5 rounded-2xl flex items-center justify-between shadow-sm hover:shadow-md transition-shadow">
          <div>
            <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider block">Total Bookings</span>
            <p class="text-2xl font-black mt-1 text-zinc-900"><%= orders.length %></p>
          </div>
          <div class="w-10 h-10 rounded-xl bg-zinc-100 text-zinc-800 flex items-center justify-center border border-zinc-200/60 shadow-sm"><i class="fa-solid fa-boxes-stacked text-sm"></i></div>
        </div>
        
        <div class="bg-white border border-zinc-100 p-5 rounded-2xl flex items-center justify-between shadow-sm hover:shadow-md transition-shadow">
          <div>
            <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider block">Awaiting Dispatch</span>
            <p class="text-2xl font-black mt-1 text-amber-600"><%= orders.filter(o => o.status === 'Pending').length %></p>
          </div>
          <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100 shadow-sm"><i class="fa-solid fa-spinner animate-spin text-sm"></i></div>
        </div>

        <div class="bg-white border border-zinc-100 p-5 rounded-2xl flex items-center justify-between shadow-sm hover:shadow-md transition-shadow">
          <div>
            <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider block">On Transit Delivery</span>
            <p class="text-2xl font-black mt-1 text-blue-600"><%= orders.filter(o => o.status === 'Dispatched').length %></p>
          </div>
          <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100 shadow-sm"><i class="fa-solid fa-truck-fast text-sm"></i></div>
        </div>

        <div class="bg-white border border-zinc-100 p-5 rounded-2xl flex items-center justify-between shadow-sm hover:shadow-md transition-shadow">
          <div>
            <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider block">Gross Turnover</span>
            <% let grandTotal = orders.reduce((acc, o) => acc + o.totalPrice, 0); %>
            <p class="text-2xl font-black mt-1 text-emerald-600">₹<%= grandTotal %></p>
          </div>
          <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100 shadow-sm"><i class="fa-solid fa-indian-rupee-sign text-sm"></i></div>
        </div>
      </div>

      <!-- FILTER PIPELINES -->
      <div class="flex items-center gap-2 border-b border-zinc-200/60 pb-3 mb-6 overflow-x-auto scrollbar-none select-none">
        <button onclick="filterOrders('All')" class="tab-btn px-4 py-2 text-xs font-black uppercase tracking-wider border-b-2 border-red-600 text-red-600 bg-red-50/50 rounded-t-xl transition-all">All Inbound</button>
        <button onclick="filterOrders('Pending')" class="tab-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-gray-900 transition-all">Pending Pipeline</button>
        <button onclick="filterOrders('Dispatched')" class="tab-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-gray-900 transition-all">Out For Delivery</button>
        <button onclick="filterOrders('Delivered')" class="tab-btn px-4 py-2 text-xs font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400 hover:text-gray-900 transition-all">Completed Orders</button>
      </div>

      <!-- SYSTEM LOG WORKSPACE -->
      <% if(orders.length === 0) { %>
        <div class="text-center py-24 border border-dashed rounded-[32px] border-zinc-200 bg-white shadow-sm">
          <i class="fa-solid fa-circle-nodes text-3xl text-zinc-300 mb-4 block"></i>
          <p class="text-xs text-gray-400 font-black uppercase tracking-wider">No Orders Inbound In System Log</p>
        </div>
      <% } else { %>
        
        <div class="bg-white border border-zinc-100 rounded-3xl overflow-hidden shadow-xl shadow-zinc-100/50">
          <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse min-w-[1100px]">
              <thead>
                <tr class="bg-zinc-50 border-b border-zinc-100 text-[10px] font-black text-gray-400 uppercase tracking-widest select-none">
                  <th class="p-5 w-80">Ordered Products & Vol</th>
                  <th class="p-5">Customer Profile</th>
                  <th class="p-5 w-64">Fulfillment Address</th>
                  <th class="p-5">Gross Bill</th>
                  <th class="p-5">Order Reference Hash</th>
                  <th class="p-5 text-right">Console Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100 text-xs font-semibold text-gray-700">
                <% orders.forEach(order => { %>
                  <tr class="order-row hover:bg-zinc-50/80 transition-colors duration-150" data-status="<%= order.status %>">
                    
                    <td class="p-5">
                      <div class="space-y-3">
                        <% order.products.forEach(item => { %>
                          <div class="flex items-center gap-3 border-b border-zinc-50/60 pb-2 last:border-0 last:pb-0">
                            
                            <div class="w-10 h-10 rounded-xl bg-zinc-50 border border-zinc-200/60 flex items-center justify-center overflow-hidden shrink-0 shadow-inner font-black text-[10px] text-red-600 uppercase">
                              <% if (item.product && item.product.image) { %>
                                <img src="/uploads/<%= item.product.image %>" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <span class="hidden w-full h-full items-center justify-center bg-red-50 text-red-600"><%= item.product.name ? item.product.name.substring(0,2) : 'KP' %></span>
                              <% } else { %>
                                <span class="w-full h-full flex items-center justify-center bg-red-50 text-red-600"><%= item.product.name ? item.product.name.substring(0,2) : 'KP' %></span>
                              <% } %>
                            </div>

                            <div class="truncate">
                              <p class="font-black text-zinc-950 text-xs truncate"><%= item.product ? item.product.name : '📦 Grocery Asset Item' %></p>
                              <p class="text-[10px] text-gray-400 font-bold mt-0.5">
                                Price: ₹<%= item.product ? item.product.price : 0 %> 
                                <span class="text-red-600 ml-1.5 bg-red-50 border border-red-100/60 px-1.5 py-0.5 rounded font-black">QTY: x<%= item.quantity %></span>
                              </p>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    </td>

                    <td class="p-5">
                      <div class="flex items-center gap-2.5">
                        <div class="w-8 h-8 rounded-xl bg-zinc-900 text-white text-[11px] font-black flex items-center justify-center uppercase shadow-sm">
                          <%= (order.user && order.user.name) ? order.user.name.substring(0,2) : 'CU' %>
                        </div>
                        <div>
                          <p class="font-black text-zinc-950"><%= (order.user && order.user.name) ? order.user.name : 'Unregistered User' %></p>
                          <p class="text-[10px] text-gray-400 font-bold mt-0.5 flex items-center gap-1">
                            <i class="fa-solid fa-phone text-[9px] text-red-500"></i><%= (order.user && order.user.contact) ? order.user.contact : 'No Info' %>
                          </p>
                        </div>
                      </div>
                    </td>

                    <td class="p-5">
                      <p class="text-[11px] text-gray-600 leading-relaxed font-bold select-text">
                        <i class="fa-solid fa-location-dot text-[10px] text-red-600 mr-1"></i><%= order.address || "Counter Pick Address" %>
                      </p>
                    </td>

                    <td class="p-5">
                      <p class="text-sm font-black text-zinc-950">₹<%= order.totalPrice %></p>
                      
                      <span class="inline-block text-[8px] font-black uppercase tracking-wider px-2 py-0.5 rounded border mt-1.5
                        <%= order.status === 'Pending' ? 'bg-amber-50 text-amber-700 border-amber-200' : '' %>
                        <%= order.status === 'Dispatched' ? 'bg-blue-50 text-blue-700 border-blue-200' : '' %>
                        <%= order.status === 'Delivered' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : '' %>">
                        <%= order.status %>
                      </span>
                    </td>

                    <td class="p-5">
                      <p class="font-mono font-bold text-gray-400 select-text text-[10px] tracking-tight"><%= order._id %></p>
                      <p class="text-[9px] text-gray-400 font-black uppercase mt-1">
                        <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %> • 
                        <%= new Date(order.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %>
                      </p>
                    </td>

                    <td class="p-5 text-right">
                      <div class="inline-flex items-center gap-1.5">
                        
                        <a href="/admin/orders/invoice/<%= order._id %>" target="_blank" class="bg-zinc-50 hover:bg-zinc-100 border border-zinc-200 text-zinc-600 w-8 h-8 flex items-center justify-center rounded-xl text-xs transition-all hover:scale-105 active:scale-95" title="Print Invoice Statement">
                          <i class="fa-solid fa-print"></i>
                        </a>

                        <form action="/admin/orders/update/<%= order._id %>" method="POST" class="inline-flex items-center gap-1.5 bg-zinc-50 p-1 border border-zinc-200 rounded-xl shadow-sm">
                          <select name="status" class="bg-transparent text-[10px] font-black uppercase tracking-wider text-zinc-800 focus:outline-none px-2 cursor-pointer">
                            <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>⏳ Pending</option>
                            <option value="Dispatched" <%= order.status === 'Dispatched' ? 'selected' : '' %>>🚚 Dispatch</option>
                            <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>✅ Deliver</option>
                          </select>

                          <button type="submit" class="bg-red-600 hover:bg-red-700 text-white w-7 h-7 flex items-center justify-center rounded-lg transition-all active:scale-90 shadow-sm" title="Save Order Status">
                            <i class="fa-solid fa-floppy-disk text-xs"></i>
                          </button>
                        </form>

                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

      <% } %>

    </main>

  </div>

  <script>
    function filterOrders(status) {
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('border-red-600', 'text-red-600', 'bg-red-50/50');
        btn.classList.add('border-transparent', 'text-gray-400');
      });

      const activeBtn = event.currentTarget;
      activeBtn.classList.remove('border-transparent', 'text-gray-400');
      activeBtn.classList.add('border-red-600', 'text-red-600', 'bg-red-50/50');

      document.querySelectorAll('.order-row').forEach(row => {
        if(status === 'All' || row.getAttribute('data-status') === status) {
          row.style.display = 'table-row';
        } else {
          row.style.display = 'none';
        }
      });
    }
  </script>

</body>
</html>