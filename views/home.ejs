        <h4 class="text-white font-semibold">Support</h4>
        <ul class="text-zinc-500 space-y-2">
          <li><a href="#" class="hover:text-white transition">Customer Care</a></li>
          <li><a href="#" class="hover:text-white transition">Shipping Policy</a></li>
          <li><a href="#" class="hover:text-white transition">Returns</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <h4 class="text-white font-semibold">Company</h4>
        <ul class="text-zinc-500 space-y-2">
