      <h4 class="font-semibold">Urban Backpack</h4>
      <p class="text-sm text-zinc-500">Minimal & durable design</p>
      <div class="flex justify-between items-center mt-3">
        <span class="font-bold">$49</span>
        <button class="text-sm px-3 py-1 bg-white text-black rounded-lg">Buy</button>
