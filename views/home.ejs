  <!-- TOGGLE THEME -->
  <script>
    function toggleTheme() {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }

    (function () {
      const savedTheme = localStorage.getItem('theme');
      const html = document.documentElement;
      if (savedTheme === 'dark') { html.classList.add('dark'); } 
      else { html.classList.remove('dark'); }
    })();
  </script>

  <script>
    const track = document.getElementById('placeholderTrack');
    const searchInput = document.getElementById('searchInput');
    const placeholderContainer = document.querySelector('.placeholder-container');
    const itemsCount = track ? track.children.length : 0;

    let index = 0;
    let interval;

    function startAnimation(){
      if(!track) return;
      interval = setInterval(()=>{
        index++;
        if(index >= itemsCount){
          index = 0;
          track.style.transition = 'none';
          track.style.transform = 'translateY(0)';
          setTimeout(()=>{
            track.style.transition = 'transform 0.5s ease-in-out';
          }, 50);
        } else {
          track.style.transform = `translateY(-${index * 22}px)`;
        }
      }, 2000);
    }

    function pauseAnimation(){ clearInterval(interval); }

    function resumeAnimation(){
      if(searchInput && searchInput.value === ""){
        if(placeholderContainer) placeholderContainer.style.display = 'block';
        startAnimation();
      }
    }

    function hidePlaceholder(){ if(placeholderContainer) placeholderContainer.style.display = 'none'; }

  function liveSearchDropdown() {
  const input = document.getElementById('searchInput');
  const dropdown = document.getElementById('search-suggestions');
  const list = document.getElementById('suggestions-list');
  
  if (!input || !dropdown || !list) return;

  const value = input.value.toLowerCase().trim();
  
  // Agar input empty hai to dropdown band karo
  if (value === "") {
    dropdown.classList.add('hidden');
    return;
  }

  list.innerHTML = ""; // Purani list clear karo
  let matchCount = 0;

  // DOM ke real product cards se fast metadata read karna
  document.querySelectorAll('.product-card').forEach(card => {
    const nameTag = card.querySelector('.product-name');
    const imgTag = card.querySelector('img');
    const priceTag = card.querySelector('.font-black');
    
    if (nameTag) {
      const name = nameTag.innerText;
      const price = priceTag ? priceTag.innerText : '';
      const imgSrc = imgTag ? imgTag.src : '';

      if (name.toLowerCase().includes(value) && matchCount < 5) {
        matchCount++;
        
        // Element banana dropdown list ke liye
        const row = document.createElement('div');
        row.className = "flex items-center gap-3 p-2 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 rounded-xl cursor-pointer transition-colors";
        row.innerHTML = `
          <img src="${imgSrc}" class="w-8 h-8 rounded-lg object-cover bg-zinc-100">
          <div class="flex-1 min-w-0">
            <p class="text-xs font-bold text-zinc-800 dark:text-zinc-200 truncate">${name}</p>
            <p class="text-[10px] text-emerald-600 font-extrabold">${price}</p>
          </div>
          <i class="fa-solid fa-chevron-right text-[9px] text-zinc-400 pr-2"></i>
        `;
        
        // Click karne par directly use card ke view par scroll karwaye ya filter set kare
        row.onclick = () => {
          input.value = name;
          dropdown.classList.add('hidden');
          // Purana grid filter trigger karna
          document.querySelectorAll('.product-card').forEach(c => {
            const n = c.querySelector('.product-name').innerText.toLowerCase();
            c.style.display = n.includes(name.toLowerCase()) ? '' : 'none';
          });
        };
        list.appendChild(row);
      }
    }
  });

  if (matchCount > 0) {
    dropdown.classList.remove('hidden');
  } else {
    list.innerHTML = `<p class="text-center py-4 text-xs font-medium text-zinc-400"><i class="fa-solid fa-face-frown mr-1"></i> No matching products found</p>`;
    dropdown.classList.remove('hidden');
  }
}

// Dropdown ko bahar click karne par close karne ka tareeka
document.addEventListener('click', (e) => {
  const dropdown = document.getElementById('search-suggestions');
  const input = document.getElementById('searchInput');
  if (dropdown && !dropdown.contains(e.target) && e.target !== input) {
    dropdown.classList.add('hidden');
  }
});
    window.addEventListener('DOMContentLoaded', () => {
      if(searchInput) searchInput.value = ""; 
      startAnimation();
    });
  </script>

  <!-- SCELETON SCRIPT  -->
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      // Skeleton ko hide karo aur real grid ko show karo
      const skeletonGrid = document.getElementById('skeleton-grid');
      const realGrid = document.getElementById('real-products-grid');
      
      if(skeletonGrid && realGrid) {
        setTimeout(() => { // 400ms ka visual smooth delay
          skeletonGrid.classList.add('hidden');
          realGrid.classList.remove('hidden');
        }, 400);
      }
    });
  </script>
