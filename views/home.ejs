    </div>

    <div class="bg-[#111] border border-zinc-800 rounded-2xl p-4 card-hover">
      <div class="h-40 bg-zinc-800 rounded-xl mb-4"></div>
      <h4 class="font-semibold">Travel Pro Bag</h4>
      <p class="text-sm text-zinc-500">Perfect for long trips</p>
      <div class="flex justify-between items-center mt-3">
        <span class="font-bold">$79</span>
        <button class="text-sm px-3 py-1 bg-white text-black rounded-lg">Buy</button>
      </div>
    </div>

    <div class="bg-[#111] border border-zinc-800 rounded-2xl p-4 card-hover">
      <div class="h-40 bg-zinc-800 rounded-xl mb-4"></div>
      <h4 class="font-semibold">Classic Leather Bag</h4>
      <p class="text-sm text-zinc-500">Premium leather finish</p>
      <div class="flex justify-between items-center mt-3">
        <span class="font-bold">$99</span>
        <button class="text-sm px-3 py-1 bg-white text-black rounded-lg">Buy</button>
      </div>
    </div>

  </div>

</section>


