  <script>
    async function increaseQty(productId) {
      let res = await fetch(`/users/cart/update/increaseQty/${productId}`, { method: 'POST' });
      let data = await res.json();
      if(data.success) { location.reload(); }
    }

    async function descreaseQty(productId) {
      let res = await fetch(`/users/cart/update/descreaseQty/${productId}`, { method: 'POST' });
      let data = await res.json();
      if(data.success) { location.reload(); }
    }

    async function addToCart (productId){
      let res = await fetch(`/users/cart/add-to-cart/${productId}`,{ method: "POST" });
      let data = await res.json();
      alert(data.message); 
      if(data.success){ location.reload() }
    }

    function toggleTheme() {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }

    (function () {
      const savedTheme = localStorage.getItem('theme');
      const html = document.documentElement;
      if (savedTheme === 'dark') { html.classList.add('dark'); } 
      else { html.classList.remove('dark'); }
    })();
  </script>

  <!-- BLINKIT SEARCH SCRIPT -->
  <script>
    const track = document.getElementById('placeholderTrack');
    const searchInput = document.getElementById('searchInput');
    const placeholderContainer = document.querySelector('.placeholder-container');
    const itemsCount = track.children.length;

    let index = 0;
    let interval;

    function startAnimation(){
      interval = setInterval(()=>{
        index++;
        if(index >= itemsCount){
          index = 0;
          track.style.transition = 'none';
          track.style.transform = 'translateY(0)';
          setTimeout(()=>{
            track.style.transition = 'transform 0.5s ease-in-out';
          }, 50);
        } else {
          track.style.transform = `translateY(-${index * 22}px)`;
        }
      }, 2000);
    }

    function pauseAnimation(){ clearInterval(interval); }

    function resumeAnimation(){
      if(searchInput.value === ""){
        placeholderContainer.style.display = 'block';
        startAnimation();
      }
    }

    function hidePlaceholder(){ placeholderContainer.style.display = 'none'; }

    function searchProducts(){
      const value = searchInput.value.toLowerCase().trim();
      document.querySelectorAll('.product-card').forEach(card => {
        const nameTag = card.querySelector('.product-name');
        if (nameTag) {
          const name = nameTag.innerText.toLowerCase();
          card.style.display = name.includes(value) ? '' : 'none';
        }
      });
    }

    window.addEventListener('DOMContentLoaded', () => {
      searchInput.value = ""; // Form input reset on refresh
      startAnimation();
    });
  </script>

