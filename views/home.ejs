          <div class="flex justify-between items-center mt-4 pt-2.5 border-t border-zinc-900/80 dark:border-zinc-100">
            <div class="flex flex-col">
              <span class="font-black text-base text-white dark:text-zinc-900">₹<%= item.price %></span>
              <% if(item.discountPrice) { %>
                <span class="text-[10px] text-zinc-500 line-through">₹<%= item.discountPrice %></span>
              <% } %>
            </div>
            <button onclick="addToCart('<%= item._id %>')" class="text-center text-xs font-extrabold px-4 py-2 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-xl hover:bg-emerald-500 hover:text-black transition-all duration-200 shadow-sm dark:bg-emerald-50 dark:text-emerald-700 dark:border-emerald-200 dark:hover:bg-emerald-500 dark:hover:text-black">
              + ADD
            </button>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-span-full text-center py-12 text-zinc-500 text-sm font-medium">
        <i class="fa-solid fa-box-open text-3xl mb-3 block opacity-40"></i>
        No products found in the database. Please add some products from the dashboard!
      </div>
    <% } %>

  </div>

</section>

