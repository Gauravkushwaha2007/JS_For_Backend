      <% products.forEach(function(item) { %>
        <div class="group bg-[#0d110e]/60 border border-zinc-900 rounded-2xl p-4 hover:border-emerald-950 hover:shadow-xl hover:shadow-emerald-500/[0.01] transition-all duration-300 flex flex-col justify-between dark:bg-white dark:border-zinc-100 dark:hover:border-emerald-100 dark:hover:shadow-zinc-200/30">
