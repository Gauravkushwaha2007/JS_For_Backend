  </div>

  <!-- Links -->
  <div class="hidden md:flex gap-8 text-sm text-zinc-400">
    <a href="#" class="hover:text-white">Home</a>
    <a href="#products" class="hover:text-white">Shop</a>
    <a href="/products/allProducts" class="hover:text-white">Collections</a>
    <a href="#" class="hover:text-white">About</a>
  </div>

  <!-- Actions -->
  <div class="flex gap-3">
    <a href="/users/login" class="px-4 py-2 text-sm border border-zinc-700 rounded-xl hover:bg-white hover:text-black transition">Login</a>
    <a href="/users/register" class="px-4 py-2 text-sm bg-white text-black rounded-xl hover:bg-zinc-200 transition">Sign Up</a>
  </div>

</nav>

<!-- HERO -->
<section class="pt-28 px-6 text-center">

  <h2 class="text-4xl md:text-6xl font-bold leading-tight">
    Premium Bags for <br> Everyday Style
  </h2>

