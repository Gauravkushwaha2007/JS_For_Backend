    // Toggle Theme Logic without destroying anything
    function toggleTheme() {
      const html = document.documentElement;
      const text = document.getElementById('theme-text');
      
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        text.innerText = "Light Theme";
        localStorage.setItem('theme', 'dark');
      } else {
        html.classList.add('dark');
        text.innerText = "Dark Theme";
        localStorage.setItem('theme', 'light');
      }
    }

    // Load Theme State on Refresh
    (function () {
      const savedTheme = localStorage.getItem('theme');
      const html = document.documentElement;
      const text = document.getElementById('theme-text');
      
      if (savedTheme === 'light') {
        html.classList.add('dark'); // 'dark' class activates Light mode configurations via Tailwind dark: modifier
        if(text) text.innerText = "Dark Theme";
      } else {
        html.classList.remove('dark');
        if(text) text.innerText = "Light Theme";
      }
    })();
  </script>

