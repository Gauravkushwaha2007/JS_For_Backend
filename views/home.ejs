<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kush Mart | Fresh Grocery Home</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700;800&family=Archivo+Black&family=Noto+Serif+Devanagari:wght=600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "GroceryStore",
      "name": "Kush Mart (Kushwaha Kirana Store)",
      "image": "/images/ramesh.png",
      "@id": "https://kushwahakiranastore.com",
      "url": "https://kushwahakiranastore.com",
      "telephone": "+919039301184",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Baikunthpur ward no.01",
        "addressLocality": "Rewa",
        "addressRegion": "MP",
        "postalCode": "486001",
        "addressCountry": "IN"
      },
      "founder": {
        "@type": "Person",
        "name": "Ramesh Kushwaha",
        "jobTitle": "Founder & Owner",
        "image": "/images/ramesh.png"
      }
    }
  </script>
</head>

<body class="bg-[#fafdfb] text-zinc-900 antialiased dark:bg-[#050906] dark:text-white transition-colors duration-300 [background:radial-gradient(circle_at_50%_-20%,#e2f5e7_0%,#f7fbf8_60%,#ffffff_100%)] dark:[background:radial-gradient(circle_at_50%_-20%,#0d2111_0%,#060c08_60%,#020403_100%)]">

  <%- include('partials/homepageNavbar') %>

  <section class="pt-40 pb-16 px-6 text-center max-w-4xl mx-auto flex flex-col items-center">
    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-[#24963f]/10 border border-[#24963f]/20 text-[#24963f] rounded-full text-[10px] uppercase tracking-widest font-bold mb-6 shadow-inner dark:bg-[#24963f]/10 dark:border-emerald-800/40 dark:text-[#24963f]">
      <span class="w-1.5 h-1.5 rounded-full bg-[#24963f] dark:bg-emerald-400 animate-ping"></span>
      ⚡ Superfast 10-Min Delivery Active in Rewa
    </div>

    <h2 class="text-4xl md:text-7xl font-extrabold tracking-tight leading-[1.1] text-zinc-900 dark:text-white">
      Daily Essentials <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#24963f] via-zinc-700 to-zinc-500 dark:from-emerald-300 dark:via-zinc-200 dark:to-zinc-400">Delivered Fresh</span>
    </h2>

    <p class="text-zinc-500 dark:text-zinc-400 mt-6 text-sm md:text-base max-w-xl font-medium leading-relaxed opacity-80">
      Skip the queue. Get farm-fresh vegetables, pure dairy, household staples, and premium groceries delivered to your doorstep instantly.
    </p>

  <div class="mt-8 flex flex-col sm:flex-row gap-4 items-center">
      <a href="/products/allProducts" class="px-7 py-3.5 bg-[#24963f] text-white text-sm font-bold rounded-xl hover:bg-[#1e7e34] shadow-xl shadow-[#24963f]/10 transition-all duration-200 flex items-center gap-2 group">
        Order Groceries Now
        <i class="fa-solid fa-arrow-right text-xs group-hover:translate-x-0.5 transition-transform"></i>
      </a>
      <a href="#categories" class="px-7 py-3.5 bg-white border border-zinc-200 text-zinc-700 text-sm font-semibold rounded-xl hover:bg-zinc-50 dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-white transition-all duration-200">
        Browse Categories
      </a>
    </div>
  </section>

  <section id="categories" class="max-w-6xl mx-auto px-6 mb-16 scroll-mt-24">
    <div class="mb-6">
      <h3 class="text-xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 flex items-center gap-2">
        <i class="fa-solid fa-layer-group text-[#24963f] text-sm"></i> Shop by Category
      </h3>
      <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">Select a category to view fresh premium essentials instantly.</p>
    </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      
      <!-- Atta, Rice & Dal -->
      <div onclick="filterByCategory('staples', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-amber-100 bg-amber-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-amber-900 leading-tight">Atta, Rice<br>& Dal</p>
          <span class="text-[9px] uppercase font-bold text-amber-600/80 tracking-wider block mt-1">Staples</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_atta.png" alt="Atta, Rice & Dal" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Fruits & Veggies -->
      <div onclick="filterByCategory('fruits', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-emerald-100 bg-emerald-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-emerald-900 leading-tight">Fruits &<br>Veggies</p>
          <span class="text-[9px] uppercase font-bold text-emerald-600/80 tracking-wider block mt-1">Fresh Farm</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_fruits.png" alt="Fruits & Veggies" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Dairy, Bread & Eggs -->
      <div onclick="filterByCategory('dairy', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-blue-100 bg-blue-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-blue-900 leading-tight">Dairy, Bread<br>& Eggs</p>
          <span class="text-[9px] uppercase font-bold text-blue-600/80 tracking-wider block mt-1">Breakfast</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_dairy.png" alt="Dairy, Bread & Eggs" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Snacks & Munchies -->
      <div onclick="filterByCategory('snacks', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-pink-100 bg-pink-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-pink-900 leading-tight">Snacks &<br>Munchies</p>
          <span class="text-[9px] uppercase font-bold text-pink-600/80 tracking-wider block mt-1">Instant Munch</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_snacks.png" alt="Snacks & Munchies" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Cold Drinks & Juices -->
      <div onclick="filterByCategory('beverages', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-red-100 bg-red-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-red-900 leading-tight">Cold Drinks<br>& Juices</p>
          <span class="text-[9px] uppercase font-bold text-red-600/80 tracking-wider block mt-1">Beverages</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_beverages.png" alt="Cold Drinks & Juices" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Bakery, Cakes & Bread -->
      <div onclick="filterByCategory('bakery', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-orange-100 bg-orange-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-orange-900 leading-tight">Bakery,<br>Cakes & Bread</p>
          <span class="text-[9px] uppercase font-bold text-orange-600/80 tracking-wider block mt-1">Freshly Baked</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_bakery.png" alt="Bakery, Cakes & Bread" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Personal Care & Hygiene -->
      <div onclick="filterByCategory('personalcare', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-teal-100 bg-teal-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-teal-900 leading-tight">Personal Care<br>& Hygiene</p>
          <span class="text-[9px] uppercase font-bold text-teal-600/80 tracking-wider block mt-1">Hygiene & Beauty</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_personalcare.png" alt="Personal Care & Hygiene" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Household & Cleaning -->
      <div onclick="filterByCategory('household', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-purple-100 bg-purple-50/40 hover:shadow-md hover:scale-[1.02] group">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-purple-900 leading-tight">Household<br>& Cleaning</p>
          <span class="text-[9px] uppercase font-bold text-purple-600/80 tracking-wider block mt-1">Home Utilities</span>
        </div>
        <div class="absolute right-1 bottom-1 w-14 h-14 sm:w-20 sm:h-20 flex items-center justify-center pointer-events-none">
          <img src="/images/category_household.png" alt="Household & Cleaning" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
        </div>
      </div>

      <!-- Show All -->
      <div onclick="filterByCategory('all', this)" class="category-nav-link relative overflow-hidden rounded-2xl p-4 h-28 sm:h-32 flex flex-col justify-between transition-all duration-300 cursor-pointer shadow-[0_4px_12px_rgba(0,0,0,0.02)] border border-zinc-200 bg-white hover:shadow-md hover:scale-[1.02] group ring-2 ring-[#24963f] ring-offset-2 scale-[1.02]">
        <div class="z-10">
          <p class="text-xs sm:text-sm font-black text-zinc-950 leading-tight">Show All<br>Products</p>
          <span class="text-[9px] uppercase font-bold text-zinc-500 tracking-wider block mt-1">Full Store</span>
        </div>
        <div class="absolute right-3 bottom-3 w-10 h-10 sm:w-14 sm:h-14 flex items-center justify-center bg-zinc-100 rounded-xl group-hover:bg-[#24963f] group-hover:text-white transition-colors duration-300 pointer-events-none text-zinc-400">
          <i class="fa-solid fa-arrow-right text-base"></i>
        </div>
      </div>

    </div>
  </section>

  <section id="products" class="max-w-6xl mx-auto px-6 pb-24">
    <div class="flex items-baseline justify-between mb-8 border-b border-zinc-100 dark:border-zinc-900/60 pb-4">
      <h3 class="text-xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 flex items-center gap-2">
        <i class="fa-solid fa-fire text-amber-500 text-sm"></i> Best Sellers Today
      </h3>
      <a href="/products/allProducts" class="text-xs font-bold text-zinc-500 dark:text-zinc-400 hover:text-[#24963f] dark:hover:text-emerald-400 transition-colors">View All Catalogue <i class="fa-solid fa-chevron-right text-[9px] ml-0.5"></i></a>
    </div>

    <!-- Skeleton Loader Container (Shuru me dikhega, JS se hide hoga) -->
    <div id="skeleton-grid" class="grid grid-cols-2 md:grid-cols-4 gap-6 w-full">
      <% for(let i=0; i<4; i++) { %>
        <div class="animate-pulse bg-white border border-zinc-100 rounded-2xl p-4 dark:bg-[#0d110e]/60 dark:border-zinc-900 h-[300px] flex flex-col justify-between">
          <div>
            <div class="h-40 bg-zinc-200 dark:bg-zinc-800 rounded-xl mb-4"></div>
            <div class="h-3 bg-zinc-200 dark:bg-zinc-800 rounded w-1/3 mb-3"></div>
            <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-3/4 mb-2"></div>
            <div class="h-3 bg-zinc-200 dark:bg-zinc-800 rounded w-1/2"></div>
          </div>
          <div class="flex justify-between items-center mt-4 pt-2 border-t border-zinc-100 dark:border-zinc-900/80">
            <div class="space-y-2 w-1/3">
              <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded"></div>
              <div class="h-3 bg-zinc-200 dark:bg-zinc-800 rounded w-1/2"></div>
            </div>
            <div class="h-8 bg-zinc-200 dark:bg-zinc-800 rounded-xl w-16"></div>
          </div>
        </div>
      <% } %>
    </div>
    <!-- Aapka main products grid (Isme shuru me 'hidden' class laga di hai) -->
    <div id="real-products-grid" class="grid grid-cols-2 md:grid-cols-4 gap-6 hidden">
      <!-- Aapka purana products loop yahan rahega -->
      <% if(products && products.length > 0) { %>
        <!-- ... aapka purana loop code ... -->
      <% } %>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% if(products && products.length > 0) { %>
        <% products.forEach(function(item) { %>
          <!-- 🌟 EDIT 1: Yahan maine 'data-category' attribute add kar diya hai -->
          <div class="product-card group bg-white border border-zinc-200 rounded-2xl p-4 hover:border-[#24963f]/40 hover:shadow-xl hover:shadow-zinc-200/30 transition-all duration-300 flex flex-col justify-between dark:bg-[#0d110e]/60 dark:border-zinc-900 dark:hover:border-emerald-950 dark:hover:shadow-emerald-500/[0.01]" 
              data-category="<%= item.category || 'Fresh Produce' %>">
            
            <div>
              <div class="h-40 bg-zinc-50 border border-zinc-100 rounded-xl mb-4 overflow-hidden relative flex items-center justify-center dark:bg-zinc-900/40 dark:border-zinc-900">
                <a href="/products/view/<%= item._id %>" class="w-full h-full block">
                  <% if(item.image) { %>
                    <img src="/uploads/<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center">
                      <i class="fa-solid fa-basket-shopping text-3xl text-[#24963f]/40 group-hover:scale-105 transition-transform duration-500"></i>
                    </div>
                  <% } %>
                </a>
              </div>
              
              <span class="text-[10px] bg-zinc-100 text-zinc-500 px-2 py-0.5 rounded font-bold uppercase tracking-wider dark:bg-zinc-900 dark:text-zinc-400">
                <%= item.category || 'Fresh Produce' %>
              </span>
              
              <h4 class="font-bold text-sm text-zinc-800 dark:text-zinc-200 group-hover:text-[#24963f] dark:group-hover:text-white mt-1.5 transition-colors line-clamp-1">
                <a href="/products/view/<%= item._id %>" class="hover:underline product-name">
                  <%= item.name %>
                </a>
              </h4>
              <p class="text-[11px] text-zinc-500 mt-0.5">Quantity: <%= item.quantity || 'Pack' %></p>
            </div>
            
            <div class="flex justify-between items-center mt-4 pt-2.5 border-t border-zinc-100 dark:border-zinc-900/80">
              <div class="flex flex-col">
                <span class="font-black text-base text-zinc-900 dark:text-white">₹<%= item.price %></span>
                <% if(item.discountPrice) { %>
                  <span class="text-[10px] text-zinc-400 dark:text-zinc-500 line-through">₹<%= item.discountPrice %></span>
                <% } %>
              </div>

              <div class="product-action-container" id="action-box-<%= item._id %>">
                <% 
                  let foundInCart = user && user.cart ? user.cart.find(c => c.product && c.product._id.toString() === item._id.toString()) : null; 
                %>

                <% if (foundInCart) { %>
                  <div class="flex items-center bg-[#24963f]/[0.09] text-black rounded-lg overflow-hidden shadow-sm font-black text-xs">
                    <button onclick="descreaseQty('<%= item._id %>')" class="px-3 py-2 hover:bg-[#24963f] hover:text-white transition-colors text-xs font-black">-</button>
                    <span id="quantityNumber-<%= item._id %>" class="px-1.5 min-w-[18px] text-center font-black text-xs"><%= foundInCart.quantity %></span>
                    <button onclick="increaseQty('<%= item._id %>')" class="px-3 py-2 hover:bg-[#24963f] hover:text-white transition-colors text-xs font-black">+</button>
                  </div>
                <% } else { %>
                  <button onclick="addToCart('<%= item._id %>', '<%= item.price %>')" class="text-center text-xs font-extrabold px-4 py-2 bg-emerald-50 text-[#24963f] border border-[#24963f]/20 rounded-xl hover:bg-[#24963f] hover:text-white transition-all duration-200 shadow-sm dark:bg-[#24963f]/10 dark:text-[#24963f] dark:border-[#24963f]/20 dark:hover:bg-[#24963f] dark:hover:text-white">
                    + ADD
                  </button>
                <% } %>
              </div>

            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center py-12 text-zinc-500 text-sm font-medium">
          <i class="fa-solid fa-box-open text-3xl mb-3 block opacity-40"></i>
          No products found in the database.
        </div>
      <% } %>
    </div>
  </section>

  <section id="about" class="mt-12 px-6 md:px-12 overflow-hidden border-t border-zinc-200 dark:border-zinc-900 pt-16 bg-[#fafdfb] dark:bg-[#040805] transition-colors duration-300">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-16 items-start">
        
        <div class="md:col-span-2 flex flex-col sm:flex-row items-center sm:items-start gap-6 bg-[#24963f]/[0.03] border border-[#24963f]/10 p-6 rounded-2xl dark:bg-[#24963f]/[0.02]">
          <a href="/about">
            <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-white dark:border-zinc-900 shrink-0 shadow-lg shadow-[#24963f]/5">
              <img src="/images/ramesh.png" alt="Ramesh Kushwaha" class="w-full h-full object-cover scale-105" onerror="this.src='https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150'">
            </div>
          </a>
          <a href="/about">
            <div class="text-center sm:text-left space-y-2">
              <h4 class="text-[#24963f] dark:text-emerald-400 font-black text-lg tracking-wide [font-family:'Noto_Serif_Devanagari',serif]">
                "विश्वास सालों का, तकनीक आज की!"
              </h4>
              <p class="text-zinc-600 dark:text-zinc-400 text-xs leading-relaxed font-medium">
                For decades, Kushwaha Kirana Store has been your trusted partner for clean, pure, and premium daily essentials. To bring unparalleled convenience to your family, our store is now completely digital.
              </p>
              <div class="pt-1">
                <span class="text-xs font-black text-zinc-800 dark:text-zinc-200 block">Ramesh Kushwaha</span>
                <span class="text-[9px] uppercase tracking-widest font-black text-[#24963f] dark:text-emerald-500">Founder & Proprietor</span>
              </div>
            </div>
          </a>
        </div>

        <div class="space-y-4 md:text-right flex flex-col md:items-end w-full">
          <h4 class="text-zinc-800 dark:text-zinc-200 font-bold uppercase tracking-wider text-[11px] text-[#24963f] dark:text-emerald-400">Store Directory</h4>
          <div class="text-zinc-500 dark:text-zinc-400 text-xs space-y-2 font-medium">
            <p class="flex items-center md:justify-end gap-2"><i class="fa-solid fa-store text-[#24963f] text-[10px]"></i> Kush Mart (Kushwaha Kirana)</p>
            <p class="flex items-center md:justify-end gap-2"><i class="fa-solid fa-location-dot text-[#24963f] text-[10px]"></i> Baikunthpur ward no.01, Rewa, MP</p>
            <p class="flex items-center md:justify-end gap-2 font-bold text-zinc-700 dark:text-zinc-300"><i class="fa-solid fa-phone text-[#24963f] text-[10px]"></i> +91 9039301184</p>
          </div>
        </div>

      </div>

      <div class="select-none pointer-events-none mt-6 overflow-hidden">
        <h1 class="text-[12vw] font-black leading-none tracking-[-0.05em] text-center text-[#24963f]/[0.04] dark:text-emerald-500/[0.02] opacity-[0.95] [font-family:'Archivo_Black',sans-serif] transition-transform duration-300 hover:rotate-6 inline-block w-full cursor-pointer pointer-events-auto">
          KUSH MART
        </h1>
      </div>
    </div>
  </section>

  <footer class="bg-zinc-50 dark:bg-[#030604] border-t border-zinc-200 dark:border-zinc-950 pt-16 pb-8 px-6 md:px-12 transition-colors duration-300">
    <div class="max-w-6xl mx-auto">
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        
