          <button class="bg-white text-black px-4 py-2 rounded-lg text-xs font-bold transition active:scale-95">Join</button>
        </div>
      </div>
    </div>

<div class="select-none pointer-events-none mt-10 overflow-hidden px-4">
  <h1 style="font-family: 'Archivo Black', sans-serif;" 
      class="text-[18vw] md:text-[18vw] font-black leading-none tracking-[-0.07em] text-white text-center opacity-90">
    kushNova
  </h1>
</div>
  </div>
</section>

<footer class="pb-10 px-6 flex flex-col md:flex-row justify-between items-center text-zinc-600 text-xs gap-4">
  <p>© 2026 KushNova. Crafting excellence.</p>
  <div class="flex gap-6 uppercase tracking-widest">
    <a href="#" class="hover:text-white transition">Instagram</a>
    <a href="#" class="hover:text-white transition">Twitter</a>
    <a href="#" class="hover:text-white transition">Behance</a>
  </div>
</footer>

