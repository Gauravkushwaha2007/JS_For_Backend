<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apna Mart Supermart | Fresh Grocery Home</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700;800&family=Archivo+Black&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
    }
    html { scroll-behavior: smooth; }
    /* Premium dark forest green glow suitable for high-end organic/grocery mart */
    .bg-glow {
      background: radial-gradient(circle at 50% -20%, #0d2111 0%, #060c08 60%, #020403 100%);
    }
    /* Hide scrollbar for Chrome, Safari and Opera */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .no-scrollbar {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }
  </style>
</head>

<body class="bg-[#050906] text-white bg-glow antialiased">

<nav class="w-full px-6 md:px-12 py-4 flex items-center justify-between border-b border-emerald-950/40 bg-[#050906]/70 backdrop-blur-xl fixed top-0 left-0 z-50 transition-all duration-300 shadow-[0_4px_30px_rgba(0,0,0,0.3)]">

  <div class="flex items-center gap-2.5 group cursor-pointer shrink-0">
    <div class="w-8 h-8 bg-emerald-500 rounded-xl flex items-center justify-center group-hover:rotate-6 transition-transform duration-300 shadow-[0_0_15px_rgba(16,185,129,0.3)]">
      <i class="fa-solid fa-basket-shopping text-black text-sm"></i>
    </div>
    <div>
      <h1 class="text-lg font-black tracking-tight text-white leading-none">Apna Mart</h1>
      <span class="text-[9px] uppercase font-bold tracking-widest text-emerald-400">Supermart</span>
    </div>
  </div>

  <div class="hidden md:flex gap-6 lg:gap-8 text-[11px] font-bold uppercase tracking-wider text-zinc-400 shrink-0">
    <a href="#" class="text-white border-b-2 border-emerald-500 pb-1">Home</a>
    <a href="#categories" class="hover:text-emerald-400 transition-colors duration-200">Categories</a>
    <a href="/products/allProducts" class="hover:text-emerald-400 transition-colors duration-200">All Products</a>
  </div>

  <div class="flex-1 max-w-md relative group mx-4 hidden sm:block">
    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-emerald-400 transition-colors"></i>
    <input type="text" 
           placeholder="Search groceries..." 
           class="w-full bg-zinc-900/50 border border-zinc-800/80 rounded-xl py-2 pl-11 pr-4 text-xs font-medium text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-zinc-900 focus:border-emerald-500 transition-all">
  </div>

  <div class="flex items-center gap-4 shrink-0">
    
    <% if(user){ %>
      <div class="relative inline-block text-left group">
        
        <button type="button" class="flex items-center gap-2 py-2 px-3.5 bg-zinc-900/80 border border-zinc-800 rounded-xl hover:border-emerald-800 transition-all duration-200">
          <div class="w-5 h-5 rounded-lg bg-emerald-500 text-black flex items-center justify-center text-[9px] font-black uppercase shadow-[0_0_10px_rgba(16,185,129,0.2)]">
            <%= user.name ? user.name.substring(0, 2) : 'A' %>
          </div>
          <span class="text-xs font-bold text-zinc-200 hidden sm:block">My Account</span>
          <i class="fa-solid fa-chevron-down text-[9px] text-zinc-500 group-hover:rotate-180 transition-transform duration-200"></i>
        </button>

        <div class="absolute right-0 w-52 mt-2 origin-top-right bg-[#090f0b] border border-zinc-800 rounded-2xl shadow-2xl shadow-black/90 opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-150 z-50">
          
          <div class="p-3.5 border-b border-zinc-900/60">
            <span class="inline-block text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded <%= user.role === 'admin' ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' %>">
              <%= user.role ? user.role : 'Customer' %>
            </span>
            <p class="text-xs font-bold text-zinc-100 truncate mt-2"><%= user.name %></p>
            <p class="text-[10px] text-zinc-500 truncate"><%= user.email %></p>
          </div>
          
          <div class="p-1.5 space-y-0.5">
            <% if(user.role === 'admin') { %>
              <a href="/products/allProducts" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-400 hover:bg-emerald-500/10 hover:text-emerald-400 rounded-xl transition-all">
                <i class="fa-solid fa-boxes-stacked text-[11px] opacity-70"></i> Dashboard / Catalog
              </a>
              <a href="/products/create" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-400 hover:bg-emerald-500/10 hover:text-emerald-400 rounded-xl transition-all">
                <i class="fa-solid fa-plus text-[11px] opacity-70"></i> Add New Item
              </a>
            <% } %>
            <a href="/users/cart/products" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-400 hover:bg-emerald-500/10 hover:text-emerald-400 rounded-xl transition-all">
              <i class="fa-solid fa-basket-shopping text-[11px] opacity-70"></i> My Cart Page
            </a>
          </div>

          <div class="p-1.5 border-t border-zinc-900/60 bg-black/40 rounded-b-2xl">
            <a href="/users/logout" class="flex items-center gap-2.5 px-3 py-2 text-xs font-bold text-rose-400 hover:bg-rose-500/10 rounded-xl transition-all">
              <i class="fa-solid fa-arrow-right-from-bracket text-[11px]"></i> Secure Logout
            </a>
          </div>

        </div>
      </div>
    <% } else { %>
      <a href="/users/login" class="px-4 py-2 text-xs font-bold text-zinc-400 hover:text-white transition-colors duration-200">Login</a>
      <a href="/users/register" class="px-4 py-2 text-xs font-bold bg-emerald-500 text-black rounded-xl hover:bg-emerald-400 shadow-md shadow-emerald-500/10 active:scale-95 transition-all duration-200">Sign Up</a>
    <% } %>


    <% if(user && user.cart && user.cart.length > 0) { %>
      <a href="/users/cart/products" class="flex items-center gap-2.5 bg-emerald-500 hover:bg-emerald-400 text-black px-3.5 py-2 rounded-xl transition-all shadow-[0_0_15px_rgba(16,185,129,0.2)]">
        <div class="flex flex-col text-left leading-none">
          <span class="text-[9px] font-black uppercase tracking-wider text-emerald-900"><%= user.cart.length %> Items</span>
          <span class="text-xs font-black mt-0.5">₹<%= typeof totalCartPrice !== 'undefined' ? totalCartPrice : 0 %></span>
        </div>
        <div class="h-5 w-[1px] bg-black/20"></div>
        <i class="fa-solid fa-basket-shopping text-xs"></i>
      </a>
    <% } else { %>
      <a href="/users/cart/products" class="flex items-center gap-2 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/30 text-zinc-300 px-4 py-2 rounded-xl transition-all font-bold text-xs uppercase tracking-wider">
        <i class="fa-solid fa-basket-shopping text-xs text-zinc-500"></i>
        <span>Cart</span>
      </a>
    <% } %>

  </div>

</nav>
<section class="pt-40 pb-16 px-6 text-center max-w-4xl mx-auto flex flex-col items-center">

  <div class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-emerald-950/40 border border-emerald-800/40 rounded-full text-[10px] uppercase tracking-widest font-bold text-emerald-400 mb-6 shadow-inner">
    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-ping"></span>
    ⚡ Superfast 10-Min Delivery Active
  </div>

  <h2 class="text-4xl md:text-7xl font-extrabold tracking-tight leading-[1.1] text-white">
    Daily Essentials <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-zinc-200 to-zinc-400">Delivered Fresh</span>
  </h2>

  <p class="text-zinc-400 mt-6 text-sm md:text-base max-w-xl font-medium leading-relaxed opacity-80">
    Skip the queue. Get farm-fresh vegetables, dairy, household staples, and premium groceries delivered to your doorstep instantly.
  </p>

  <div class="mt-8 flex flex-col sm:flex-row gap-4 items-center">
    <a href="/products/allProducts" class="px-7 py-3.5 bg-emerald-500 text-black text-sm font-bold rounded-xl hover:bg-emerald-400 shadow-xl shadow-emerald-500/10 transition-all duration-200 flex items-center gap-2 group">
      Order Groceries Now
      <i class="fa-solid fa-arrow-right text-xs group-hover:translate-x-0.5 transition-transform"></i>
    </a>
    <a href="#categories" class="px-7 py-3.5 bg-zinc-900/80 border border-zinc-800 text-sm font-semibold text-zinc-300 rounded-xl hover:bg-zinc-800 hover:text-white transition-all duration-200">
      Browse Categories
    </a>
  </div>

</section>

<section id="categories" class="max-w-6xl mx-auto px-6 mb-12 scroll-mt-24">
  <div class="flex items-center gap-3 overflow-x-auto pb-4 no-scrollbar text-xs font-bold tracking-wide uppercase text-zinc-400">
    <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-4 py-2.5 rounded-xl whitespace-nowrap cursor-pointer">Fruits & Veggies</span>
    <span class="bg-zinc-900 border border-zinc-800 px-4 py-2.5 rounded-xl whitespace-nowrap hover:text-white cursor-pointer transition-colors">Atta, Rice & Dals</span>
    <span class="bg-zinc-900 border border-zinc-800 px-4 py-2.5 rounded-xl whitespace-nowrap hover:text-white cursor-pointer transition-colors">Dairy, Bread & Eggs</span>
    <span class="bg-zinc-900 border border-zinc-800 px-4 py-2.5 rounded-xl whitespace-nowrap hover:text-white cursor-pointer transition-colors">Snacks & Munchies</span>
    <span class="bg-zinc-900 border border-zinc-800 px-4 py-2.5 rounded-xl whitespace-nowrap hover:text-white cursor-pointer transition-colors">Cold Drinks & Juices</span>
  </div>
</section>

<section id="products" class="max-w-6xl mx-auto px-6 pb-24">

  <div class="flex items-baseline justify-between mb-8 border-b border-zinc-900/60 pb-4">
    <h3 class="text-xl font-bold tracking-tight text-zinc-100 flex items-center gap-2">
      <i class="fa-solid fa-fire text-amber-500 text-sm"></i> Best Sellers Today
    </h3>
    <a href="/products/allProducts" class="text-xs font-bold text-zinc-400 hover:text-emerald-400 transition-colors">View All Catalogue <i class="fa-solid fa-chevron-right text-[9px] ml-0.5"></i></a>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

    <% if(products && products.length > 0) { %>
      <% products.forEach(function(item) { %>
        <div class="group bg-[#0d110e]/60 border border-zinc-900 rounded-2xl p-4 hover:border-emerald-950 hover:shadow-xl hover:shadow-emerald-500/[0.01] transition-all duration-300 flex flex-col justify-between">
          <div>
            <div class="h-40 bg-zinc-900/40 rounded-xl mb-4 overflow-hidden relative border border-zinc-900 flex items-center justify-center">
              <% if(item.image) { %>
                <img src="/uploads/<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <% } else { %>
                <i class="fa-solid fa-basket-shopping text-3xl text-emerald-600/40 group-hover:scale-105 transition-transform duration-500"></i>
              <% } %>
            </div>
            <span class="text-[10px] bg-zinc-900 text-zinc-400 px-2 py-0.5 rounded font-bold uppercase tracking-wider">
              <%= item.category || 'Fresh Produce' %>
            </span>
            <h4 class="font-bold text-sm text-zinc-200 group-hover:text-white mt-1.5 transition-colors line-clamp-1">
              <%= item.name %>
            </h4>
            <p class="text-[11px] text-zinc-500 mt-0.5">Quantity: <%= item.quantity || 'Pack' %></p>
          </div>
          <div class="flex justify-between items-center mt-4 pt-2.5 border-t border-zinc-900/80">
            <div class="flex flex-col">
              <span class="font-black text-base text-white">₹<%= item.price %></span>
              <% if(item.discountPrice) { %>
                <span class="text-[10px] text-zinc-500 line-through">₹<%= item.discountPrice %></span>
              <% } %>
            </div>
            <button onclick="addToCart('<%= item._id %>')" class="text-center text-xs font-extrabold px-4 py-2 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 rounded-xl hover:bg-emerald-500 hover:text-black transition-all duration-200 shadow-sm">
              + ADD
            </button>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-span-full text-center py-12 text-zinc-500 text-sm font-medium">
        <i class="fa-solid fa-box-open text-3xl mb-3 block opacity-40"></i>
        No products found in the database. Please add some products from the dashboard!
      </div>
    <% } %>

  </div>

</section>

<section class="mt-12 px-6 md:px-12 overflow-hidden border-t border-zinc-900/60 pt-16 bg-[#040805]">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-wrap justify-between gap-10 mb-16 text-xs font-medium">
      
      <div class="space-y-4">
        <h4 class="text-white font-bold uppercase tracking-wider text-[11px] text-emerald-400">Help & Support</h4>
        <ul class="text-zinc-500 space-y-2.5">
          <li><a href="#" class="hover:text-white transition-colors">Track Order Live</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Refunds & Cancellations</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Partner Delivery Terms</a></li>
        </ul>
      </div>

      <div class="space-y-4">
        <h4 class="text-white font-bold uppercase tracking-wider text-[11px] text-emerald-400">Our Company</h4>
        <ul class="text-zinc-500 space-y-2.5">
          <li><a href="#" class="hover:text-white transition-colors">About KushNova Kirana</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Direct Farm Sourcing</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Quality Assurance Policy</a></li>
        </ul>
      </div>

      <div class="max-w-xs sm:text-right sm:ml-auto w-full sm:w-auto">
        <h4 class="text-white font-bold uppercase tracking-wider text-[11px] text-emerald-400 mb-3 sm:text-right">Get Discount Alerts</h4>
        <p class="text-zinc-500 leading-relaxed mb-4">Subscribe to unlock mid-week flash deal alerts and free shipping slots.</p>
        <div class="flex gap-2 bg-zinc-900/80 p-1.5 rounded-xl border border-zinc-800 focus-within:border-emerald-800 transition-all">
          <input type="email" placeholder="Enter phone or email" class="bg-transparent text-white px-3 py-1.5 text-xs outline-none w-full placeholder-zinc-600">
          <button class="bg-emerald-500 text-black px-4 py-1.5 rounded-lg text-xs font-bold hover:bg-emerald-400 transition active:scale-95 flex-shrink-0">Join</button>
        </div>
      </div>
    </div>

    <div class="select-none pointer-events-none mt-6 overflow-hidden">
      <h1 style="font-family: 'Archivo Black', sans-serif;" 
          class="text-[12vw] font-black leading-none tracking-[-0.05em] text-center text-emerald-500/[0.03] opacity-[0.95]">
        Apna mart
      </h1>
    </div>
  </div>
</section>

<footer class="bg-[#040805] py-8 px-6 md:px-12 border-t border-zinc-950 flex flex-col sm:flex-row justify-between items-center text-zinc-600 text-[11px] font-medium gap-4">
  <div class="max-w-6xl mx-auto w-full flex flex-col sm:flex-row justify-between items-center gap-4">
    <p>© 2026 Apna Mart Kirana Store. Freshness Guaranteed.</p>
    <div class="flex gap-6 uppercase tracking-widest text-[10px] text-zinc-500">
      <a href="https://www.instagram.com/gaurav.kushwaha7" class="hover:text-white transition-colors"><i class="fa-brands fa-instagram text-sm mr-1"></i> Instagram</a>
      <a href="#" class="hover:text-white transition-colors"><i class="fa-brands fa-x-twitter text-sm mr-1"></i> Twitter</a>
    </div>
  </div>
</footer>



  <script>
    async function addToCart (productId){
      let res = await fetch(`/users/cart/add-to-cart/${productId}`,{
          method: "POST"
      });
      let data = await res.json();
      alert(data.message); 
      if(data.success){
        location.reload()
      }
    }
  </script>

</body>
</html>
























