            <h4 class="font-bold text-sm text-zinc-200 dark:text-zinc-800 group-hover:text-white dark:group-hover:text-emerald-600 mt-1.5 transition-colors line-clamp-1">
              <%= item.name %>
            </h4>
            <p class="text-[11px] text-zinc-500 mt-0.5">Quantity: <%= item.quantity || 'Pack' %></p>
