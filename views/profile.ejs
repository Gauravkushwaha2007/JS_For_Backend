<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Account - Apna Mart</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
    }
  </script>
  <script>
    (function () {
      const savedTheme = localStorage.getItem('theme');
      const html = document.documentElement;
      if (savedTheme === 'dark') { html.classList.add('dark'); } 
      else { html.classList.remove('dark'); }
    })();
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 min-h-screen">

  <div class="max-w-6xl mx-auto px-4 py-6 sm:py-10">
    
    <div class="flex items-center justify-between gap-4 mb-6">
      <div class="flex items-center gap-2 text-xs font-bold text-zinc-400">
        <a href="/" class="hover:text-[#24963f] transition-colors flex items-center gap-1.5">
          <i class="fa-solid fa-house text-[11px]"></i> Home
        </a>
        <i class="fa-solid fa-chevron-right text-[9px] opacity-50"></i>
        <span class="text-zinc-600 dark:text-zinc-400">My Account</span>
      </div>
      
      <button onclick="window.history.back()" class="flex items-center gap-1.5 px-3.5 py-1.5 bg-white dark:bg-zinc-900 border border-zinc-200/80 dark:border-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-800 text-zinc-700 dark:text-zinc-200 text-xs font-black rounded-xl transition-all shadow-sm active:scale-95 cursor-pointer">
        <i class="fa-solid fa-arrow-left"></i> Go Back
      </button>
    </div>
    
    <div class="bg-white dark:bg-zinc-900 border border-zinc-200/80 dark:border-zinc-800 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.02)] overflow-hidden min-h-[550px] flex flex-col md:flex-row">
      
      <div class="w-full md:w-1/4 border-b md:border-b-0 md:border-r border-zinc-100 dark:border-zinc-800 p-6 flex flex-col justify-between shrink-0 bg-white dark:bg-zinc-900/50">
        
        <div class="space-y-6">
          <div class="flex items-center gap-3 pb-4 border-b border-zinc-100 dark:border-zinc-800">
            <div class="w-10 h-10 rounded-full bg-[#24963f] flex items-center justify-center text-white shrink-0 shadow-sm shadow-[#24963f]/20">
              <i class="fa-solid fa-user text-sm"></i>
            </div>
            <div class="min-w-0">
              <h1 class="text-xs font-black text-zinc-800 dark:text-zinc-100 truncate tracking-tight">
                Hi, <%= user.name ? user.name.split(' ')[0] : 'User' %>!
              </h1>
              <p class="text-[10px] text-zinc-400 font-bold truncate mt-0.5"><%= user.contact || user.email %></p>
            </div>
          </div>

          <nav class="space-y-1">
            <a href="/users/profile" class="flex items-center gap-3 px-3 py-3 text-xs font-black text-[#24963f] bg-emerald-50/60 dark:bg-emerald-500/10 rounded-xl transition-all">
              <i class="fa-solid fa-location-dot text-sm shrink-0"></i> 
              <span>My Addresses</span>
            </a>

            <a href="/users/cart/products" class="flex items-center gap-3 px-3 py-2.5 text-xs font-bold text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 hover:text-[#24963f] dark:hover:text-[#24963f] rounded-xl transition-all">
              <i class="fa-solid fa-basket-shopping text-sm opacity-70"></i>
              <span>My Cart</span>
            </a>
            
            <a href="/users/orders" class="flex items-center gap-3 px-3 py-3 text-xs font-bold text-zinc-500 dark:text-zinc-400 hover:text-[#24963f] dark:hover:text-[#24963f] hover:bg-zinc-50 dark:hover:bg-zinc-800/50 rounded-xl transition-all group">
              <i class="fa-solid fa-bag-shopping text-sm text-zinc-400 group-hover:text-[#24963f] shrink-0"></i> 
              <span>My Orders</span>
            </a>

            <div class="flex items-center gap-3 px-3 py-3 text-xs font-bold text-zinc-300 dark:text-zinc-700 cursor-not-allowed select-none">
              <i class="fa-solid fa-prescription-bottle-medical text-sm shrink-0"></i> 
              <span>My Prescriptions <span class="text-[9px] font-black bg-zinc-100 dark:bg-zinc-800 text-zinc-400 px-1 rounded ml-1">🔒</span></span>
            </div>

            <div class="flex items-center gap-3 px-3 py-3 text-xs font-bold text-zinc-300 dark:text-zinc-700 cursor-not-allowed select-none">
              <i class="fa-solid fa-gift text-sm shrink-0"></i> 
              <span>E-Gift Cards</span>
            </div>
          </nav>
        </div>

        <div class="pt-6 border-t border-zinc-100 dark:border-zinc-800 mt-6 md:mt-0">
          <a href="/users/logout" class="flex items-center gap-3 px-3 py-2.5 text-xs font-extrabold text-red-500 hover:bg-red-50 dark:hover:bg-red-950/30 rounded-xl transition-all group">
            <i class="fa-solid fa-arrow-right-from-bracket text-sm text-red-400 group-hover:text-red-500"></i> 
            <span>Logout</span>
          </a>
        </div>

      </div>

      <div class="flex-1 p-6 sm:p-8 bg-zinc-50/30 dark:bg-zinc-950/45 flex flex-col gap-8">
        
      <div class="bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800/60 rounded-2xl p-4 sm:p-5 flex flex-col sm:flex-row justify-between sm:items-center gap-4 shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-xs w-full max-w-xl">
          <div>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-wide block">Account Holder</span>
            <span class="font-extrabold text-zinc-800 dark:text-zinc-200"><%= user.name %></span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-wide block">Email ID / Phone</span>
            <span class="font-extrabold text-zinc-800 dark:text-zinc-200 truncate block"><%= user.contact || user.email %></span>
          </div>
        </div>
        
        <button onclick="toggleProfileModal(true, '<%= user.name %>', '<%= user.contact || '' %>')" class="flex items-center gap-1.5 px-3 py-2 bg-zinc-50 hover:bg-zinc-100 dark:bg-zinc-800 dark:hover:bg-zinc-700 text-zinc-700 dark:text-zinc-200 text-[11px] font-black rounded-xl transition-all border border-zinc-200/50 dark:border-zinc-700 shadow-sm shrink-0">
          <i class="fa-solid fa-user-pen"></i>
          EDIT PROFILE
        </button>
      </div>

        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="text-xs font-black uppercase tracking-wider text-zinc-400">Manage Saved Addresses</h2>
              <p class="text-[11px] text-zinc-400 font-medium mt-0.5">Where would you like your orders delivered?</p>
            </div>
            
            <button onclick="toggleModal(true)" class="flex items-center gap-1.5 px-3 py-2 bg-emerald-50 hover:bg-[#24963f] text-emerald-700 hover:text-white text-xs font-extrabold rounded-xl transition-all duration-200 border border-emerald-200/30 shadow-sm">
              <i class="fa-solid fa-circle-plus text-sm"></i>
              ADD NEW
            </button>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% if(user.addresses && user.addresses.length > 0) { %>
              <% user.addresses.forEach(addr => { %>
                <div class="bg-white dark:bg-zinc-900 border <%= addr.isDefault ? 'border-[#24963f] ring-2 ring-[#24963f]/10' : 'border-zinc-200/60 dark:border-zinc-800/80' %> rounded-2xl p-4 shadow-sm flex flex-col justify-between relative group hover:border-zinc-300 dark:hover:border-zinc-700 transition-all">
                  
                  <div>
                    <div class="flex items-center justify-between gap-2 mb-2.5">
                      <div class="flex items-center gap-1.5">
                        <span class="text-[10px] px-2 py-0.5 bg-zinc-100 dark:bg-zinc-800 font-black rounded uppercase tracking-wide text-zinc-600 dark:text-zinc-300 flex items-center gap-1">
                          <i class="fa-solid <%= addr.title === 'Home' ? 'fa-house' : addr.title === 'Office' ? 'fa-briefcase' : 'fa-location-dot' %> text-[10px]"></i>
                          <%= addr.title %>
                        </span>
                        <% if(addr.isDefault) { %>
                          <span class="text-[9px] px-1.5 py-0.5 bg-[#24963f] text-white font-black rounded uppercase tracking-wider">Default</span>
                        <% } %>
                      </div>

                      <div class="flex items-center gap-1 opacity-80 group-hover:opacity-100 transition-opacity">
                        <% if(!addr.isDefault) { %>
                          <button onclick="makeAddressPrimary('<%= addr._id %>')" title="Set as Primary" class="w-6 h-6 rounded-lg text-zinc-400 hover:text-[#24963f] hover:bg-emerald-50 dark:hover:bg-zinc-800 flex items-center justify-center transition-colors">
                            <i class="fa-solid fa-star text-[10px]"></i>
                          </button>
                        <% } %>
                        <button type="button" onclick="copyToClipboard('<%= addr.flatNo %>, <%= addr.area %>, <%= addr.city %> - <%= addr.pincode %>')" title="Copy Address" class="w-6 h-6 rounded-lg text-zinc-400 hover:text-[#24963f] hover:bg-emerald-50 dark:hover:bg-zinc-800 flex items-center justify-center transition-colors">
                          <i class="fa-regular fa-copy text-[10px]"></i>
                        </button>
                        <button onclick="openEditAddressModal('<%= addr._id %>', '<%= addr.title %>', '<%= addr.flatNo %>', '<%= addr.area %>', '<%= addr.landmark %>', '<%= addr.city %>', '<%= addr.state %>', '<%= addr.pincode %>')" title="Edit Address" class="w-6 h-6 rounded-lg text-zinc-400 hover:text-[#24963f] hover:bg-emerald-50 dark:hover:bg-zinc-800 flex items-center justify-center transition-colors">
                          <i class="fa-solid fa-pencil text-[10px]"></i>
                        </button>
                        
                        <button onclick="deleteAddress('<%= addr._id %>')" title="Delete Address" class="w-6 h-6 rounded-lg text-zinc-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-zinc-800 flex items-center justify-center transition-colors">
                          <i class="fa-solid fa-trash-can text-[10px]"></i>
                        </button>
                      </div>
                    </div>

                    <p class="text-xs font-black text-zinc-800 dark:text-zinc-100 leading-relaxed"><%= addr.flatNo %></p>
                    <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 mt-0.5"><%= addr.area %></p>
                    <% if(addr.landmark) { %>
                      <p class="text-[11px] text-zinc-400 font-medium mt-1">
                        <span class="text-zinc-300 dark:text-zinc-700">📌</span> <%= addr.landmark %>
                      </p>
                    <% } %>
                    <p class="text-[10px] text-zinc-400 font-bold tracking-tight mt-2 border-t border-zinc-50 dark:border-zinc-800/60 pt-1.5">
                      <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %>
                    </p>
                  </div>

                </div>
              <% }) %>
            <% } else { %>
              <div class="col-span-1 sm:col-span-2 text-center py-16 bg-white dark:bg-zinc-900 border border-dashed border-zinc-200 dark:border-zinc-800 rounded-3xl">
                <div class="w-16 h-16 bg-zinc-50 dark:bg-zinc-950 text-zinc-300 dark:text-zinc-700 rounded-2xl flex items-center justify-center mx-auto mb-3">
                  <i class="fa-solid fa-map-location-dot text-2xl"></i>
                </div>
                <p class="text-xs font-black text-zinc-700 dark:text-zinc-300">No saved addresses found</p>
                <p class="text-[11px] text-zinc-400 mt-1 max-w-[240px] mx-auto">Add your delivery address to start ordering freshest essentials.</p>
              </div>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div id="addressModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white dark:bg-zinc-900 w-full max-w-md rounded-3xl p-6 border border-zinc-200/60 dark:border-zinc-800 shadow-xl transition-all scale-95 opacity-0 duration-300" id="modalBox">
      <div class="flex justify-between items-center mb-5">
        <h3 id="modalTitle" class="text-xs font-black uppercase tracking-wider text-zinc-400">Add New Address</h3>
        <button onclick="toggleModal(false)" class="w-7 h-7 bg-zinc-50 dark:bg-zinc-800 hover:bg-zinc-100 rounded-full text-zinc-400 hover:text-zinc-600 flex items-center justify-center transition-colors"><i class="fa-solid fa-xmark text-xs"></i></button>
      </div>

      <div class="mb-4">
        <button type="button" onclick="getCurrentLocation()" id="locationBtn" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-emerald-50 dark:bg-emerald-950/40 text-[#24963f] border border-emerald-200/50 hover:bg-[#24963f] hover:text-white text-xs font-black rounded-xl transition-all active:scale-95 shadow-sm uppercase tracking-wider">
          <i class="fa-solid fa-location-crosshairs text-sm"></i>
          <span id="locationBtnText">Use Current Location</span>
        </button>
      </div>

      <form id="addressForm" action="/users/profile/address/add" method="POST" class="space-y-4 text-xs">
        <div>
          <label class="block text-zinc-400 font-bold mb-1.5">Address Type</label>
          <div class="flex gap-2 mb-4">
            <button type="button" onclick="setAddressType('Home')" id="type-Home" class="flex-1 py-2.5 border-2 border-[#24963f] bg-emerald-50 text-[#24963f] font-black rounded-xl text-center transition-all">
              <i class="fa-solid fa-house mr-1"></i> Home
            </button>
            <button type="button" onclick="setAddressType('Office')" id="type-Office" class="flex-1 py-2.5 border border-zinc-200 dark:border-zinc-800 font-bold rounded-xl text-center text-zinc-600 dark:text-zinc-400 transition-all">
              <i class="fa-solid fa-briefcase mr-1"></i> Office
            </button>
            <button type="button" onclick="setAddressType('Other')" id="type-Other" class="flex-1 py-2.5 border border-zinc-200 dark:border-zinc-800 font-bold rounded-xl text-center text-zinc-600 dark:text-zinc-400 transition-all">
              <i class="fa-solid fa-location-dot mr-1"></i> Other
            </button>
          </div>
          <input type="hidden" id="input-title" name="title" value="Home">
          <script>
          function setAddressType(type) {
            document.getElementById('input-title').value = type;
            ['Home', 'Office', 'Other'].forEach(t => {
              const btn = document.getElementById(`type-${t}`);
              if(t === type) {
                btn.className = "flex-1 py-2.5 border-2 border-[#24963f] bg-emerald-50 text-[#24963f] font-black rounded-xl text-center transition-all";
              } else {
                btn.className = "flex-1 py-2.5 border border-zinc-200 dark:border-zinc-800 font-bold rounded-xl text-center text-zinc-600 dark:text-zinc-400 transition-all";
              }
            });
          }
          </script>
        </div>
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Flat / House No. / Building</label>
          <input type="text" id="input-flatNo" name="flatNo" required placeholder="e.g. Flat 402, 4th Floor" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
        </div>
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Area / Colony / Street Name</label>
          <input type="text" id="input-area" name="area" required placeholder="e.g. Near Main Market, Saket" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
        </div>
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Landmark (Optional)</label>
          <input type="text" id="input-landmark" name="landmark" placeholder="e.g. Opposite Hanuman Mandir" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
        </div>
        
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="block text-zinc-400 font-bold mb-1">City</label>
            <input type="text" id="input-city" name="city" required placeholder="Bhopal" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">State</label>
            <input type="text" id="input-state" name="state" required placeholder="MP" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">Pincode</label>
            <input type="text" id="input-pincode" name="pincode" required placeholder="462001" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
          </div>
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-[#24963f] hover:bg-[#1e7e34] text-white font-black py-3.5 rounded-xl transition-all shadow-md shadow-emerald-700/20 mt-2 text-xs uppercase tracking-wider">
          Save Address
        </button>
      </form>
    </div>
  </div>

  <div id="profileModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white dark:bg-zinc-900 w-full max-w-md rounded-3xl p-6 border border-zinc-200/60 dark:border-zinc-800 shadow-xl transition-all scale-95 opacity-0 duration-300" id="profileModalBox">
      <div class="flex justify-between items-center mb-5">
        <h3 class="text-xs font-black uppercase tracking-wider text-zinc-400">Update Profile Details</h3>
        <button onclick="toggleProfileModal(false)" class="w-7 h-7 bg-zinc-50 dark:bg-zinc-800 hover:bg-zinc-100 rounded-full text-zinc-400 hover:text-zinc-600 flex items-center justify-center transition-colors"><i class="fa-solid fa-xmark text-xs"></i></button>
      </div>

      <form action="/users/profile/update" method="POST" class="space-y-4 text-xs">
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Full Name</label>
          <input type="text" id="edit-profile-name" name="name" required placeholder="Your Name" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
        </div>
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Phone Number</label>
          <input type="text" id="edit-profile-phone" name="phone" required placeholder="10 Digit Mobile Number" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none focus:border-[#24963f] transition-colors">
        </div>

        <button type="submit" class="w-full bg-[#24963f] hover:bg-[#1e7e34] text-white font-black py-3.5 rounded-xl transition-all shadow-md shadow-emerald-700/20 mt-2 text-xs uppercase tracking-wider">
          Save Changes
        </button>
      </form>
    </div>
  </div>

  <script>
    async function makeAddressPrimary(addressId) {
      if (confirm("Do you want to make this your primary delivery address?")) {
        try {
          let res = await fetch(`/users/profile/address/default/${addressId}`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          let data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert(data.message || "Failed to update primary address.");
          }
        } catch (error) {
          console.error("Error setting primary address:", error);
          alert("Something went wrong!");
        }
      }
    }

    async function deleteAddress(addressId) {
      if (confirm("Are you sure you want to delete this address?")) {
        try {
          let res = await fetch(`/users/profile/address/delete/${addressId}`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          let data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert(data.message || "Failed to delete address.");
          }
        } catch (error) {
          console.error("Error deleting address:", error);
          alert("Something went wrong!");
        }
      }
    }

    function toggleModal(show) {
      const modal = document.getElementById('addressModal');
      const box = document.getElementById('modalBox');
      
      if (show) {
        modal.classList.remove('hidden');
        setTimeout(() => box.classList.remove('scale-95', 'opacity-0'), 10);
      } else {
        box.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          modal.classList.add('hidden');
          document.getElementById('addressForm').action = "/users/profile/address/add";
          document.getElementById('modalTitle').innerText = "Add New Address";
          document.getElementById('submitBtn').innerText = "Save Address";
          document.getElementById('addressForm').reset();
        }, 300);
      }
    }

    function openEditAddressModal(id, title, flatNo, area, landmark, city, state, pincode) {
      document.getElementById('addressForm').action = `/users/profile/address/edit/${id}`;
      document.getElementById('modalTitle').innerText = "Update Address";
      document.getElementById('submitBtn').innerText = "Update Address";
      
      document.getElementById('input-title').value = title;
      document.getElementById('input-flatNo').value = flatNo;
      document.getElementById('input-area').value = area;
      document.getElementById('input-landmark').value = (landmark === 'undefined' || landmark === 'null') ? '' : landmark;
      document.getElementById('input-city').value = city;
      document.getElementById('input-state').value = state;
      document.getElementById('input-pincode').value = pincode;
      
      toggleModal(true);
    }

    // 📍 USER की CURRENT LOCATION निकालने का फंक्शन
    function getCurrentLocation() {
      const btn = document.getElementById('locationBtn');
      const btnText = document.getElementById('locationBtnText');
      
      if (!navigator.geolocation) {
        alert("Your browser does not support location detection.");
        return;
      }

      btn.disabled = true;
      btnText.innerText = "Fetching your location...";
      
      navigator.geolocation.getCurrentPosition(
        async (position) => {
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;

          try {
            // 2. अपने ही बैकएंड के एक रूट पर लेटिट्यूड और लोंगिट्यूड भेज रहे हैं (ताकि API Key चोरी न हो)
            let res = await fetch(`/users/profile/address/fetch-address?lat=${lat}&lng=${lng}`);
            let data = await res.json();

            if (data.success) {
              // 3. जादुई ऑटो-फिल: फॉर्म के इनपुट्स में डेटा डालो
              document.getElementById('input-flatNo').value = data.data.flatNo || '';
              document.getElementById('input-area').value = data.data.area || '';
              document.getElementById('input-city').value = data.data.city || '';
              document.getElementById('input-state').value = data.data.state || '';
              document.getElementById('input-pincode').value = data.data.pincode || '';
              
              btnText.innerText = "Location Detected Successfully!";
            } else {
              alert(data.message || "Could not fetch address details.");
              btnText.innerText = "Use Current Location";
            }
          } catch (err) {
            console.error(err);
            alert("Error connecting to location server.");
            btnText.innerText = "Use Current Location";
          } finally {
            btn.disabled = false;
          }
        },
        (error) => {
          // अगर यूजर ने लोकेशन परमिशन 'Deny' कर दी
          console.error(error);
          alert("Please allow location permission to use this feature.");
          btnText.innerText = "Use Current Location";
          btn.disabled = false;
        },
        { enableHighAccuracy: true, timeout: 10000 }
      );
    }


    function copyToClipboard(text) {
      navigator.clipboard.writeText(text);
      alert("Address copied to clipboard! 📋");
    }

    function toggleProfileModal(show, name = '', phone = '') {
      const modal = document.getElementById('profileModal');
      const box = document.getElementById('profileModalBox');
      
      if (show) {
        document.getElementById('edit-profile-name').value = name;
        document.getElementById('edit-profile-phone').value = phone;
        modal.classList.remove('hidden');
        setTimeout(() => box.classList.remove('scale-95', 'opacity-0'), 10);
      } else {
        box.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
    }
  </script>
</body>
</html>