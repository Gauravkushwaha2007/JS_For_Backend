<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile - Apna Mart</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 min-h-screen">

  <!-- मेन कंटेनर -->
  <div class="max-w-4xl mx-auto px-4 py-10">
    
    <!-- हेडर कार्ड -->
    <div class="bg-white dark:bg-zinc-900 border border-zinc-200/60 dark:border-zinc-800/80 rounded-3xl p-6 sm:p-8 shadow-sm flex flex-col sm:flex-row items-center justify-between gap-6 mb-8">
      <div class="flex items-center gap-4">
        <!-- प्रोफाइल एवतार -->
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center font-black text-white text-xl uppercase shadow-md shadow-emerald-500/10">
          <%= user.name.substring(0,2) %>
        </div>
        <div>
          <h1 class="text-xl font-black tracking-tight"><%= user.name %></h1>
          <p class="text-xs text-zinc-400 font-medium mt-0.5"><%= user.email %></p>
        </div>
      </div>
      <!-- क्विक लिंक्स -->
      <div class="flex gap-3 w-full sm:w-auto">
        <a href="/users/orders" class="flex-1 text-center px-4 py-2.5 bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700/80 rounded-xl text-xs font-black transition-all">
          <i class="fa-solid fa-bag-shopping mr-1"></i> My Orders
        </a>
      </div>
    </div>

    <!-- ग्रिड: पर्सनल डिटेल्स और एड्रेस -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- लेफ्ट कॉलम: पर्सनल इंफो -->
      <div class="bg-white dark:bg-zinc-900 border border-zinc-200/60 dark:border-zinc-800/80 rounded-3xl p-6 shadow-sm h-fit">
        <h2 class="text-sm font-black uppercase tracking-wider text-zinc-400 mb-4">Personal Info</h2>
        <div class="space-y-4 text-xs">
          <div>
            <label class="block text-zinc-400 font-bold mb-1">Full Name</label>
            <p class="font-bold text-zinc-800 dark:text-zinc-200 bg-zinc-50 dark:bg-zinc-950 p-2.5 rounded-xl border border-zinc-100 dark:border-zinc-900"><%= user.name %></p>
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">Email Address</label>
            <p class="font-bold text-zinc-800 dark:text-zinc-200 bg-zinc-50 dark:bg-zinc-950 p-2.5 rounded-xl border border-zinc-100 dark:border-zinc-900"><%= user.email %></p>
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">Phone Number</label>
            <p class="font-bold text-zinc-500 dark:text-zinc-400 bg-zinc-50 dark:bg-zinc-950 p-2.5 rounded-xl border border-zinc-100 dark:border-zinc-900">
              <%= user.phone || "Not linked yet" %>
            </p>
          </div>
        </div>
      </div>

      <!-- राइट कॉलम: सेव्ड एड्रेस लिस्ट -->
      <div class="md:col-span-2 space-y-6">
        
        <!-- एड्रेस हेडर और बटन -->
        <div class="flex justify-between items-center">
          <h2 class="text-sm font-black uppercase tracking-wider text-zinc-400">Saved Addresses</h2>
          <button onclick="toggleModal(true)" class="px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-black text-xs font-black rounded-xl transition-all shadow-md shadow-emerald-500/10">
            <i class="fa-solid fa-plus mr-1"></i> Add New
          </button>
        </div>

        <!-- एड्रेस कार्ड्स की लिस्ट -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% if(user.addresses && user.addresses.length > 0) { %>
            <% user.addresses.forEach(addr => { %>
              <div class="bg-white dark:bg-zinc-900 border <%= addr.isDefault ? 'border-emerald-500' : 'border-zinc-200/60 dark:border-zinc-800/80' %> rounded-2xl p-4 shadow-sm flex flex-col justify-between relative group">
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <!-- आइकन बेस्ड ऑन टाइटल -->
                    <span class="text-xs px-2 py-0.5 bg-zinc-100 dark:bg-zinc-800 font-black rounded uppercase tracking-wide text-zinc-600 dark:text-zinc-300">
                      <i class="fa-solid <%= addr.title === 'Home' ? 'fa-house' : addr.title === 'Office' ? 'fa-briefcase' : 'fa-location-dot' %> mr-1"></i>
                      <%= addr.title %>
                    </span>
                    <% if(addr.isDefault) { %>
                      <span class="text-[9px] px-1.5 py-0.5 bg-emerald-500/10 text-emerald-500 font-black rounded uppercase">Default</span>
                    <% } %>
                  </div>
                  <p class="text-xs font-bold text-zinc-800 dark:text-zinc-200 leading-relaxed">
                    <%= addr.flatNo %>, <%= addr.area %>
                  </p>
                  <% if(addr.landmark) { %>
                    <p class="text-[11px] text-zinc-400 font-medium mt-1">Landmark: <%= addr.landmark %></p>
                  <% } %>
                  <p class="text-[11px] text-zinc-500 font-semibold mt-1"><%= addr.city %>, <%= addr.state %> - <%= addr.pincode %></p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <!-- नो एड्रेस स्टेट -->
            <div class="col-span-2 text-center py-12 bg-white dark:bg-zinc-900 border border-dashed border-zinc-200 dark:border-zinc-800 rounded-3xl">
              <i class="fa-solid fa-map-location-dot text-3xl text-zinc-300 dark:text-zinc-700 mb-3 block"></i>
              <p class="text-xs font-bold text-zinc-400">No addresses saved yet. Add one to checkout faster!</p>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <!-- 📥 एड्रेस ऐड करने का पॉपअप मोडल (Popup Modal) -->
  <div id="addressModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white dark:bg-zinc-900 w-full max-w-md rounded-3xl p-6 border border-zinc-200/60 dark:border-zinc-800 shadow-xl transition-all scale-95 opacity-0 duration-300" id="modalBox">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-sm font-black uppercase tracking-wider text-zinc-800 dark:text-zinc-200">Add New Address</h3>
        <button onclick="toggleModal(false)" class="text-zinc-400 hover:text-zinc-600"><i class="fa-solid fa-xmark text-sm"></i></button>
      </div>

      <form action="/users/profile/address/add" method="POST" class="space-y-4 text-xs">
        <!-- एड्रेस टाइप -->
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Address Type</label>
          <select name="title" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-bold text-zinc-800 dark:text-zinc-200 outline-none">
            <option value="Home">Home (All day delivery)</option>
            <option value="Office">Office (Delivery between 9 AM - 6 PM)</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <!-- फ्लैट / हाउस नंबर -->
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Flat / House No. / Floor / Building</label>
          <input type="text" name="flatNo" required placeholder="e.g. Flat 402, 4th Floor" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
        </div>
        <!-- एरिया / रोड -->
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Area / Colony / Street Name</label>
          <input type="text" name="area" required placeholder="e.g. Near Main Market, Saket" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
        </div>
        <!-- लैंडमार्क -->
        <div>
          <label class="block text-zinc-400 font-bold mb-1">Landmark (Optional)</label>
          <input type="text" name="landmark" placeholder="e.g. Opposite Hanuman Mandir" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
        </div>
        <!-- सिटी, स्टेट, पिनकोड ग्रिड -->
        <div class="grid grid-cols-3 gap-2">
          <div>
            <label class="block text-zinc-400 font-bold mb-1">City</label>
            <input type="text" name="city" required placeholder="Bhopal" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">State</label>
            <input type="text" name="state" required placeholder="MP" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
          </div>
          <div>
            <label class="block text-zinc-400 font-bold mb-1">Pincode</label>
            <input type="text" name="pincode" required placeholder="462001" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3 font-semibold text-zinc-800 dark:text-zinc-200 outline-none">
          </div>
        </div>

        <button type="submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-black font-black py-3.5 rounded-xl transition-all shadow-md shadow-emerald-500/10 mt-2">
          Save Address
        </button>
      </form>
    </div>
  </div>

  <!-- ⚙️ मोडल ओपन/क्लोज स्क्रिप्ट -->
  <script>
    function toggleModal(show) {
      const modal = document.getElementById('addressModal');
      const box = document.getElementById('modalBox');
      if (show) {
        modal.classList.remove('hidden');
        setTimeout(() => {
          box.classList.remove('scale-95', 'opacity-0');
        }, 10);
      } else {
        box.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
    }
  </script>
</body>
</html>