<!DOCTYPE html>
<html lang="en">
<head>
  <title>Your Orders | KushNova</title>
  <%- include('partials/head') %>
  <style>
    @keyframes pulse-slow-amber {
      0%, 100% { transform: scale(1.05); filter: drop-shadow(0 0 4px rgba(245, 158, 11, 0.4)); }
      50% { transform: scale(1.12); filter: drop-shadow(0 0 12px rgba(245, 158, 11, 0.7)); }
    }
    @keyframes pulse-slow-blue {
      0%, 100% { transform: scale(1.05); filter: drop-shadow(0 0 4px rgba(59, 130, 246, 0.4)); }
      50% { transform: scale(1.12); filter: drop-shadow(0 0 12px rgba(59, 130, 246, 0.7)); }
    }
    .animate-pulse-slow-amber {
      animation: pulse-slow-amber 2s infinite ease-in-out;
    }
    .animate-pulse-slow-blue {
      animation: pulse-slow-blue 2s infinite ease-in-out;
    }
  </style>
</head>

<body class="bg-[#f8f9fa] text-gray-900 antialiased dark:bg-[#050906] dark:text-zinc-100 transition-colors duration-300">

  <%- include('partials/header') %>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row min-h-[calc(100vh-5rem)]">
    
    <%- include('partials/sidebar') %>

    <main class="flex-1 p-4 sm:p-6 lg:p-8 select-none">
      <% if (typeof orderSuccessMessage !== 'undefined' && orderSuccessMessage) { %>
        <div id="orderSuccessPopup" class="fixed top-6 right-6 z-50 select-none max-w-md w-[calc(100%-3rem)] transition-all duration-500 ease-out transform -translate-y-6 opacity-0 shadow-[0_15px_35px_rgba(16,185,129,0.12)] bg-white dark:bg-zinc-950 border border-emerald-500/20 rounded-2xl overflow-hidden">
          <div class="p-4 flex items-center gap-3.5">
            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center border border-emerald-500/20 shrink-0">
              <i class="fa-solid fa-circle-check text-lg"></i>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-[10px] font-black tracking-wider uppercase text-emerald-600 dark:text-emerald-400">Order Placed!</p>
              <p class="text-xs font-bold text-gray-800 dark:text-zinc-200 mt-0.5"><%= orderSuccessMessage %></p>
            </div>
            <button type="button" onclick="dismissOrderPopup()" class="w-8 h-8 rounded-xl hover:bg-gray-50 dark:hover:bg-zinc-900 text-gray-400 hover:text-gray-900 dark:hover:text-zinc-200 flex items-center justify-center transition-all border border-transparent hover:border-gray-100 dark:hover:border-zinc-800 shrink-0">
              <i class="fa-solid fa-xmark text-sm"></i>
            </button>
          </div>
          <!-- Progress Timer Line -->
          <div class="h-1 bg-emerald-500 w-full transition-all ease-linear" id="orderSuccessProgress" style="width: 100%;"></div>
        </div>
        
        <script>
          document.addEventListener("DOMContentLoaded", () => {
            const popup = document.getElementById("orderSuccessPopup");
            const progress = document.getElementById("orderSuccessProgress");
            if (!popup) return;

            // Trigger Slide in
            setTimeout(() => {
              popup.classList.remove("-translate-y-6", "opacity-0");
              popup.classList.add("translate-y-0", "opacity-100");
            }, 100);

            // Animate progress bar (4.5 seconds duration)
            const duration = 4500;
            const interval = 10;
            let elapsed = 0;
            const timer = setInterval(() => {
              elapsed += interval;
              const remainingPercent = Math.max(0, 100 - (elapsed / duration) * 100);
              if (progress) progress.style.width = `${remainingPercent}%`;
              
              if (elapsed >= duration) {
                clearInterval(timer);
                dismissOrderPopup();
              }
            }, interval);

            window.dismissOrderPopup = () => {
              clearInterval(timer);
              popup.classList.remove("translate-y-0", "opacity-100");
              popup.classList.add("-translate-y-6", "opacity-0", "pointer-events-none");
              setTimeout(() => {
                popup.remove();
              }, 500);
            };
          });
        </script>
      <% } %>
      <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 bg-white dark:bg-zinc-900 p-5 rounded-2xl border border-gray-100 dark:border-zinc-800 shadow-sm">
        <div>
          <div class="flex items-center gap-2 mb-1 text-[11px] font-medium text-zinc-400">
            <a href="/" class="hover:text-black dark:hover:text-white transition-colors"><i class="fa-solid fa-house"></i> Home</a>
            <span class="text-gray-300 dark:text-zinc-700">/</span>
            <span class="font-semibold text-zinc-700 dark:text-zinc-300">Orders</span>
          </div>
          <h2 class="text-xl font-black tracking-tight text-gray-900 dark:text-white uppercase">Your Order History</h2>
          <p class="text-[11px] font-bold text-zinc-400 mt-0.5">Track and manage your grocery deliveries</p>
        </div>
        
        <div class="w-10 h-10 rounded-xl bg-emerald-50 dark:bg-emerald-900/10 flex items-center justify-center text-[#24963f] border border-emerald-100 dark:border-emerald-900/20">
          <i class="fa-solid fa-clock-rotate-left text-sm"></i>
        </div>
      </div>

      <% if(orders.length === 0) { %>
        <div class="max-w-md mx-auto text-center py-16 bg-white dark:bg-zinc-900 rounded-3xl border border-gray-100 dark:border-zinc-800 shadow-sm my-10 px-6">
          <div class="w-16 h-16 mx-auto bg-zinc-50 dark:bg-zinc-800/50 text-zinc-300 dark:text-zinc-600 rounded-2xl flex items-center justify-center text-2xl mb-4 border border-gray-100 dark:border-zinc-700">
            <i class="fa-solid fa-box-open"></i>
          </div>
          <h3 class="text-base font-bold text-zinc-800 dark:text-zinc-200">No Orders Yet!</h3>
          <p class="text-xs text-zinc-400 mt-1 max-w-xs mx-auto">Looks like you haven't bought any groceries yet. Let's fill your kitchen!</p>
          <a href="/products/allProducts" class="mt-6 inline-flex bg-[#24963f] hover:bg-[#1e7e34] text-white text-xs font-black px-6 py-3 rounded-xl transition-all active:scale-95 shadow-sm uppercase tracking-wider">
            Start Shopping
          </a>
        </div>
      <% } else { %>
        
        <div class="space-y-6">
          <% orders.forEach(order => { %>
            <div class="order-container border border-gray-100 dark:border-zinc-800/80 rounded-2xl bg-white dark:bg-zinc-900/40 shadow-sm overflow-hidden hover:shadow-md transition-all duration-300" data-order-id="<%= order._id %>" data-order-status="<%= order.status %>">
              
              <div class="bg-gray-50/70 dark:bg-zinc-900/50 px-5 py-4 border-b border-gray-100 dark:border-zinc-800 flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-5 text-xs font-semibold">
                  <div>
                    <span class="text-[9px] text-zinc-400 font-bold uppercase block tracking-wider mb-0.5">Order Placed</span>
                    <span class="text-zinc-800 dark:text-zinc-200 font-extrabold">
                      <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </span>
                  </div>
                  <div class="h-6 w-[1px] bg-gray-200 dark:bg-zinc-800"></div>
                  <div>
                    <span class="text-[9px] text-zinc-400 font-bold uppercase block tracking-wider mb-0.5">Order ID</span>
                    <span class="font-mono text-zinc-600 dark:text-zinc-400 font-bold text-[11px] uppercase tracking-tight"><%= order._id %></span>
                  </div>
                </div>
                
                <div id="status-pill-<%= order._id %>">
                  <% if(order.status === 'Pending') { %>
                    <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20 uppercase tracking-wider flex items-center gap-1.5 animate-pulse">
                      <i class="fa-solid fa-circle-notch animate-spin text-[9px]"></i> Processing
                    </span>
                  <% } else if(order.status === 'Dispatched') { %>
                    <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20 uppercase tracking-wider flex items-center gap-1.5">
                      <i class="fa-solid fa-truck-fast text-[11px]"></i> Out For Delivery
                    </span>
                  <% } else { %>
                    <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 uppercase tracking-wider flex items-center gap-1.5">
                      <i class="fa-solid fa-circle-check text-[11px]"></i> Delivered
                    </span>
                  <% } %>
                </div>
              </div>

              <div class="p-4 sm:p-5 space-y-3">
                <% order.products.forEach(item => { %>
                  <% if(item.product) { %>
                    <div class="flex items-center justify-between gap-4 bg-gray-50/40 dark:bg-zinc-950/20 p-3 rounded-xl border border-gray-100 dark:border-zinc-800/40">
                      
                      <div class="flex items-center gap-3.5 min-w-0 flex-1">
                        <a href="/products/view/<%= item.product._id %>" class="flex items-center gap-3.5 min-w-0 group cursor-pointer">
                          <div class="w-12 h-12 rounded-xl bg-white dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 flex items-center justify-center overflow-hidden shrink-0 shadow-sm transition-transform group-hover:scale-105">
                            <% if (item.product.image) { %>
                              <img src="/uploads/<%= item.product.image %>" 
                                   class="w-full h-full object-contain p-1" 
                                   onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                              <span class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-emerald-500/10 to-teal-500/10 font-bold text-xs text-[#24963f]">
                                <%= item.product.name ? item.product.name.substring(0,2).toUpperCase() : 'KP' %>
                              </span>
                            <% } else { %>
                              <span class="w-full h-full flex items-center justify-center bg-gradient-to-br from-emerald-500/10 to-teal-500/10 font-bold text-xs text-[#24963f]">
                                <%= item.product.name ? item.product.name.substring(0,2).toUpperCase() : 'KP' %>
                              </span>
                            <% } %>
                          </div>

                          <div class="min-w-0">
                            <h4 class="text-xs font-bold text-zinc-900 dark:text-zinc-100 truncate group-hover:text-[#24963f] transition-colors">
                              <%= item.product.name %>
                            </h4>
                            <p class="text-[10px] font-bold text-zinc-400 mt-0.5">
                              Quantity: <span class="text-[#24963f] font-black">x<%= item.quantity %></span>
                            </p>
                          </div>
                        </a>
                      </div>

                      <div class="flex items-center gap-4 shrink-0">
                        <div class="text-right">
                          <span class="text-xs font-black text-zinc-900 dark:text-white">₹<%= item.product.price * item.quantity %></span>
                          <p class="text-[9px] text-zinc-400 font-medium mt-0.5">₹<%= item.product.price %> each</p>
                        </div>

                        <a href="/users/orders/bill/<%= order._id %>" 
                           title="Download Invoice"
                           class="px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 hover:bg-[#24963f] hover:text-white dark:hover:bg-[#24963f] dark:hover:text-white flex items-center gap-1.5 transition-all text-[10px] font-bold border border-gray-200 dark:border-zinc-700">
                          <i class="fa-solid fa-file-invoice"></i> Bill
                        </a>
                      </div>

                    </div>
                  <% } %>
                <% }) %>
              </div>

              <!-- Visual Step-Progress Live Tracker Bar -->
              <div class="px-5 pb-5 border-b border-gray-50/60 dark:border-zinc-800/40" id="tracker-box-<%= order._id %>">
                <div class="bg-gray-50/50 dark:bg-zinc-950/20 rounded-2xl p-4 sm:p-5 border border-gray-100 dark:border-zinc-800/60">
                  <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-black uppercase text-gray-400 tracking-wider">Live Delivery Status</span>
                    <span class="text-[10px] font-black text-[#24963f] tracking-wide flex items-center gap-1.5 status-text-label">
                      <% if(order.status === 'Pending') { %>
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-ping"></span> Packing Essentials
                      <% } else if(order.status === 'Dispatched') { %>
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-ping"></span> Out For Delivery
                      <% } else if(order.status === 'Delivered') { %>
                        <span class="w-1.5 h-1.5 rounded-full bg-[#24963f]"></span> Delivered Successfully
                      <% } else { %>
                        Cancelled
                      <% } %>
                    </span>
                  </div>

                  <div class="tracker-active-view <%= order.status === 'Cancelled' ? 'hidden' : '' %>">
                    <!-- Progress Bar Container -->
                    <div class="relative flex items-center justify-between w-full mt-4 select-none px-4">
                      
                      <!-- Background Progress line -->
                      <div class="absolute left-10 right-10 top-3 h-1 bg-gray-200 dark:bg-zinc-800 z-0 rounded-full"></div>
                      
                      <!-- Dynamic Active Progress line -->
                      <% 
                        let progressWidth = '0%';
                        if(order.status === 'Pending') progressWidth = '33%';
                        else if(order.status === 'Dispatched') progressWidth = '66%';
                        else if(order.status === 'Delivered') progressWidth = '100%';
                      %>
                      <div class="absolute left-10 top-3 h-1 bg-[#24963f] z-0 rounded-full transition-all duration-1000 ease-out progress-bar-line" style="width: calc(<%= progressWidth %> - 8px);"></div>

                      <!-- Step 1: Placed -->
                      <div class="relative z-10 flex flex-col items-center step-placed">
                        <div class="step-circle w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black shadow-sm transition-all duration-300 border-2 bg-[#24963f] border-[#24963f] text-white">
                          <i class="fa-solid fa-check"></i>
                        </div>
                        <span class="text-[9px] font-black text-gray-800 dark:text-zinc-200 uppercase tracking-wider mt-1.5">Placed</span>
                      </div>

                      <!-- Step 2: Packing -->
                      <% 
                        let step2Bg = 'bg-gray-100 border-gray-200 text-gray-400 dark:bg-zinc-800 dark:border-zinc-700 dark:text-zinc-500';
                        if(order.status === 'Pending') {
                          step2Bg = 'bg-amber-500 border-amber-500 text-white shadow-md animate-pulse-slow-amber';
                        } else if(order.status === 'Dispatched' || order.status === 'Delivered') {
                          step2Bg = 'bg-[#24963f] border-[#24963f] text-white';
                        }
                      %>
                      <div class="relative z-10 flex flex-col items-center step-packed">
                        <div class="step-circle w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black shadow-sm transition-all duration-300 border-2 <%= step2Bg %>">
                          <% if(order.status !== 'Pending' && order.status !== 'Cancelled') { %>
                            <i class="fa-solid fa-check"></i>
                          <% } else { %>
                            <i class="fa-solid fa-box-open"></i>
                          <% } %>
                        </div>
                        <span class="text-[9px] font-black text-gray-800 dark:text-zinc-200 uppercase tracking-wider mt-1.5">Packed</span>
                      </div>

                      <!-- Step 3: Dispatched -->
                      <% 
                        let step3Bg = 'bg-gray-100 border-gray-200 text-gray-400 dark:bg-zinc-800 dark:border-zinc-700 dark:text-zinc-500';
                        if(order.status === 'Dispatched') {
                          step3Bg = 'bg-blue-500 border-blue-500 text-white shadow-md animate-pulse-slow-blue';
                        } else if(order.status === 'Delivered') {
                          step3Bg = 'bg-[#24963f] border-[#24963f] text-white';
                        }
                      %>
                      <div class="relative z-10 flex flex-col items-center step-shipped">
                        <div class="step-circle w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black shadow-sm transition-all duration-300 border-2 <%= step3Bg %>">
                          <% if(order.status === 'Delivered') { %>
                            <i class="fa-solid fa-check"></i>
                          <% } else { %>
                            <i class="fa-solid fa-truck-fast"></i>
                          <% } %>
                        </div>
                        <span class="text-[9px] font-black text-gray-800 dark:text-zinc-200 uppercase tracking-wider mt-1.5">Shipped</span>
                      </div>

                      <!-- Step 4: Delivered -->
                      <% 
                        let step4Bg = 'bg-gray-100 border-gray-200 text-gray-400 dark:bg-zinc-800 dark:border-zinc-700 dark:text-zinc-500';
                        if(order.status === 'Delivered') {
                          step4Bg = 'bg-[#24963f] border-[#24963f] text-white shadow-md shadow-emerald-500/20 scale-105';
                        }
                      %>
                      <div class="relative z-10 flex flex-col items-center step-arrived">
                        <div class="step-circle w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black shadow-sm transition-all duration-300 border-2 <%= step4Bg %>">
                          <i class="fa-solid fa-house-chimney-user"></i>
                        </div>
                        <span class="text-[9px] font-black text-gray-800 dark:text-zinc-200 uppercase tracking-wider mt-1.5">Arrived</span>
                      </div>

                    </div>
                  </div>

                  <div class="tracker-cancelled-view <%= order.status !== 'Cancelled' ? 'hidden' : '' %>">
                    <div class="flex items-center gap-2 p-3 bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/50 rounded-xl text-xs font-bold text-rose-600 dark:text-rose-400">
                      <i class="fa-solid fa-circle-xmark text-sm"></i>
                      <span>This order was cancelled. Feel free to re-order items from the shop.</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="px-5 py-4 bg-gray-50/40 dark:bg-zinc-900/20 border-t border-gray-100 dark:border-zinc-800 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                
                <div class="space-y-0.5 max-w-sm">
                  <span class="text-[9px] text-zinc-400 dark:text-zinc-500 font-bold uppercase tracking-wider block">Delivery Location</span>
                  <div class="flex items-start gap-1.5 text-zinc-600 dark:text-zinc-400">
                    <i class="fa-solid fa-location-dot text-[10px] text-[#24963f] mt-0.5"></i>
                    <p class="text-[11px] font-bold leading-tight truncate"><%= order.address || "Main Address" %></p>
                  </div>
                </div>
                
                <div class="w-full sm:w-auto flex sm:flex-col justify-between items-center sm:items-end bg-emerald-500/[0.04] dark:bg-emerald-500/[0.06] border border-emerald-500/10 p-3 sm:p-0 rounded-xl sm:bg-transparent sm:border-0">
                  <div class="sm:text-right">
                    <span class="text-[9px] text-zinc-400 dark:text-zinc-500 font-bold uppercase tracking-wider block">Total Paid</span>
                    <span class="text-sm font-black text-zinc-900 dark:text-white mt-0.5">₹<%= order.totalPrice %></span>
                  </div>
                  <span class="text-[8px] font-black text-[#24963f] bg-emerald-500/10 px-1.5 py-0.5 rounded uppercase tracking-wider sm:mt-1">
                    Cash On Delivery
                  </span>
                </div>

              </div>

            </div>
          <% }) %>
        </div>
        
      <% } %>

    </main>
  </div>

  <script>
    // ⏰ Live Order status Polling Logic
    document.addEventListener("DOMContentLoaded", () => {
      // Find all order containers to check if we have any active ones
      const orderContainers = document.querySelectorAll(".order-container");
      let activeOrderIds = [];

      orderContainers.forEach(container => {
        const orderId = container.dataset.orderId;
        const status = container.dataset.orderStatus;
        if (status === "Pending" || status === "Dispatched") {
          activeOrderIds.push(orderId);
        }
      });

      // If there are active orders, poll status every 7 seconds
      if (activeOrderIds.length > 0) {
        const intervalId = setInterval(async () => {
          try {
            const response = await fetch("/users/orders/status");
            const data = await response.json();
            
            if (data && data.success && data.orders) {
              let stillHasActive = false;
              
              data.orders.forEach(updatedOrder => {
                const container = document.querySelector(`.order-container[data-order-id="${updatedOrder._id}"]`);
                if (!container) return;
                
                const oldStatus = container.dataset.orderStatus;
                const newStatus = updatedOrder.status;
                
                if (newStatus === "Pending" || newStatus === "Dispatched") {
                  stillHasActive = true;
                }
                
                if (oldStatus !== newStatus) {
                  container.dataset.orderStatus = newStatus;
                  updateOrderUI(updatedOrder._id, newStatus);
                }
              });
              
              if (!stillHasActive) {
                clearInterval(intervalId);
                console.log("No active orders remaining. Polling stopped.");
              }
            }
          } catch (error) {
            console.error("Polling error:", error);
          }
        }, 7000);
      }

      // UI Update Logic for live order statuses
      function updateOrderUI(orderId, status) {
        // 1. Update top status badge/pill
        const statusPill = document.getElementById(`status-pill-${orderId}`);
        if (statusPill) {
          if (status === 'Pending') {
            statusPill.innerHTML = `
              <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20 uppercase tracking-wider flex items-center gap-1.5 animate-pulse">
                <i class="fa-solid fa-circle-notch animate-spin text-[9px]"></i> Processing
              </span>
            `;
          } else if (status === 'Dispatched') {
            statusPill.innerHTML = `
              <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20 uppercase tracking-wider flex items-center gap-1.5">
                <i class="fa-solid fa-truck-fast text-[11px]"></i> Out For Delivery
              </span>
            `;
          } else if (status === 'Delivered') {
            statusPill.innerHTML = `
              <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 uppercase tracking-wider flex items-center gap-1.5">
                <i class="fa-solid fa-circle-check text-[11px]"></i> Delivered
              </span>
            `;
          } else if (status === 'Cancelled') {
            statusPill.innerHTML = `
              <span class="text-[10px] font-black px-3 py-1.5 rounded-xl bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-500/20 uppercase tracking-wider flex items-center gap-1.5">
                <i class="fa-solid fa-circle-xmark text-[11px]"></i> Cancelled
              </span>
            `;
          }
        }

        // 2. Update Live Delivery Status subtitle label
        const trackerBox = document.getElementById(`tracker-box-${orderId}`);
        if (!trackerBox) return;
        
        const textLabel = trackerBox.querySelector(".status-text-label");
        if (textLabel) {
          if (status === 'Pending') {
            textLabel.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-ping"></span> Packing Essentials`;
          } else if (status === 'Dispatched') {
            textLabel.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-ping"></span> Out For Delivery`;
          } else if (status === 'Delivered') {
            textLabel.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-[#24963f]"></span> Delivered Successfully`;
          } else if (status === 'Cancelled') {
            textLabel.innerHTML = `Cancelled`;
          }
        }

        // 3. Toggle normal/cancelled tracker views
        const activeView = trackerBox.querySelector(".tracker-active-view");
        const cancelledView = trackerBox.querySelector(".tracker-cancelled-view");
        
        if (status === "Cancelled") {
          if (activeView) activeView.classList.add("hidden");
          if (cancelledView) cancelledView.classList.remove("hidden");
          return;
        } else {
          if (activeView) activeView.classList.remove("hidden");
          if (cancelledView) cancelledView.classList.add("hidden");
        }

        // 4. Update progress bar line width
        const progressLine = trackerBox.querySelector(".progress-bar-line");
        if (progressLine) {
          let progressWidth = "0%";
          if (status === 'Pending') progressWidth = "33%";
          else if (status === 'Dispatched') progressWidth = "66%";
          else if (status === 'Delivered') progressWidth = "100%";
          
          progressLine.style.width = `calc(${progressWidth} - 8px)`;
        }

        // 5. Update Step Circles and Icons
        const step2Circle = trackerBox.querySelector(".step-packed .step-circle");
        const step3Circle = trackerBox.querySelector(".step-shipped .step-circle");
        const step4Circle = trackerBox.querySelector(".step-arrived .step-circle");

        // Helper to clear classes
        const clearStepClasses = (circle) => {
          circle.className = "step-circle w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-black shadow-sm transition-all duration-300 border-2";
        };

        if (status === 'Pending') {
          // Step 2 is active
          if (step2Circle) {
            clearStepClasses(step2Circle);
            step2Circle.classList.add("bg-amber-500", "border-amber-500", "text-white", "shadow-md", "animate-pulse-slow-amber");
            step2Circle.innerHTML = `<i class="fa-solid fa-box-open"></i>`;
          }
          // Step 3 is inactive
          if (step3Circle) {
            clearStepClasses(step3Circle);
            step3Circle.classList.add("bg-gray-100", "border-gray-200", "text-gray-400", "dark:bg-zinc-800", "dark:border-zinc-700", "dark:text-zinc-500");
            step3Circle.innerHTML = `<i class="fa-solid fa-truck-fast"></i>`;
          }
          // Step 4 is inactive
          if (step4Circle) {
            clearStepClasses(step4Circle);
            step4Circle.classList.add("bg-gray-100", "border-gray-200", "text-gray-400", "dark:bg-zinc-800", "dark:border-zinc-700", "dark:text-zinc-500");
            step4Circle.innerHTML = `<i class="fa-solid fa-house-chimney-user"></i>`;
          }
        } 
        else if (status === 'Dispatched') {
          // Step 2 is completed
          if (step2Circle) {
            clearStepClasses(step2Circle);
            step2Circle.classList.add("bg-[#24963f]", "border-[#24963f]", "text-white");
            step2Circle.innerHTML = `<i class="fa-solid fa-check"></i>`;
          }
          // Step 3 is active
          if (step3Circle) {
            clearStepClasses(step3Circle);
            step3Circle.classList.add("bg-blue-500", "border-blue-500", "text-white", "shadow-md", "animate-pulse-slow-blue");
            step3Circle.innerHTML = `<i class="fa-solid fa-truck-fast"></i>`;
          }
          // Step 4 is inactive
          if (step4Circle) {
            clearStepClasses(step4Circle);
            step4Circle.classList.add("bg-gray-100", "border-gray-200", "text-gray-400", "dark:bg-zinc-800", "dark:border-zinc-700", "dark:text-zinc-500");
            step4Circle.innerHTML = `<i class="fa-solid fa-house-chimney-user"></i>`;
          }
        } 
        else if (status === 'Delivered') {
          // Step 2 is completed
          if (step2Circle) {
            clearStepClasses(step2Circle);
            step2Circle.classList.add("bg-[#24963f]", "border-[#24963f]", "text-white");
            step2Circle.innerHTML = `<i class="fa-solid fa-check"></i>`;
          }
          // Step 3 is completed
          if (step3Circle) {
            clearStepClasses(step3Circle);
            step3Circle.classList.add("bg-[#24963f]", "border-[#24963f]", "text-white");
            step3Circle.innerHTML = `<i class="fa-solid fa-check"></i>`;
          }
          // Step 4 is active/completed
          if (step4Circle) {
            clearStepClasses(step4Circle);
            step4Circle.classList.add("bg-[#24963f]", "border-[#24963f]", "text-white", "shadow-md", "shadow-emerald-500/20", "scale-105");
            step4Circle.innerHTML = `<i class="fa-solid fa-house-chimney-user"></i>`;
          }
        }
      }
    });
  </script>
  <%- include('partials/header-scripts') %>
</body>
</html>