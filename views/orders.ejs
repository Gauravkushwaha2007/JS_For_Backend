<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Orders - Apna Mart</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script>
    // डार्क मोड और थीम टॉगल फंक्शनलिटी
    function toggleTheme() {
      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }
    // पेज लोड होते ही थीम सेट करना
    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="bg-zinc-50 text-zinc-900 dark:bg-[#050906] dark:text-zinc-100 min-h-screen font-sans antialiased transition-colors duration-300">

  <!-- ─── ⚡ COMPLETE NAVIGATION BAR ─── -->
  <nav class="w-full px-6 md:px-12 py-4 flex items-center justify-between border-b border-emerald-100 bg-white/70 backdrop-blur-xl fixed top-0 left-0 z-50 transition-all duration-300 shadow-[0_4px_20px_rgba(0,0,0,0.03)] dark:bg-[#050906]/70 dark:border-emerald-950/40 dark:shadow-[0_4px_30px_rgba(0,0,0,0.3)]">

    <!-- लोगो सेक्शन -->
    <a href="/" class="flex items-center gap-2.5 group cursor-pointer shrink-0">
      <div class="w-8 h-8 bg-emerald-500 rounded-xl flex items-center justify-center group-hover:rotate-6 transition-transform duration-300 shadow-[0_0_15px_rgba(16,185,129,0.3)]">
        <i class="fa-solid fa-basket-shopping text-black text-sm"></i>
      </div>
      <div>
        <h1 class="text-lg font-black tracking-tight text-zinc-900 dark:text-white leading-none">Apna Mart</h1>
        <span class="text-[9px] uppercase font-bold tracking-widest text-emerald-600 dark:text-emerald-400">Supermart</span>
      </div>
    </a>

    <!-- मेनू लिंक्स -->
    <div class="hidden md:flex gap-6 lg:gap-8 text-[11px] font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 shrink-0">
      <a href="/" class="hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors duration-200">Home</a>
      <a href="/#categories" class="hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors duration-200">Categories</a>
      <a href="/products/allProducts" class="hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors duration-200">All Products</a>
    </div>

    <!-- 🔍 वर्किंग सर्च बार फॉर्म -->
    <form action="/" method="GET" class="flex-1 max-w-md relative group mx-4 hidden sm:block">
      <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 group-focus-within:text-emerald-600 dark:text-zinc-500 dark:group-focus-within:text-emerald-400 transition-colors"></i>
      <input type="text" 
             name="search" 
             placeholder="Search groceries and press Enter..." 
             class="w-full bg-zinc-100 border border-zinc-200 rounded-xl py-2 pl-11 pr-4 text-xs font-medium text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:bg-white focus:border-emerald-500 transition-all dark:bg-zinc-900/50 dark:border-zinc-800/80 dark:text-white dark:placeholder-zinc-500">
    </form>

    <!-- राइट साइड एक्शन्स -->
    <div class="flex items-center gap-3 shrink-0">
      
      <!-- 🌙 थीम टॉगल बटन -->
      <button onclick="toggleTheme()" class="w-8 h-8 flex items-center justify-center rounded-xl bg-zinc-100 border border-zinc-200 text-zinc-600 dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-400 hover:border-emerald-400 transition-all">
        <i class="fa-solid fa-moon dark:hidden"></i>
        <i class="fa-solid fa-sun hidden dark:block text-amber-400"></i>
      </button>
      
      <% if(user){ %>
        <!-- अकाउंट ड्रापडाउन -->
        <div class="relative inline-block text-left group">
          <button type="button" class="flex items-center gap-2 py-2 px-3.5 bg-white border border-zinc-200 rounded-xl hover:border-emerald-300 transition-all duration-200 dark:bg-zinc-900/80 dark:border-zinc-800">
            <div class="w-5 h-5 rounded-lg bg-emerald-500 text-black flex items-center justify-center text-[9px] font-black uppercase shadow-[0_0_10px_rgba(16,185,129,0.2)]">
              <%= user.name ? user.name.substring(0, 2) : 'A' %>
            </div>
            <span class="text-xs font-bold text-zinc-700 dark:text-zinc-200 hidden sm:block">My Account</span>
            <i class="fa-solid fa-chevron-down text-[9px] text-zinc-400 group-hover:rotate-180 transition-transform duration-200"></i>
          </button>

          <div class="absolute right-0 w-52 mt-2 origin-top-right bg-white border border-zinc-200 rounded-2xl shadow-xl shadow-zinc-200/50 opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-150 z-50 dark:bg-[#090f0b] dark:border-zinc-800 dark:shadow-2xl dark:shadow-black/90">
            <div class="p-3.5 border-b border-zinc-100 dark:border-zinc-900/60">
              <span class="inline-block text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded <%= user.role === 'admin' ? 'bg-red-50 text-red-600 border border-red-100 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20' : 'bg-emerald-50 text-emerald-600 border border-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20' %>">
                <%= user.role ? user.role : 'Customer' %>
              </span>
              <p class="text-xs font-bold text-zinc-800 dark:text-zinc-100 truncate mt-2"><%= user.name %></p>
              <p class="text-[10px] text-zinc-400 dark:text-zinc-500 truncate"><%= user.email %></p>
            </div>
            
            <div class="p-1.5 space-y-0.5">
              <% if(user.role === 'admin') { %>
                <a href="/products/allProducts" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-600 hover:bg-emerald-50 hover:text-emerald-600 rounded-xl transition-all dark:text-zinc-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-400">
                  <i class="fa-solid fa-boxes-stacked text-[11px] opacity-70"></i> Dashboard / Catalog
                </a>
                <a href="/products/create" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-600 hover:bg-emerald-50 hover:text-emerald-600 rounded-xl transition-all dark:text-zinc-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-400">
                  <i class="fa-solid fa-plus text-[11px] opacity-70"></i> Add New Item
                </a>
              <% } %>
              <a href="/users/cart/products" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-600 hover:bg-emerald-50 hover:text-emerald-600 rounded-xl transition-all dark:text-zinc-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-400">
                <i class="fa-solid fa-basket-shopping text-[11px] opacity-70"></i> My Cart Page
              </a>
            </div>

            <div class="p-1.5 border-t border-zinc-100 bg-zinc-50 rounded-b-2xl dark:border-zinc-900/60 dark:bg-black/40">
              <a href="/users/logout" class="flex items-center gap-2.5 px-3 py-2 text-xs font-bold text-rose-600 hover:bg-rose-50 rounded-xl transition-all dark:text-rose-400 dark:hover:bg-rose-500/10">
                <i class="fa-solid fa-arrow-right-from-bracket text-[11px]"></i> Secure Logout
              </a>
            </div>
          </div>
        </div>
      <% } else { %>
        <a href="/users/login" class="px-3 py-2 text-xs font-bold text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors duration-200">Login</a>
        <a href="/users/register" class="px-4 py-2 text-xs font-bold bg-emerald-500 text-black rounded-xl hover:bg-emerald-400 shadow-md shadow-emerald-500/10 active:scale-95 transition-all duration-200">Sign Up</a>
      <% } %>

      <!-- 🛒 प्रीमियम लाइव कार्ट बटन -->
      <% if(user && user.cart && user.cart.length > 0) { %>
        <a href="/users/cart/products" class="flex items-center gap-3 bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-200 dark:border-emerald-900/60 px-3.5 py-1.5 rounded-xl transition-all duration-300 shadow-[0_4px_15px_rgba(16,185,129,0.08)] select-none hover:border-emerald-400 group">
          <div class="relative flex items-center justify-center w-8 h-8 bg-emerald-500/15 rounded-lg text-[#24963f] dark:text-emerald-400">
            <i class="fa-solid fa-basket-shopping text-base group-hover:scale-110 transition-transform duration-200"></i>
            <span class="absolute -top-1.5 -right-1.5 bg-red-600 text-white font-black text-[10px] w-5 h-5 rounded-full flex items-center justify-center shadow-md border-2 border-white dark:border-zinc-950">
              <%= user.cart.length %>
            </span>
          </div>
          <span class="text-xs font-black text-zinc-900 dark:text-white tracking-tight">
            ₹<%= typeof totalCartPrice !== 'undefined' ? totalCartPrice : 0 %>
          </span>
        </a>
      <% } else { %>
        <a href="/users/cart/products" class="flex items-center gap-2 border border-zinc-200 bg-zinc-100 text-zinc-600 px-4 py-2 rounded-xl transition-all font-bold text-xs uppercase tracking-wider hover:bg-zinc-200 dark:text-zinc-300 dark:bg-zinc-900/30 dark:border-zinc-800 dark:hover:border-zinc-700">
          <i class="fa-solid fa-basket-shopping text-xs text-zinc-400 dark:text-zinc-500"></i>
          <span>Cart</span>
        </a>
      <% } %>

    </div>
  </nav>

  <!-- ─── 📦 MAIN CONTENT SECTION ─── -->
  <main class="max-w-3xl mx-auto px-4 md:px-6 pt-28 pb-16 select-none">
    
    <div class="flex items-center justify-between mb-8 border-b border-zinc-100 dark:border-zinc-900/80 pb-5">
      <div>
        <h1 class="text-xl font-black text-zinc-900 dark:text-white uppercase tracking-tight">Your Order History</h1>
        <p class="text-[11px] font-bold text-zinc-400 mt-0.5">Track and manage your grocery deliveries</p>
      </div>
      <div class="w-10 h-10 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-[#24963f] border border-emerald-500/20 dark:border-emerald-500/10">
        <i class="fa-solid fa-clock-rotate-left text-sm"></i>
      </div>
    </div>

    <% if(orders.length === 0) { %>
      <div class="text-center py-20 border border-dashed rounded-[32px] border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/20 shadow-sm">
        <div class="w-16 h-16 mx-auto bg-zinc-100 dark:bg-zinc-900 text-zinc-400 dark:text-zinc-600 rounded-full flex items-center justify-center text-2xl mb-4">
          <i class="fa-solid fa-box-open"></i>
        </div>
        <h3 class="text-sm font-black text-zinc-800 dark:text-zinc-200 uppercase tracking-wider">No Orders Yet!</h3>
        <p class="text-xs text-zinc-400 font-bold mt-1 max-w-xs mx-auto">Looks like you haven't bought any groceries yet. Let's fill your kitchen!</p>
        <a href="/" class="mt-6 inline-block bg-[#24963f] hover:bg-[#1e7e34] text-white text-xs font-black px-8 py-3.5 rounded-xl transition-all active:scale-95 shadow-md shadow-emerald-900/10 uppercase tracking-wider">
          Start Shopping
        </a>
      </div>
    <% } else { %>
      
      <!-- list of Orders -->
      <div class="space-y-6">
        <% orders.forEach(order => { %>
          <div class="border border-zinc-200/80 dark:border-zinc-800/80 rounded-3xl bg-white dark:bg-[#090f0b]/40 shadow-sm overflow-hidden hover:border-zinc-300 dark:hover:border-zinc-700 transition-all duration-200">
            
            <!-- 1. Card data -->
            <div class="bg-zinc-50/70 dark:bg-zinc-950/40 px-5 py-4 border-b border-zinc-100 dark:border-zinc-900 flex flex-wrap items-center justify-between gap-3">
              <div class="flex items-center gap-4 text-[11px] font-bold text-zinc-500">
                <div>
                  <span class="text-[9px] text-zinc-400 font-black uppercase block tracking-wider mb-0.5">Order Placed</span>
                  <span class="text-zinc-700 dark:text-zinc-300 font-black">
                    <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </span>
                </div>
                <div class="hidden sm:block h-6 w-[1px] bg-zinc-200 dark:bg-zinc-800"></div>
                <div>
                  <span class="text-[9px] text-zinc-400 font-black uppercase block tracking-wider mb-0.5">Order ID</span>
                  <span class="font-mono text-zinc-600 dark:text-zinc-400 uppercase"><%= order._id %></span>
                </div>
              </div>
              
              <!-- Live status Badge -->
              <div>
                <% if(order.status === 'Pending') { %>
                  <span class="text-[10px] font-black px-3 py-1 rounded-xl bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20 uppercase tracking-wider">
                    ⏳ Pending
                  </span>
                <% } else if(order.status === 'Dispatched') { %>
                  <span class="text-[10px] font-black px-3 py-1 rounded-xl bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20 uppercase tracking-wider">
                    🚚 Out For Delivery
                  </span>
                <% } else { %>
                  <span class="text-[10px] font-black px-3 py-1 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 uppercase tracking-wider">
                    ✅ Delivered
                  </span>
                <% } %>
              </div>
            </div>

            <!-- proudcts list which are purchased -->
            <div class="p-5 space-y-4">
              <% order.products.forEach(item => { %>
                <% if(item.product) { %>
                  <div class="flex items-center justify-between gap-4 bg-zinc-50/40 dark:bg-zinc-950/10 p-2.5 rounded-2xl border border-zinc-100/70 dark:border-zinc-900/30">
                    
                    <!-- Image -->
                    <div class="flex items-center gap-3.5 min-w-0">
                      
                      <a href="/products/view/<%= item.product._id %>" class="flex items-center gap-3.5 min-w-0 group cursor-pointer hover:opacity-85 transition-all">
                      
                        <div class="w-12 h-12 rounded-xl bg-zinc-100 dark:bg-zinc-900 border border-zinc-200/60 dark:border-zinc-800 flex items-center justify-center overflow-hidden shrink-0 shadow-sm font-black text-xs uppercase text-emerald-600 dark:text-emerald-400 group-hover:scale-105 group-hover:border-emerald-400/50 transition-all duration-200">
                          <% if (item.product.image) { %>
                            <img src="/uploads/<%= item.product.image %>" 
                                class="w-full h-full object-cover" 
                                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                            
                            <span class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-emerald-500/20 to-teal-500/20">
                              <%= item.product.name ? item.product.name.substring(0,2) : 'KP' %>
                            </span>
                          <% } else { %>
                            <span class="w-full h-full flex items-center justify-center bg-gradient-to-br from-emerald-500/20 to-teal-500/20">
                              <%= item.product.name ? item.product.name.substring(0,2) : 'KP' %>
                            </span>
                          <% } %>
                        </div>

                        <div class="min-w-0">
                          <h4 class="text-xs font-black text-zinc-900 dark:text-zinc-100 truncate group-hover:text-emerald-500 dark:group-hover:text-emerald-400 transition-colors">
                            <%= item.product.name %>
                          </h4>
                          <p class="text-[10px] font-bold text-zinc-400 mt-0.5 uppercase tracking-wide">
                            Qty: <span class="text-emerald-500 bg-emerald-500/10 px-1.5 py-0.2 rounded font-black">x<%= item.quantity %></span>
                          </p>
                        </div>

                    </a>

                      <!-- Name and quantity -->
                      <div class="min-w-0">
                      
                      </div>
                    </div>

                    <!-- Total price of product -->
                    <div class="text-right shrink-0">
                      <span class="text-xs font-black text-zinc-900 dark:text-white">₹<%= item.product.price * item.quantity %></span>
                      <p class="text-[9px] text-zinc-400 font-medium mt-0.5">₹<%= item.product.price %> each</p>
                    </div>

                  </div>
                <% } %>
              <% }) %>
            </div>

            <div class="px-5 py-4 bg-zinc-50/30 dark:bg-zinc-950/20 border-t border-zinc-100 dark:border-zinc-900/60 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              
              <!-- डिलीवरी एड्रेस -->
              <div class="space-y-0.5 max-w-md">
                <span class="text-[9px] text-zinc-400 font-black uppercase tracking-wider block">Delivery Location</span>
                <div class="flex items-start gap-1.5 text-zinc-600 dark:text-zinc-400">
                  <i class="fa-solid fa-map-pin text-[10px] text-emerald-500 mt-1"></i>
                  <p class="text-[11px] font-semibold leading-relaxed"><%= order.address || "Main Address" %></p>
                </div>
              </div>
              
              <!-- टोटल अमाउंट -->
              <div class="w-full sm:w-auto flex sm:flex-col justify-between items-center sm:items-end bg-emerald-500/5 dark:bg-emerald-500/10 border border-emerald-500/10 sm:bg-transparent sm:border-0 p-3 sm:p-0 rounded-xl">
                <div>
                  <span class="text-[9px] text-zinc-400 font-black uppercase tracking-wider block sm:text-right">Total Paid</span>
                  <span class="text-base font-black text-zinc-900 dark:text-white mt-0.5">₹<%= order.totalPrice %></span>
                </div>
                <span class="text-[9px] font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-widest hidden sm:block mt-0.5">Cash On Delivery</span>
              </div>

            </div>

          </div>
        <% }) %>
      </div>
      
    <% } %>

  </main>

</body>
</html>