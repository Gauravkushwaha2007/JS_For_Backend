<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice #<%= order._id %> - Apna Mart</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @media print {
      .no-print { display: none !important; }
      body { background: white; color: black; }
    }
  </style>
</head>
<body class="bg-zinc-50 text-zinc-900 min-h-screen py-12 px-4">

  <div class="max-w-2xl mx-auto bg-white border border-zinc-200 rounded-3xl p-8 shadow-sm">
    
    <!-- 1. बिल हेडर -->
    <div class="flex justify-between items-start border-b border-zinc-100 pb-6">
      <div>
        <h1 class="text-xl font-black tracking-tight text-blue-500">KUSHMART</h1>
        <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest">Retail Invoice / Bill</p>
      </div>
      <div class="text-right text-xs text-zinc-500 font-medium">
        <p><strong class="text-zinc-800">Invoice No:</strong> <span class="font-mono uppercase"><%= order._id %></span></p>
        <p><strong class="text-zinc-800">Date:</strong> <%= new Date(order.createdAt).toLocaleDateString('en-IN') %></p>
      </div>
    </div>

    <!-- 2. कस्टमर और स्टोर डिटेल्स -->
    <div class="grid grid-cols-2 gap-6 my-6 text-xs">
      <div>
        <h3 class="text-[10px] font-black text-zinc-400 uppercase tracking-wider mb-1">Billed To (Customer)</h3>
        <p class="font-bold text-zinc-800"><%= order.user ? order.user.name : user.name %></p>
        <p class="text-zinc-500"><%= order.user ? order.user.email : user.email %></p>
        <p class="text-zinc-500 mt-1"><i class="fa-solid fa-map-pin text-emerald-500 mr-1"></i> <%= order.address || "Main Address" %></p>
      </div>
      <div class="text-right">
        <h3 class="text-[10px] font-black text-zinc-400 uppercase tracking-wider mb-1">Merchant Details</h3>
        <p class="font-bold text-zinc-800">KushMart Supermarket</p>
        <p class="text-zinc-500">kushmart@gmail.com</p>
        <p class="text-zinc-500">GSTIN: 23AAAAA0000A1Z5</p>
      </div>
    </div>

    <!-- 3. आइटम्स की टेबल -->
    <div class="border border-zinc-100 rounded-2xl overflow-hidden my-6">
      <table class="w-full text-left border-collapse text-xs">
        <thead>
          <tr class="bg-zinc-50 text-zinc-500 font-bold border-b border-zinc-100">
            <th class="p-3">Item Description</th>
            <th class="p-3 text-center">Qty</th>
            <th class="p-3 text-right">Rate</th>
            <th class="p-3 text-right">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% order.products.forEach(item => { %>
            <% if(item.product) { %>
              <tr>
                <td class="p-3 font-bold text-zinc-800"><%= item.product.name %></td>
                <td class="p-3 text-center font-semibold text-zinc-600">x<%= item.quantity %></td>
                <td class="p-3 text-right text-zinc-600">₹<%= item.product.price %></td>
                <td class="p-3 text-right font-bold text-zinc-800">₹<%= item.product.price * item.quantity %></td>
              </tr>
            <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- 4. फाइनल बिल ब्रेकअप -->
    <div class="w-full sm:w-64 ml-auto text-xs space-y-2 border-t border-zinc-100 pt-4">
      <div class="flex justify-between text-zinc-500 font-medium">
        <span>Subtotal:</span>
        <span>₹<%= subtotal %></span>
      </div>
      <div class="flex justify-between text-zinc-500 font-medium">
        <span>Delivery Fee:</span>
        <span><%= deliveryCharge === 0 ? 'FREE' : '₹' + deliveryCharge %></span>
      </div>
      <div class="flex justify-between text-zinc-500 font-medium">
        <span>Taxes (incl. GST):</span>
        <span>₹<%= gst %></span>
      </div>
      <div class="flex justify-between text-base font-black text-zinc-900 border-t border-dashed border-zinc-200 pt-2 mt-2">
        <span>Grand Total:</span>
        <span>₹<%= finalBillAmount %></span>
      </div>
    </div>

    <!-- 5. फुटर मैसेज -->
    <div class="text-center border-t border-zinc-100 pt-6 mt-8">
      <p class="text-[11px] font-bold text-[#24963f] uppercase tracking-wider">Thank you for shopping with us!</p>
      <p class="text-[9px] text-zinc-400 mt-0.5">This is a computer-generated invoice and doesn't require a physical signature.</p>
    </div>

  </div>

  <!-- 6. एक्शन्स बटन्स (Print & Back) -->
  <div class="max-w-2xl mx-auto flex gap-4 mt-6 no-print">
    <a href="/users/orders" class="flex-1 bg-zinc-200 hover:bg-zinc-300 text-zinc-700 text-xs font-bold py-3.5 rounded-xl text-center transition-all">
      <i class="fa-solid fa-arrow-left mr-1"></i> Back to Orders
    </a>
    <button onclick="window.print()" class="flex-1 bg-blue-500 hover:bg-[#1e7e34] text-white text-xs font-black py-3.5 rounded-xl transition-all shadow-md shadow-emerald-500/10">
      <i class="fa-solid fa-print mr-1"></i> Save as PDF
    </button>
  </div>

</body>
</html>