<div style="font-family: Arial, sans-serif; max-width: 550px; margin: 0 auto; background-color: #fafdfb; border: 1px solid #e2f5e7; border-radius: 24px; overflow: hidden;">
    <div style="background: linear-gradient(135deg, #24963f 0%, #1e7e34 100%); padding: 35px 20px; text-align: center;">
        <h1 style="color: #ffffff; margin: 0;">KUSH<span style="color: #a7f3d0;">MART</span></h1>
    </div>
    <div style="padding: 40px 30px; background-color: #ffffff;">
        <h2>Hello <%= userName %>, 👋</h2>
        <p style="color: #52525b; font-size: 14px; line-height: 1.6;">
            KUSH MART परिवार में आपका स्वागत है! हमें बेहद खुशी है कि आपने हमारे साथ अपनी डिजिटल ग्रोसरी शॉपिंग की शुरुआत की है।
        </p>
        आपका OTP है: <h1 style="color:#24963f; letter-spacing:4px;"><%= otp %></h1>
        <div style="text-align: center; margin: 30px 0;">
            <a href="<%= hostUrl %>/products/allProducts" style="background-color: #24963f; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 12px; font-weight: bold; display: inline-block;">
               Start Shopping Now
            </a>
        </div>
    </div>
</div>