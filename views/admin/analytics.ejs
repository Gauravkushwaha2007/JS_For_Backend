<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kush Mart | Core Business Analytics Panel</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <style>
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
      background-color: #09090b; /* Zinc 950 */
    }
    /* Custom Scrollbar for premium feel */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #09090b; }
    ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #dc2626; }
    
    /* Cyber Glass Effect */
    .cyber-glass {
      background: rgba(18, 18, 24, 0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.04);
    }
    .cyber-glass-glow:hover {
      border: 1px solid rgba(220, 38, 38, 0.2);
      box-shadow: 0 10px 30px -10px rgba(220, 38, 38, 0.1);
    }
  </style>
</head>
<body class="text-zinc-100 antialiased flex flex-col md:flex-row min-h-screen selection:bg-red-600 selection:text-white">

  <div class="w-full bg-zinc-950/80 backdrop-blur-md text-white p-4 flex items-center justify-between border-b border-zinc-900 sticky top-0 z-50 md:hidden h-16">
    <h1 class="text-xl font-black tracking-tight flex items-center gap-2">
      <span class="w-2.5 h-5 bg-red-600 rounded-sm inline-block shadow-[0_0_15px_rgba(220,38,38,0.5)]"></span>
      Kush Mart <span class="text-[9px] bg-red-600/10 text-red-500 border border-red-500/20 px-1.5 py-0.5 rounded font-black uppercase tracking-wider">Console</span>
    </h1>
    
    <button onclick="toggleAdminSidebar()" type="button" class="w-10 h-10 flex items-center justify-center bg-zinc-900 border border-zinc-800 rounded-xl text-white active:scale-95 transition-all">
      <i id="hamburgerIcon" class="fa-solid fa-bars-staggered text-base"></i>
    </button>
  </div>
  <%- include('../partials/adminSidebar') %>

  <div id="sidebarOverlay" onclick="toggleAdminSidebar()" class="fixed inset-0 bg-black/60 z-40 hidden transition-opacity duration-300 backdrop-blur-sm"></div>

  <main class="flex-1 md:ml-64 p-4 sm:p-8 lg:p-10 w-full overflow-y-auto">
    
    <div class="mb-10 flex flex-col lg:flex-row lg:items-center lg:justify-between border-b border-zinc-900 pb-6 gap-4">
      <div>
        <div class="flex items-center gap-2 text-xs font-bold text-red-500 uppercase tracking-widest mb-1.5">
          <i class="fa-solid fa-network-wired"></i> Live Data Feed Dashboard
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">Financial <span class="bg-clip-text text-transparent bg-gradient-to-r from-red-500 to-amber-500">Analytics</span></h1>
        <p class="text-xs text-zinc-500 mt-1 font-medium">Real-time macroscopic performance indicators, automated audit metrics, and item trends.</p>
      </div>
      
      <div class="cyber-glass px-4 py-2.5 rounded-xl flex items-center gap-3 border border-zinc-800">
        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_10px_#10b981]"></div>
        <div class="text-left">
          <span class="block text-[9px] font-black uppercase text-zinc-500 tracking-wider">System Status</span>
          <span class="text-xs font-bold text-zinc-300" id="liveClock">Streaming Live Data</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      
      <div class="cyber-glass cyber-glass-glow p-6 rounded-2xl shadow-xl flex items-center justify-between group transition-all duration-300">
        <div>
          <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Total Store Sales</span>
            <h3 class="text-3xl font-black text-white mt-1.5 tracking-tight group-hover:text-red-500 transition-colors">₹<%= totalRevenue %></h3>
            <div class="flex items-center gap-1.5 text-[10px] text-emerald-400 font-bold mt-3 bg-emerald-500/5 border border-emerald-500/10 px-2 py-0.5 rounded-md w-fit">
            <i class="fa-solid fa-circle-arrow-up"></i> कुल गल्ला बिक्री (लाइव)
            </div>
        </div>
        <div class="w-14 h-14 bg-zinc-900/50 border border-zinc-800 text-zinc-400 group-hover:text-red-500 group-hover:border-red-500/20 rounded-2xl flex items-center justify-center text-xl shadow-2xl transition-all duration-300">
          <i class="fa-solid fa-vault"></i>
        </div>
      </div>

      <div class="cyber-glass cyber-glass-glow p-6 rounded-2xl shadow-xl flex items-center justify-between group transition-all duration-300">
        <div>
          <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Total Orders Placed</span>
            <h3 class="text-3xl font-black text-white mt-1.5 tracking-tight group-hover:text-red-500 transition-colors"><%= totalOrders %></h3>
            <div class="flex items-center gap-1.5 text-[10px] text-red-400 font-bold mt-3 bg-red-500/5 border border-red-500/10 px-2 py-0.5 rounded-md w-fit">
            <i class="fa-solid fa-chart-bar"></i> कुल सफल डिलीवरी/ऑर्डर्स
            </div>
        </div>
        <div class="w-14 h-14 bg-zinc-900/50 border border-zinc-800 text-zinc-400 group-hover:text-red-500 group-hover:border-red-500/20 rounded-2xl flex items-center justify-center text-xl shadow-2xl transition-all duration-300">
          <i class="fa-solid fa-boxes-packing"></i>
        </div>
      </div>

      <div class="cyber-glass cyber-glass-glow p-6 rounded-2xl shadow-xl flex items-center justify-between group transition-all duration-300 sm:col-span-2 lg:col-span-1">
        <div>
          <span class="block text-[10px] font-black uppercase tracking-widest text-zinc-500">Average Order Value</span>
            <h3 class="text-3xl font-black text-white mt-1.5 tracking-tight group-hover:text-red-500 transition-colors">₹<%= totalOrders > 0 ? (totalRevenue / totalOrders).toFixed(2) : 0 %></h3>
            <div class="flex items-center gap-1.5 text-[10px] text-zinc-400 font-bold mt-3 bg-zinc-500/5 border border-zinc-800 px-2 py-0.5 rounded-md w-fit">
            प्रति ग्राहक औसत बिक्री (Avg. Bill)
            </div>
        </div>
        <div class="w-14 h-14 bg-zinc-900/50 border border-zinc-800 text-zinc-400 group-hover:text-red-500 group-hover:border-red-500/20 rounded-2xl flex items-center justify-center text-xl shadow-2xl transition-all duration-300">
          <i class="fa-solid fa-scale-balanced"></i>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2 cyber-glass p-6 rounded-2xl shadow-xl border border-zinc-900">
    <div class="flex items-center justify-between mb-6">
        <div>
        <h3 class="text-lg font-bold text-white tracking-tight">Sales & Revenue Graph 📈</h3>
        <p class="text-[11px] text-zinc-500 mt-0.5">महीने-दर-महीने दुकान की कुल कमाई और बिज़नेस ग्रोथ का लाइव ग्राफ़।</p>
        </div>
        <span class="text-[10px] font-black uppercase px-2.5 py-1 bg-zinc-900 border border-zinc-800 text-zinc-400 rounded-lg tracking-wider">
        Live Track
        </span>
    </div>
    <div class="relative w-full h-80">
        <canvas id="revenueChart"></canvas>
    </div>
    </div>

    <div class="mb-10 cyber-glass p-6 rounded-3xl border border-red-900/30 shadow-[0_0_30px_rgba(220,38,38,0.02)]">
      <div class="flex items-center justify-between border-b border-zinc-900 pb-4 mb-4">
        <div class="flex items-center gap-2.5">
          <div class="relative flex h-2 w-2">
            <% if (lowStockProducts.length > 0) { %>
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
            <% } else { %>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            <% } %>
          </div>
          <div>
            <h3 class="text-sm font-black uppercase tracking-wider text-white flex items-center gap-2">
              Inventory Alert Node 
              <% if (lowStockProducts.length > 0) { %>
                <span class="text-[10px] bg-amber-500/10 text-amber-500 border border-amber-500/20 px-2 py-0.5 rounded font-black"><%= lowStockProducts.length %> Items Warning</span>
              <% } %>
            </h3>
            <p class="text-[10px] text-zinc-500 mt-0.5">Real-time stock monitoring. Items listed here require immediate re-stocking.</p>
          </div>
        </div>
        <i class="fa-solid fa-triangle-exclamation text-amber-500 text-lg animate-pulse"></i>
      </div>

      <% if (lowStockProducts.length === 0) { %>
        <div class="flex items-center gap-3 bg-emerald-500/5 border border-emerald-500/10 p-4 rounded-xl text-zinc-400 text-xs font-semibold">
          <i class="fa-solid fa-circle-check text-emerald-500 text-sm"></i>
          <span>All system inventory nodes are nominal. Every product has sufficient stock levels.</span>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% lowStockProducts.forEach(product => { %>
            <div class="bg-zinc-950/60 border border-zinc-900 p-3.5 rounded-xl flex items-center justify-between hover:border-amber-500/30 transition-all duration-300 group">
              <div class="flex items-center gap-3">
                <% if (product.picture) { %>
                  <img src="<%= product.picture %>" alt="<%= product.name %>" class="w-10 h-10 rounded-lg object-cover bg-zinc-900 border border-zinc-800">
                <% } else { %>
                  <div class="w-10 h-10 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-600">
                    <i class="fa-solid fa-box text-sm"></i>
                  </div>
                <% } %>
                <div>
                  <h4 class="text-xs font-black text-white group-hover:text-amber-500 transition-colors"><%= product.name %></h4>
                  <p class="text-[10px] text-zinc-500 mt-0.5">Price: ₹<%= product.price %></p>
                </div>
              </div>
              
              <div class="text-right">
                <% if (product.stock === 0) { %>
                  <span class="text-[9px] font-black uppercase bg-red-600/10 text-red-500 border border-red-500/20 px-2 py-1 rounded-md">
                    Out of Stock 🚨
                  </span>
                <% } else { %>
                  <span class="text-[9px] font-black uppercase bg-amber-500/10 text-amber-500 border border-amber-500/20 px-2 py-1 rounded-md">
                    Only <%= product.stock %> Left
                  </span>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </main>

  <script>
    function toggleAdminSidebar() {
      const sidebar = document.getElementById('adminSidebar');
      const overlay = document.getElementById('sidebarOverlay');
      const icon = document.getElementById('hamburgerIcon');

      if (sidebar.classList.contains('-translate-x-full')) {
        sidebar.classList.remove('-translate-x-full');
        sidebar.classList.add('translate-x-0');
        overlay.classList.remove('hidden');
        if(icon) { icon.classList.remove('fa-bars-staggered'); icon.classList.add('fa-xmark'); }
      } else {
        sidebar.classList.remove('translate-x-0');
        sidebar.classList.add('-translate-x-full');
        overlay.classList.add('hidden');
        if(icon) { icon.classList.remove('fa-xmark'); icon.classList.add('fa-bars-staggered'); }
      }
    }

    // Dynamic Server Feed Engine (ChartJS Injection)
    const monthlySalesData = <%- monthlySalesData %>;
    const topProductNames = <%- topProductNames %>;
    const topProductCounts = <%- topProductCounts %>;

    // Chart.js Global Configurations for Premium Dark Mode
    Chart.defaults.color = '#71717a'; // Zinc 400
    Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";

    // --- 📈 LINE CHART ENGINE (REVENUE VECTORS) ---
    const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
    
    // Creating gradient flow for cinematic background under the line
    const revenueGradient = ctxRevenue.createLinearGradient(0, 0, 0, 300);
    revenueGradient.addColorStop(0, 'rgba(220, 38, 38, 0.15)');
    revenueGradient.addColorStop(1, 'rgba(220, 38, 38, 0)');

    new Chart(ctxRevenue, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
        datasets: [{
          label: 'Net Returns (₹)',
          data: monthlySalesData,
          borderColor: '#dc2626', // Premium Red Line
          borderWidth: 3,
          backgroundColor: revenueGradient,
          fill: true,
          tension: 0.35,
          pointBackgroundColor: '#09090b',
          pointBorderColor: '#dc2626',
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 7,
          pointHoverBackgroundColor: '#dc2626',
          pointHoverBorderColor: '#ffffff'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { 
          legend: { display: false },
          tooltip: {
            backgroundColor: '#18181b',
            titleColor: '#ffffff',
            bodyColor: '#dc2626',
            bodyFont: { weight: 'bold' },
            borderColor: '#27272a',
            borderWidth: 1,
            padding: 12,
            boxPadding: 6,
            displayColors: false
          }
        },
        scales: {
          y: { 
            beginAtZero: true, 
            grid: { color: 'rgba(255, 255, 255, 0.03)' },
            ticks: { color: '#71717a', font: { size: 10 } }
          },
          x: { 
            grid: { display: false },
            ticks: { color: '#71717a', font: { size: 10, weight: 'bold' } }
          }
        }
      }
    });

    // --- 📊 DOUGHNUT CHART ENGINE (VELOCITY LEADERS) ---
    if(topProductNames.length > 0) {
      const ctxProducts = document.getElementById('topProductsChart').getContext('2d');
      new Chart(ctxProducts, {
        type: 'doughnut',
        data: {
          labels: topProductNames,
          datasets: [{
            data: topProductCounts,
            backgroundColor: [
              '#dc2626', // Core Red
              '#ea580c', // Bright Orange
              '#f59e0b', // Amber Glow
              '#3f3f46', // Matte Zinc
              '#71717a'  // Light Zinc
            ],
            borderWidth: 4,
            borderColor: '#121218', // Space out chunks nicely
            hoverOffset: 8
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: { 
                boxWidth: 8, 
                boxHeight: 8,
                usePointStyle: true,
                font: { size: 10, weight: '600' }, 
                padding: 16,
                color: '#a1a1aa'
              }
            },
            tooltip: {
              backgroundColor: '#18181b',
              borderColor: '#27272a',
              borderWidth: 1,
              padding: 10
            }
          },
          cutout: '75%' // Thinner and modern doughnut hole
        }
      });
    }
  </script>

</body>
</html>