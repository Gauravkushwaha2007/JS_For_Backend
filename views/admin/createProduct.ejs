<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product ? "Edit Product" : "Create Product" %> | KushNova Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .admin-input:focus {
      border-color: #dc2626;
      box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.08);
    }
  </style>
</head>

<body class="bg-[#fafafa] text-gray-950 antialiased">

  <div class="min-h-screen flex flex-col">
    
    <%- include('../partials/adminSidebar') %>

    <main class="flex-1 w-full min-w-0 p-5 sm:p-8 lg:p-12 md:pl-76 lg:pl-76 transition-all duration-300 md:ml-64">
      
      <div class="mb-8 pb-5 border-b border-zinc-200/60 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <div class="flex items-center gap-2 mb-1.5 text-[11px] font-medium text-gray-400">
            <a href="/products/allProducts" class="hover:text-black transition-colors">Catalogue</a>
            <span class="text-gray-300">/</span>
            <span class="font-semibold text-red-600"><%= product ? "Edit Dashboard" : "Creation Dashboard" %></span>
          </div>
          <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-gray-900">
            <%= product ? "Modify Live Product" : "Publish New Product" %>
          </h2>
        </div>

        <div class="self-start sm:self-auto">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-xl border <%= product ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-red-50 text-red-700 border-red-200' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= product ? 'bg-amber-500' : 'bg-red-600' %>"></span>
            <%= product ? 'Edit Mode Active' : 'Fresh Listing Mode' %>
          </span>
        </div>
      </div>

      <div class="max-w-3xl bg-white border <%= product ? 'border-amber-200/70 shadow-amber-100/30' : 'border-zinc-100 shadow-zinc-100/60' %> rounded-3xl p-6 sm:p-8 shadow-2xl transition-all">
        
        <form action="<%= product ? '/products/edit/' + product._id : '/products/create' %>" 
              method="post" 
              enctype="multipart/form-data" 
              onsubmit="showLoader(event)"
              class="space-y-8">
          
          <div class="bg-zinc-50/50 p-5 rounded-2xl border border-zinc-100">
            <h3 class="text-[11px] font-black uppercase tracking-wider text-gray-400 mb-4 flex items-center gap-2">
              <i class="fa-regular fa-image text-xs text-red-600"></i> Product Media Asset
            </h3>
            
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
              <% if(product && product.images && product.images.length > 0){ %>
                <div class="flex items-center gap-2 flex-wrap max-w-full sm:max-w-[300px]">
                  <% product.images.forEach(img => { %>
                    <div class="w-16 h-16 bg-white rounded-xl border border-zinc-200 p-1.5 flex items-center justify-center relative overflow-hidden shadow-sm shrink-0 group">
                      <img src="/uploads/<%= img %>" class="max-w-full max-h-full object-contain transition-transform duration-300 group-hover:scale-105" alt="product">
                    </div>
                  <% }) %>
                </div>
              <% } else if(product && product.image){ %>
                <div class="w-16 h-16 bg-white rounded-xl border border-zinc-200 p-1.5 flex items-center justify-center relative overflow-hidden shadow-sm shrink-0 group">
                  <img src="/uploads/<%= product.image %>" class="max-w-full max-h-full object-contain transition-transform duration-300 group-hover:scale-105" alt="product">
                </div>
              <% } %>
              
              <div class="w-full">
                <label class="block">
                  <span class="sr-only">Choose Product Images</span>
                  <input type="file" name="images" <%= product ? '' : 'required' %> multiple
                         class="block w-full text-xs text-gray-500
                                file:mr-4 file:py-2.5 file:px-4
                                file:rounded-xl file:border-0
                                file:text-[11px] file:font-extrabold file:uppercase file:tracking-wider
                                file:bg-zinc-900 file:text-white
                                hover:file:bg-red-600 hover:file:text-white
                                file:transition-all file:cursor-pointer" />
                </label>
                <p class="text-[10px] text-gray-400 mt-2.5">Hold Ctrl (Windows) / Cmd (Mac) to select multiple images. PNGs look exceptionally sleek.</p>
              </div>
            </div>
          </div>

          <div class="space-y-5">
            <h3 class="text-[11px] font-black uppercase tracking-wider text-gray-400 mb-1 flex items-center gap-2">
              <i class="fa-solid fa-tags text-xs text-red-600"></i> Inventory Specifications
            </h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Product Title / Name</label>
                <input type="text" name="name" placeholder="e.g. Fresh Amul Butter"
                       value="<%= product ? product.name : '' %>"
                       class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm" required>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Base Retail Price (₹)</label>
                <input type="number" name="price" placeholder="0" min="0"
                       value="<%= product ? product.price : '' %>"
                       class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm" required>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="sm:col-span-1">
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Discount Amount (₹)</label>
                <input type="number" name="discount" placeholder="0" min="0"
                       value="<%= product ? product.discount : '0' %>"
                       class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Stock Count (Units)</label>
                <input type="number" name="stock" placeholder="e.g. 50" min="0"
                      value="<%= product ? product.stock : '10' %>"
                      class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm" required>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Quantity Metric / Unit</label>
                <input type="text" name="quantity" placeholder="e.g. 1 kg, 500 g, 1 L"
                      value="<%= product ? product.quantity : '' %>"
                      class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm" required>
              </div>
            </div>

            <div class="relative">
              <label class="block text-xs font-bold text-gray-700 mb-1.5">Product Department Hierarchy</label>
              <input type="hidden" name="category" id="category-input" required value="<%= product ? product.category : '' %>">
              
              <!-- Custom Dropdown Trigger Button -->
              <button type="button" id="dropdown-trigger-btn"
                      class="w-full flex items-center justify-between text-xs font-semibold p-3.5 border border-gray-200 rounded-xl bg-white focus:outline-none shadow-sm transition-all cursor-pointer hover:border-red-500/40 text-left">
                <span id="dropdown-selected-content" class="flex items-center gap-2 text-gray-500">
                  <i class="fa-solid fa-layer-group text-red-500"></i>
                  <span>-- Choose Department Category --</span>
                </span>
                <i class="fa-solid fa-chevron-down text-gray-400 text-[10px] transition-transform duration-200" id="dropdown-chevron"></i>
              </button>

              <!-- Custom Dropdown Panel -->
              <div id="dropdown-menu-panel"
                   class="absolute left-0 right-0 mt-2 bg-white border border-zinc-200/80 rounded-2xl shadow-2xl overflow-hidden hidden z-50 transition-all duration-200 origin-top scale-95 opacity-0">
                <div class="p-2 max-h-80 overflow-y-auto space-y-1" id="dropdown-options-list">
                  
                  <!-- Fruits & Veggies -->
                  <div onclick="selectCategory('fruits', 'Fruits & Veggies', '🍎', 'emerald')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-emerald-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="fruits">
                    <div class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🍎
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Fruits & Veggies</p>
                      <p class="text-[10px] text-gray-400 truncate">Farm fresh vegetables & fruits</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-emerald-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Atta, Rice & Dal -->
                  <div onclick="selectCategory('staples', 'Atta, Rice & Dal', '🌾', 'amber')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-amber-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="staples">
                    <div class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🌾
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Atta, Rice & Dal</p>
                      <p class="text-[10px] text-gray-400 truncate">Wheat, pulses, rice & kitchen staples</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-amber-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Dairy, Bread & Eggs -->
                  <div onclick="selectCategory('dairy', 'Dairy, Bread & Eggs', '🥛', 'blue')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-blue-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="dairy">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🥛
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Dairy, Bread & Eggs</p>
                      <p class="text-[10px] text-gray-400 truncate">Milk, butter, bread, cheese & eggs</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-blue-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Snacks & Munchies -->
                  <div onclick="selectCategory('snacks', 'Snacks & Munchies', '🍪', 'pink')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-pink-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="snacks">
                    <div class="w-8 h-8 rounded-lg bg-pink-50 text-pink-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🍪
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Snacks & Munchies</p>
                      <p class="text-[10px] text-gray-400 truncate">Chips, cookies, namkeen & munchies</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-pink-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Cold Drinks & Juices -->
                  <div onclick="selectCategory('beverages', 'Cold Drinks & Juices', '🥤', 'red')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-red-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="beverages">
                    <div class="w-8 h-8 rounded-lg bg-red-50 text-red-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🥤
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Cold Drinks & Juices</p>
                      <p class="text-[10px] text-gray-400 truncate">Sodas, juices, energy drinks, tea & coffee</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-red-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Bakery & Bread -->
                  <div onclick="selectCategory('bakery', 'Bakery & Bread', '🍞', 'orange')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-orange-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="bakery">
                    <div class="w-8 h-8 rounded-lg bg-orange-50 text-orange-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🍞
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Bakery & Bread</p>
                      <p class="text-[10px] text-gray-400 truncate">Cakes, croissants, fresh buns & pastries</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-orange-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Personal Care -->
                  <div onclick="selectCategory('personalcare', 'Personal Care', '🧴', 'teal')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-teal-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="personalcare">
                    <div class="w-8 h-8 rounded-lg bg-teal-50 text-teal-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🧴
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Personal Care</p>
                      <p class="text-[10px] text-gray-400 truncate">Soaps, shampoos, body washes & grooming</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-teal-600 hidden check-icon shrink-0"></i>
                  </div>

                  <!-- Household Essentials -->
                  <div onclick="selectCategory('household', 'Household Essentials', '🧼', 'purple')"
                       class="dropdown-option flex items-center gap-3 p-2.5 hover:bg-purple-50 rounded-xl cursor-pointer transition-colors group"
                       data-value="household">
                    <div class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center text-base shrink-0 group-hover:scale-105 transition-transform">
                      🧼
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold text-gray-800">Household Essentials</p>
                      <p class="text-[10px] text-gray-400 truncate">Cleaning liquids, detergents & utility items</p>
                    </div>
                    <i class="fa-solid fa-check text-xs text-purple-600 hidden check-icon shrink-0"></i>
                  </div>

                </div>
              </div>
            </div>
          </div>

          <div class="p-5 bg-zinc-50/50 rounded-2xl border border-zinc-100 space-y-4">
            <h3 class="text-[11px] font-black uppercase tracking-wider text-gray-400 flex items-center gap-2">
              <i class="fa-solid fa-palette text-xs text-red-600"></i> Card Personalization Console
            </h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="bg-white p-3 rounded-xl border border-zinc-200/60 shadow-sm flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <label class="block text-[11px] font-bold text-gray-700">Outer Card Bg</label>
                  <span class="text-[9px] text-gray-400 block truncate">Card framing setup</span>
                </div>
                <input type="color" name="bgColor" value="<%= product && product.bgColor ? product.bgColor : '#ffffff' %>" class="w-8 h-8 border-0 rounded-lg cursor-pointer bg-transparent">
              </div>

              <div class="bg-white p-3 rounded-xl border border-zinc-200/60 shadow-sm flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <label class="block text-[11px] font-bold text-gray-700">Bottom Info Panel</label>
                  <span class="text-[9px] text-gray-400 block truncate">Action section color</span>
                </div>
                <input type="color" name="panelColor" value="<%= product && product.panelColor ? product.panelColor : '#f3f4f6' %>" class="w-8 h-8 border-0 rounded-lg cursor-pointer bg-transparent">
              </div>

              <div class="bg-white p-3 rounded-xl border border-zinc-200/60 shadow-sm flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <label class="block text-[11px] font-bold text-gray-700">Text Labels Color</label>
                  <span class="text-[9px] text-gray-400 block truncate">Title/Price palette</span>
                </div>
                <input type="color" name="textColor" value="<%= product && product.textColor ? product.textColor : '#111827' %>" class="w-8 h-8 border-0 rounded-lg cursor-pointer bg-transparent">
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-[11px] font-black uppercase tracking-wider text-gray-400 mb-2 flex items-center gap-2">
              <i class="fa-solid fa-align-left text-xs text-red-600"></i> Editorial Product Copy
            </h3>
            <textarea name="description" rows="3" placeholder="Enter explicit weight specs, shelf life details, or pack configurations..."
                      class="admin-input w-full text-xs font-medium p-3.5 border border-gray-200 rounded-xl focus:outline-none bg-zinc-50/20 transition-all shadow-sm"><%= product && product.description ? product.description : '' %></textarea>
          </div>

          <div class="pt-4 border-t border-zinc-100 flex flex-col sm:flex-row items-center justify-end gap-3">
            <a href="/products/allProducts" class="w-full sm:w-auto text-center text-xs font-bold py-3.5 px-6 rounded-xl border border-zinc-200 hover:bg-zinc-50 text-gray-600 transition-all uppercase tracking-wider">
              Cancel
            </a>
            <button type="submit"
                    class="w-full sm:w-auto <%= product ? 'bg-amber-600 hover:bg-amber-700' : 'bg-red-600 hover:bg-red-700' %> text-white text-xs font-black py-3.5 px-8 rounded-xl transition-all shadow-lg active:scale-95 flex items-center justify-center gap-2 uppercase tracking-wider">
              <i class="fa-solid <%= product ? 'fa-cloud-arrow-up' : 'fa-rocket' %> text-sm"></i>
              <%= product ? "Commit System Changes" : "Deploy Product Live" %>
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
  
  <%- include('../partials/loader') %>

  <script>
    // Toggle Category Dropdown Menu
    const dropdownBtn = document.getElementById('dropdown-trigger-btn');
    const dropdownPanel = document.getElementById('dropdown-menu-panel');
    const dropdownChevron = document.getElementById('dropdown-chevron');
    const categoryInput = document.getElementById('category-input');

    if (dropdownBtn && dropdownPanel) {
      dropdownBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = dropdownPanel.classList.contains('hidden');
        if (isHidden) {
          dropdownPanel.classList.remove('hidden');
          setTimeout(() => {
            dropdownPanel.classList.remove('scale-95', 'opacity-0');
            dropdownPanel.classList.add('scale-100', 'opacity-100');
          }, 10);
          dropdownChevron.classList.add('rotate-180');
        } else {
          closeDropdown();
        }
      });
    }

    function closeDropdown() {
      if (dropdownPanel && !dropdownPanel.classList.contains('hidden')) {
        dropdownPanel.classList.remove('scale-100', 'opacity-100');
        dropdownPanel.classList.add('scale-95', 'opacity-0');
        dropdownChevron.classList.remove('rotate-180');
        setTimeout(() => {
          dropdownPanel.classList.add('hidden');
        }, 150);
      }
    }

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (dropdownPanel && !dropdownPanel.contains(e.target) && !dropdownBtn.contains(e.target)) {
        closeDropdown();
      }
    });

    // Select category function
    function selectCategory(value, label, emoji, colorClass) {
      // Update hidden input
      categoryInput.value = value;

      // Update button trigger content
      const selectedContent = document.getElementById('dropdown-selected-content');
      selectedContent.innerHTML = `
        <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-lg bg-${colorClass}-50 text-${colorClass}-700 font-bold border border-${colorClass}-200/50">
          <span class="mr-1 text-sm">${emoji}</span>
          ${label}
        </span>
      `;
      selectedContent.className = "flex items-center gap-2";

      // Update check icons and active states in the dropdown options
      document.querySelectorAll('.dropdown-option').forEach(opt => {
        const checkIcon = opt.querySelector('.check-icon');
        if (opt.getAttribute('data-value') === value) {
          opt.classList.add('bg-zinc-50', 'ring-1', 'ring-red-500/10');
          if (checkIcon) checkIcon.classList.remove('hidden');
        } else {
          opt.classList.remove('bg-zinc-50', 'ring-1', 'ring-red-500/10');
          if (checkIcon) checkIcon.classList.add('hidden');
        }
      });

      // Close menu
      closeDropdown();
    }

    // Initialize selection on load (e.g. for Edit Mode)
    window.addEventListener('DOMContentLoaded', () => {
      const initialVal = categoryInput.value;
      if (initialVal) {
        const option = document.querySelector(`.dropdown-option[data-value="${initialVal}"]`);
        if (option) {
          option.click();
        }
      }
    });
  </script>

</body>
</html>