<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Kush Mart</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { darkMode: 'class' }
  </script>
</head>
<body class="bg-[#fafdfb] text-zinc-900 antialiased dark:bg-[#050906] dark:text-white transition-colors duration-300 flex flex-col min-h-screen [background:radial-gradient(circle_at_50%_-20%,#e2f5e7_0%,#f7fbf8_60%,#ffffff_100%)] dark:[background:radial-gradient(circle_at_50%_-20%,#0d2111_0%,#060c08_60%,#020403_100%)]">

  <div class="flex-grow flex items-center justify-center px-4 py-24">
    <div class="w-full max-w-md bg-white dark:bg-[#0d110e]/80 border border-zinc-200 dark:border-zinc-900 rounded-3xl p-8 shadow-xl shadow-zinc-200/40 dark:shadow-none backdrop-blur-md">
      
      <div class="text-center mb-8">
        <a href="/" class="text-3xl font-black tracking-tighter text-zinc-900 dark:text-white inline-block transition-transform duration-300 hover:rotate-12">
          KUSH<span class="text-[#24963f]">MART</span>
        </a>
        <h2 class="text-xl font-extrabold text-zinc-800 dark:text-zinc-100 mt-4 tracking-tight">Reset Your Password</h2>
        <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1.5 font-medium">Enter your registered email and we'll send you a secure link.</p>
      </div>

      <% if (message) { %>
        <div class="mb-6 p-3.5 rounded-xl text-xs font-bold flex items-center gap-2 border 
          <%= type === 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-700 dark:bg-emerald-950/30 dark:border-emerald-900 dark:text-emerald-400' : 'bg-rose-50 border-rose-200 text-rose-700 dark:bg-rose-950/30 dark:border-rose-900 dark:text-rose-400' %>">
          <i class="fa-solid <%= type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation' %> text-sm"></i>
          <%= message %>
        </div>
      <% } %>

      <form action="/users/forgot-password" onsubmit="showLoader(event)" method="POST" class="space-y-5">
        <div>
          <label for="email" class="block text-[10px] font-black uppercase tracking-widest text-[#24963f] mb-2">Email Address</label>
          <div class="relative flex items-center">
            <span class="absolute left-4 text-zinc-400"><i class="fa-solid fa-envelope text-xs"></i></span>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder="name@example.com"
              class="w-full bg-zinc-50/50 border border-zinc-200 rounded-xl py-3.5 pl-11 pr-4 text-xs font-medium text-zinc-900 outline-none transition-all focus:border-[#24963f] focus:ring-2 focus:ring-emerald-500/10 dark:bg-zinc-900/40 dark:border-zinc-800 dark:text-white dark:focus:border-[#24963f]"
            />
          </div>
        </div>

        <button type="submit" class="w-full py-3.5 bg-[#24963f] hover:bg-[#1e7e34] text-white text-xs font-bold rounded-xl shadow-md shadow-emerald-700/10 transition-all duration-200 flex items-center justify-center gap-2 group">
          Send Recovery Link
          <i class="fa-solid fa-paper-plane text-[10px] group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></i>
        </button>
      </form>

      <div class="mt-8 pt-6 border-t border-zinc-100 dark:border-zinc-900 text-center">
        <a href="/users/login" class="text-xs font-bold text-zinc-500 hover:text-[#24963f] dark:text-zinc-400 dark:hover:text-[#24963f] transition-colors inline-flex items-center gap-1.5">
          <i class="fa-solid fa-arrow-left-long text-[10px]"></i> Back to Login
        </a>
      </div>

    </div>
  </div>

  <script>
    (function () {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'dark') { document.documentElement.classList.add('dark'); } 
      else { document.documentElement.classList.remove('dark'); }
    })();
  </script>
  <%- include('partials/loader') %>
</body>
</html>