<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Set New Password | Kush Mart</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { darkMode: 'class' }</script>
</head>
<body class="bg-[#fafdfb] text-zinc-900 antialiased dark:bg-[#050906] dark:text-white transition-colors duration-300 flex flex-col min-h-screen [background:radial-gradient(circle_at_50%_-20%,#e2f5e7_0%,#f7fbf8_60%,#ffffff_100%)] dark:[background:radial-gradient(circle_at_50%_-20%,#0d2111_0%,#060c08_60%,#020403_100%)]">

  <div class="flex-grow flex items-center justify-center px-4 py-24">
    <div class="w-full max-w-md bg-white dark:bg-[#0d110e]/80 border border-zinc-200 dark:border-zinc-900 rounded-3xl p-8 shadow-xl shadow-zinc-200/40 dark:shadow-none backdrop-blur-md">
      
      <div class="text-center mb-8">
        <a href="/" class="text-3xl font-black tracking-tighter text-zinc-900 dark:text-white inline-block transition-transform duration-300 hover:rotate-12">
          KUSH<span class="text-[#24963f]">MART</span>
        </a>
        <h2 class="text-xl font-extrabold text-zinc-800 dark:text-zinc-100 mt-4 tracking-tight">Create New Password</h2>
        <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1.5 font-medium">Please enter your strong new password below.</p>
      </div>

      <% if (message) { %>
        <div class="mb-6 p-3.5 rounded-xl text-xs font-bold flex items-center gap-2 border bg-rose-50 border-rose-200 text-rose-700 dark:bg-rose-950/30 dark:border-rose-900 dark:text-rose-400">
          <i class="fa-solid fa-circle-exclamation text-sm"></i>
          <%= message %>
        </div>
      <% } %>

      <form action="/users/reset-password/<%= token %>" method="POST" onsubmit="showLoader(event)" class="space-y-5">
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[#24963f] mb-2">New Password</label>
          <div class="relative flex items-center">
            <span class="absolute left-4 text-zinc-400"><i class="fa-solid fa-lock text-xs"></i></span>
            <input 
              type="password" 
              name="password" 
              required 
              placeholder="••••••••"
              class="w-full bg-zinc-50/50 border border-zinc-200 rounded-xl py-3.5 pl-11 pr-4 text-xs font-medium text-zinc-900 outline-none transition-all focus:border-[#24963f] focus:ring-2 focus:ring-emerald-500/10 dark:bg-zinc-900/40 dark:border-zinc-800 dark:text-white dark:focus:border-[#24963f]"
            />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[#24963f] mb-2">Confirm New Password</label>
          <div class="relative flex items-center">
            <span class="absolute left-4 text-zinc-400"><i class="fa-solid fa-circle-check text-xs"></i></span>
            <input 
              type="password" 
              name="confirmPassword" 
              required 
              placeholder="••••••••"
              class="w-full bg-zinc-50/50 border border-zinc-200 rounded-xl py-3.5 pl-11 pr-4 text-xs font-medium text-zinc-900 outline-none transition-all focus:border-[#24963f] focus:ring-2 focus:ring-emerald-500/10 dark:bg-zinc-900/40 dark:border-zinc-800 dark:text-white dark:focus:border-[#24963f]"
            />
          </div>
        </div>

        <button type="submit" class="w-full py-3.5 bg-[#24963f] hover:bg-[#1e7e34] text-white text-xs font-bold rounded-xl shadow-md shadow-emerald-700/10 transition-all duration-200 flex items-center justify-center gap-2 group">
          Update Password
          <i class="fa-solid fa-key text-[10px] group-hover:rotate-45 transition-transform"></i>
        </button>
      </form>

    </div>
  </div>

  <script>
    (function () {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'dark') { document.documentElement.classList.add('dark'); } 
      else { document.documentElement.classList.remove('dark'); }
    })();
  </script>

  <%- include('partials/loader') %>
</body>
</html>