              <i class="fa-solid fa-basket-shopping text-[11px] opacity-70"></i> My Cart Page
            </a>
            <a href="/users/orders" class="flex items-center gap-2.5 px-3 py-2 text-xs font-semibold text-zinc-600 hover:bg-emerald-50 hover:text-emerald-600 rounded-xl transition-all dark:text-zinc-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-400">
