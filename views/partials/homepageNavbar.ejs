    <div class="flex items-center justify-between mb-6 pb-4 border-b border-zinc-100 dark:border-zinc-900/60">
      <a href="/" class="text-lg font-black tracking-tighter text-zinc-900 dark:text-white">KUSH<span class="text-[#24963f]">MART</span></a>
