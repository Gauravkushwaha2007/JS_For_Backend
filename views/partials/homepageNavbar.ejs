  <% if(user){ %>
    <div class="pt-4 border-t border-zinc-100 dark:border-zinc-900/60 mt-4">
      <a href="/users/logout" class="w-full flex items-center justify-center gap-2.5 py-3 px-4 bg-rose-50 hover:bg-rose-100 dark:bg-rose-500/5 dark:hover:bg-rose-500/10 text-rose-600 dark:text-rose-400 rounded-xl font-extrabold text-xs uppercase tracking-wider transition-all duration-200">
        <i class="fa-solid fa-arrow-right-from-bracket text-xs"></i> <span>Secure Logout</span>
      </a>
    </div>
  <% } %>
</aside>

<div id="navMobileOverlay" onclick="toggleNavMenu()" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden transition-opacity duration-300"></div>

<script>
  // Placeholder visibility management
  function hidePlaceholderTrack() {
    const pBox = document.getElementById('navPlaceholderBox');
    if (pBox) pBox.classList.add('hidden');
  }

  function showPlaceholderTrack() {
    const input = document.getElementById('searchInput');
    const pBox = document.getElementById('navPlaceholderBox');
    if (pBox && input && input.value.trim() === "") pBox.classList.remove('hidden');
  }

  // Live Instant UI Search Filtering Engine
  function liveSearchDropdown() {
    const input = document.getElementById('searchInput');
    const dropdown = document.getElementById('search-suggestions');
    const list = document.getElementById('suggestions-list');
    
    if (!input || !dropdown || !list) return;
    const query = input.value.toLowerCase().trim();
    
    if (query === "") {
      dropdown.classList.add('hidden');
      resetProductDisplayGrid();
      return;
    }

    list.innerHTML = ""; 
    let matchCount = 0;
    const cards = document.querySelectorAll('.product-card');
    
    cards.forEach(card => {
      const nameTag = card.querySelector('.product-name');
      const imgTag = card.querySelector('img');
      const priceTag = card.querySelector('.font-black');
      
      if (nameTag) {
        const nameText = nameTag.innerText;
        const cleanName = nameText.toLowerCase();
        
        if (cleanName.includes(query)) {
          matchCount++;
          card.style.display = ''; // Show matches
          
          if (matchCount <= 5) {
            const row = document.createElement('div');
            row.className = "flex items-center gap-3 p-2 hover:bg-zinc-50 dark:hover:bg-zinc-900 rounded-xl cursor-pointer transition-colors";
            
            const imgSrc = imgTag ? imgTag.src : 'https://placehold.co/40';
            const priceText = priceTag ? priceTag.innerText : '₹0';
            
            row.innerHTML = `
              <img src="${imgSrc}" class="w-8 h-8 rounded-lg object-cover bg-zinc-50 border border-zinc-100 dark:border-zinc-800">
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-zinc-800 dark:text-zinc-200 truncate">${nameText}</p>
                <p class="text-[10px] text-emerald-600 font-extrabold">${priceText}</p>
              </div>
              <i class="fa-solid fa-chevron-right text-[8px] text-zinc-400 pr-1"></i>
            `;
            
            row.onclick = function() {
              input.value = nameText;
              dropdown.classList.add('hidden');
              cards.forEach(c => {
                const nt = c.querySelector('.product-name');
                if (nt) c.style.display = nt.innerText.toLowerCase() === cleanName ? '' : 'none';
              });
            };
            list.appendChild(row);
          }
        } else {
          card.style.display = 'none'; // Hide non-matches
        }
      }
    });

    if (matchCount > 0) dropdown.classList.remove('hidden');
    else {
      list.innerHTML = `<div class="text-center py-3 text-zinc-400 text-[11px] font-bold">Product nahi mila bhai</div>`;
      dropdown.classList.remove('hidden');
    }
  }

  // Non-Reload Client-Side Category Filter Rules Engine
  function filterByCategory(categoryName, element) {
    if(window.event) window.event.preventDefault();

    const cards = document.querySelectorAll('.product-card');
    const targetCategory = categoryName.toLowerCase().trim();

    cards.forEach(card => {
      const productCategory = card.getAttribute('data-category') ? card.getAttribute('data-category').toLowerCase().trim() : '';
      if (targetCategory === 'all' || productCategory === targetCategory) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Handle styling states without breaking core button visibility wrappers
    document.querySelectorAll('.category-nav-link').forEach(link => {
      link.className = "bg-zinc-900 border border-zinc-800 px-4 py-2.5 rounded-xl whitespace-nowrap text-zinc-300 hover:text-white cursor-pointer transition-colors category-nav-link";
    });

    if (element && element.classList.contains('category-nav-link')) {
      if (targetCategory === 'all') {
        element.className = "category-nav-link bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 px-4 py-2.5 rounded-xl whitespace-nowrap cursor-pointer";
      } else {
        element.className = "category-nav-link bg-emerald-600 border border-emerald-500 px-4 py-2.5 rounded-xl whitespace-nowrap text-white cursor-pointer transition-colors";
      }
    }
  }

  function resetProductDisplayGrid() {
    document.querySelectorAll('.product-card').forEach(card => { card.style.display = ''; });
  }

  // Dropdown dismissal observer
  document.addEventListener('click', function(e) {
    const dropdown = document.getElementById('search-suggestions');
    const input = document.getElementById('searchInput');
    if (dropdown && !dropdown.contains(e.target) && e.target !== input) {
      dropdown.classList.add('hidden');
    }
  });

  // Mobile navigation controller
  function toggleNavMenu() {
    const drawer = document.getElementById('navMobileDrawer');
    const overlay = document.getElementById('navMobileOverlay');
    const icon = document.getElementById('navHamburgerIcon');

    if (drawer.classList.contains('-translate-x-full')) {
      drawer.classList.remove('-translate-x-full');
      drawer.classList.add('translate-x-0');
      overlay.classList.remove('hidden');
      icon.classList.remove('fa-bars');
      icon.classList.add('fa-xmark');
    } else {
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
      icon.classList.remove('fa-xmark');
      icon.classList.add('fa-bars');
    }
  }

  function renderHomepageCart(summary) {
    const totalItems = Number(summary?.totalItems || 0);
    const totalCartPrice = Number(summary?.totalCartPrice || 0);

    if (totalItems > 0) {
      return `
        <a id="header-cart-link" href="/users/cart/products" class="flex items-center gap-2 sm:gap-3 bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-200 dark:border-emerald-900/60 px-3 py-1.5 rounded-xl transition-all duration-300 shadow-[0_4px_15px_rgba(16,185,129,0.08)] group">
          <div class="relative flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 bg-emerald-500/15 rounded-lg text-[#24963f] dark:text-emerald-400">
            <i class="fa-solid fa-basket-shopping text-sm sm:text-base group-hover:scale-110 transition-transform duration-200"></i>
            <span id="header-cart-count" class="absolute -top-1.5 -right-1.5 bg-red-600 text-white font-black text-[9px] sm:text-[10px] w-4 h-4 sm:w-5 sm:h-5 rounded-full flex items-center justify-center shadow-md border-2 border-white dark:border-zinc-950">${totalItems}</span>
          </div>
          <span id="header-cart-total" class="text-xs font-black text-zinc-900 dark:text-white tracking-tight">&#8377;${totalCartPrice}</span>
        </a>
      `;
    }

    return `
      <a id="header-cart-link" href="/users/cart/products" class="flex items-center gap-2 border border-zinc-200 bg-zinc-100 text-zinc-600 px-3.5 py-2 rounded-xl transition-all font-bold text-xs uppercase tracking-wider hover:bg-zinc-200 dark:text-zinc-300 dark:bg-zinc-900/30 dark:border-zinc-800">
        <i class="fa-solid fa-basket-shopping text-xs text-zinc-400 dark:text-zinc-500"></i>
        <span class="hidden sm:inline">Cart</span>
      </a>
    `;
  }

  window.syncHeaderCart = function(summary) {
    const headerCartLink = document.getElementById('header-cart-link');
    if (!headerCartLink || !summary) return;

    headerCartLink.outerHTML = renderHomepageCart(summary);
  };
</script>
