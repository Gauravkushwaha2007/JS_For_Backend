            <div class="h-[22px] leading-[22px] text-xs font-medium text-zinc-400 dark:text-zinc-600">Search "snacks"</div>
          </div>
        </div>

        <div class="relative w-full">
          <input type="text" id="searchInput" oninput="liveSearchDropdown()" onfocus="hidePlaceholderTrack(); liveSearchDropdown();" onblur="showPlaceholderTrack();" class="w-full bg-transparent focus:outline-none text-sm text-zinc-800 dark:text-zinc-100 z-20 relative" autocomplete="off">
          
          <div id="search-suggestions" class="absolute left-[-45px] right-[-15px] top-[38px] bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-2xl shadow-2xl max-h-64 overflow-y-auto hidden z-50">
            <div id="suggestions-list" class="p-1.5 space-y-0.5"></div>
          </div>
        </div>
      </div>
    </form>
  </div>

