    <div class="space-y-5">
      <div>
        <p class="font-bold text-[10px] uppercase text-zinc-400 dark:text-zinc-500 mb-2.5 tracking-wider">Navigation</p>
        <nav class="space-y-1 text-xs font-bold">
          <a href="/" class="flex items-center gap-3.5 py-2.5 px-3 rounded-xl bg-emerald-50 text-[#24963f] dark:bg-emerald-950/20 dark:text-emerald-400">
            <i class="fa-solid fa-house text-sm"></i> <span>Home</span>
          </a>
          <a href="#categories" onclick="toggleNavMenu()" class="flex items-center gap-3.5 py-2.5 px-3 rounded-xl text-zinc-600 hover:bg-zinc-50 dark:text-zinc-400 dark:hover:bg-zinc-900/40 transition-all">
            <i class="fa-solid fa-layer-group text-sm opacity-70"></i> <span>Categories</span>
          </a>
          <a href="/products/allProducts" class="flex items-center gap-3.5 py-2.5 px-3 rounded-xl text-zinc-600 hover:bg-zinc-50 dark:text-zinc-400 dark:hover:bg-zinc-900/40 transition-all">
            <i class="fa-solid fa-boxes-stacked text-sm opacity-70"></i> <span>All Products</span>
          </a>
