    <button onclick="toggleNavMenu()" type="button" class="w-9 h-9 flex md:hidden items-center justify-center bg-zinc-100 hover:bg-zinc-200 border border-zinc-200 rounded-xl text-zinc-700 transition-all dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-300">
      <i id="navHamburgerIcon" class="fa-solid fa-bars text-base"></i>
    </button>

  </div>
</nav>

<aside id="navMobileDrawer" class="fixed inset-y-0 left-0 w-72 bg-white dark:bg-[#070c08] p-6 shadow-[5px_0_30px_rgba(0,0,0,0.15)] z-50 transform -translate-x-full md:hidden flex flex-col justify-between transition-transform duration-300 ease-in-out">
