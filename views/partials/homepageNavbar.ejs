            <a href="/users/logout" class="flex items-center gap-2.5 px-3 py-2 text-xs font-bold text-rose-600 hover:bg-rose-50 rounded-xl transition-all dark:text-rose-400">
              <i class="fa-solid fa-arrow-right-from-bracket text-[11px]"></i> Secure Logout
            </a>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="hidden md:flex items-center gap-2">
        <a href="/users/login" class="px-3 py-2 text-xs font-bold text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors duration-200">Login</a>
        <a href="/users/register" class="px-4 py-2 text-xs font-bold bg-emerald-500 text-white rounded-xl hover:bg-emerald-400 shadow-md shadow-emerald-500/10 active:scale-95 transition-all duration-200">Sign Up</a>
      </div>
    <% } %>

    <button onclick="toggleTheme()" type="button" class="w-9 h-9 flex items-center justify-center bg-zinc-100 hover:bg-zinc-200 border border-zinc-200 rounded-xl text-zinc-700 transition-all dark:bg-zinc-900/80 dark:border-zinc-800 dark:text-zinc-300">
      <i id="theme-icon-sun" class="fa-solid fa-sun text-sm hidden dark:block"></i>
      <i id="theme-icon-moon" class="fa-solid fa-moon text-sm dark:hidden"></i>
    </button>

    <% const homepageCartItems = (user && user.cart) ? user.cart.filter(item => item && item.product).length : 0; %>
    <% if(user && user.cart && homepageCartItems > 0) { %>
      <a id="header-cart-link" href="/users/cart/products" class="flex items-center gap-2 sm:gap-3 bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-200 dark:border-emerald-900/60 px-3 py-1.5 rounded-xl transition-all duration-300 shadow-[0_4px_15px_rgba(16,185,129,0.08)] group">
        <div class="relative flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 bg-emerald-500/15 rounded-lg text-[#24963f] dark:text-emerald-400">
          <i class="fa-solid fa-basket-shopping text-sm sm:text-base group-hover:scale-110 transition-transform duration-200"></i>
          <span id="header-cart-count" class="absolute -top-1.5 -right-1.5 bg-red-600 text-white font-black text-[9px] sm:text-[10px] w-4 h-4 sm:w-5 sm:h-5 rounded-full flex items-center justify-center shadow-md border-2 border-white dark:border-zinc-950">
            <%= homepageCartItems %>
          </span>
        </div>
        <span id="header-cart-total" class="text-xs font-black text-zinc-900 dark:text-white tracking-tight">
          ₹<%= typeof totalCartPrice !== 'undefined' ? totalCartPrice : 0 %>
        </span>
      </a>
    <% } else { %>
      <a id="header-cart-link" href="/users/cart/products" class="flex items-center gap-2 border border-zinc-200 bg-zinc-100 text-zinc-600 px-3.5 py-2 rounded-xl transition-all font-bold text-xs uppercase tracking-wider hover:bg-zinc-200 dark:text-zinc-300 dark:bg-zinc-900/30 dark:border-zinc-800">
        <i class="fa-solid fa-basket-shopping text-xs text-zinc-400 dark:text-zinc-500"></i>
