          <div class="grid grid-cols-2 gap-2">
            <a href="/users/login" class="flex items-center justify-center py-2 px-3 bg-zinc-100 dark:bg-zinc-800 text-zinc-800 dark:text-white text-xs font-extrabold rounded-xl">LOGIN</a>
