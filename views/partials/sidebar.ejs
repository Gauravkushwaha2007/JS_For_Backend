<aside class="w-full md:w-60 bg-white border-b md:border-b-0 md:border-r border-gray-100 p-6 flex-shrink-0 md:sticky md:top-20 md:h-[calc(100vh-5rem)] overflow-y-auto">
  <div class="mb-6">
    <h1 class="text-xl font-black tracking-tight text-black">Apna Mart</h1>
    <p class="text-[10px] uppercase font-bold tracking-widest text-[#24963f] mt-0.5">
      <%= (typeof user !== 'undefined' && user && user.role === 'admin') ? 'Admin Control' : 'Shop Catalogue' %>
    </p>
  </div>

  <nav class="space-y-1 text-xs font-semibold text-gray-500">
    <p class="font-bold text-[10px] uppercase tracking-wider text-gray-400 mb-2 px-1">Browse</p>
    
    <a href="/products/allProducts" class="bg-[#24963f]/10 text-[#24963f] py-2.5 px-3 rounded-xl flex items-center gap-2.5 transition-all">
      <i class="fa-solid fa-store text-xs"></i> All Categories
    </a>
    
    <a href="/users/cart/products" class="flex items-center gap-2.5 py-2.5 px-3 rounded-xl hover:bg-gray-50 hover:text-black transition-all">
      <i class="fa-solid fa-basket-shopping text-xs opacity-70"></i> Your Basket
    </a>

    <% if(typeof user !== 'undefined' && user) { %>
      <a href="/users/orders" class="flex items-center gap-2.5 py-2.5 px-3 rounded-xl hover:bg-gray-50 hover:text-black transition-all">
        <i class="fa-solid fa-clock-rotate-left text-xs opacity-70"></i> Track Orders
      </a>
    <% } %>
  </nav>
</aside>