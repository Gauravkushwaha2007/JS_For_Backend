<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> | Apna Mart</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .nav-sticky { position: sticky; top: 0; z-index: 50; }
  </style>
</head>
<body class="bg-white text-gray-900 antialiased">

<%- include('partials/header') %>

  <nav class="max-w-7xl mx-auto px-6 pt-8 text-[10px] text-gray-400 font-bold uppercase tracking-widest flex items-center gap-2 flex-wrap">
    <a href="/" class="hover:text-[#24963f] transition-colors flex items-center gap-1.5">
      <i class="fa-solid fa-house text-[11px]"></i> Home
    </a>
    <span class="text-gray-300">/</span>
    <a href="/products/allProducts" class="hover:text-[#24963f] text-gray-400 transition-colors flex items-center gap-1.5">
      <i class="fa-solid fa-cubes text-[11px]"></i> Products
    </a>
    <span class="text-gray-300">/</span>
    <span class="text-gray-800 truncate flex items-center gap-1.5">
      <i class="fa-solid fa-basket-shopping text-[11px] text-[#24963f]"></i> <%= product.name %>
    </span>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
    
    <!-- Product Images Column -->
    <div class="md:col-span-5 flex flex-col gap-6">
      
      <!-- Main Image Card -->
      <div class="w-full flex items-center justify-center border border-gray-100 rounded-[32px] p-8 relative min-h-[350px] sm:min-h-[450px] shadow-sm transition-all duration-300 group" style="background-color: <%= product.bgColor || '#f9fafb' %>;">
        
        <!-- Main Image Elements -->
        <div class="relative w-full h-[280px] sm:h-[350px] flex items-center justify-center">
          <% if (product.images && product.images.length > 0) { %>
            <% product.images.forEach((img, idx) => { %>
              <img id="detailSlide-<%= idx %>" 
                   src="/uploads/<%= img %>" 
                   alt="<%= product.name %>" 
                   class="detail-slide absolute max-w-full max-h-full object-contain drop-shadow-2xl transition-all duration-500 <%= idx === 0 ? 'opacity-100 scale-100' : 'opacity-0 scale-95 pointer-events-none' %>"
                   onerror="this.src='/uploads/default-product.png'">
            <% }) %>
          <% } else { %>
            <img src="/uploads/<%= product.image || 'default-product.png' %>" 
                 alt="<%= product.name %>" 
                 class="max-w-full max-h-full object-contain drop-shadow-2xl hover:scale-105 transition-transform duration-500"
                 onerror="this.src='/uploads/default-product.png'">
          <% } %>
        </div>

        <!-- Off Badge -->
        <% if(product.discount > 0) { %>
          <span class="absolute top-6 left-6 bg-red-500 text-white text-[10px] font-black px-3.5 py-1.5 rounded-xl uppercase tracking-widest shadow-md shadow-red-500/20 z-10">
            <%= Math.round((product.discount / (product.price + product.discount)) * 100) %>% OFF
          </span>
        <% } %>

        <!-- Navigation Chevrons (Only if multiple images exist) -->
        <% if (product.images && product.images.length > 1) { %>
          <button onclick="prevDetailSlide(event)" class="absolute left-4 top-1/2 -translate-y-1/2 w-9 h-9 rounded-xl bg-white/90 hover:bg-emerald-600 hover:text-white text-emerald-700 flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 active:scale-90 shadow-md border border-gray-100/50 z-20 cursor-pointer">
            <i class="fa-solid fa-chevron-left text-xs"></i>
          </button>
          <button onclick="nextDetailSlide(event)" class="absolute right-4 top-1/2 -translate-y-1/2 w-9 h-9 rounded-xl bg-white/90 hover:bg-emerald-600 hover:text-white text-emerald-700 flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 active:scale-90 shadow-md border border-gray-100/50 z-20 cursor-pointer">
            <i class="fa-solid fa-chevron-right text-xs"></i>
          </button>
        <% } %>

        <!-- Stock Status Label -->
        <div class="absolute bottom-6 left-6 right-6 z-10">
          <% if (product.stock == 0) { %>
            <span class="w-full text-center block bg-red-500/10 border border-red-500/20 text-red-600 text-[10px] font-black py-2 px-4 rounded-xl uppercase tracking-wider">
              🚨 Out of Stock (Re-stocking Soon)
            </span>
          <% } else if (product.stock <= 10) { %>
            <span class="w-full text-center block bg-amber-500/10 border border-amber-500/20 text-amber-600 text-[10px] font-black py-2 px-4 rounded-xl uppercase tracking-wider animate-pulse">
              ⚡ Hurry Up! Only <%= product.stock %> units left in stock
            </span>
          <% } else { %>
            <span class="w-full text-center block bg-emerald-50/80 border border-emerald-100 text-emerald-600 text-[10px] font-bold py-2 px-4 rounded-xl uppercase tracking-wider">
              ✅ In Stock (Available)
            </span>
          <% } %>
        </div>
      </div>

      <!-- Thumbnail Carousel (Only if multiple images exist) -->
      <% if (product.images && product.images.length > 1) { %>
        <div class="flex items-center justify-center gap-3 flex-wrap select-none">
          <% product.images.forEach((img, idx) => { %>
            <button onclick="setDetailSlide(<%= idx %>)" 
                    id="detailThumb-<%= idx %>"
                    class="detail-thumb w-14 h-14 rounded-2xl bg-white p-1.5 border-2 transition-all hover:scale-105 active:scale-95 shadow-sm overflow-hidden flex items-center justify-center flex-shrink-0 cursor-pointer <%= idx === 0 ? 'border-[#24963f] shadow-md scale-105' : 'border-gray-100' %>">
              <img src="/uploads/<%= img %>" alt="thumb" class="max-w-full max-h-full object-contain" onerror="this.src='/uploads/default-product.png'">
            </button>
          <% }) %>
        </div>
      <% } %>

    </div>

<div class="md:col-span-7 flex flex-col space-y-8">
      
  <div>
    <h1 class="text-3xl md:text-4xl font-black tracking-tight text-gray-900 leading-tight">
      <%= product.name %>
    </h1>
    <div class="flex flex-wrap gap-2 mt-3">
      <span class="text-emerald-700 bg-emerald-50 border border-emerald-100 font-bold text-[10px] px-3 py-1 rounded-lg flex items-center gap-1.5 uppercase tracking-wider">
        <i class="fa-solid fa-truck-fast"></i> Fast & Secured Delivery
      </span>
      <span class="text-gray-500 bg-gray-50 border border-gray-100 font-bold text-[10px] px-3 py-1 rounded-lg flex items-center gap-1.5 uppercase tracking-wider">
        <i class="fa-solid fa-circle-check"></i> Quality Assured
      </span>
    </div>
  </div>

  <div class="border-t border-b border-gray-100 py-5">
    <h3 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">
      <i class="fa-solid fa-circle-info text-gray-400 mr-1"></i> Product Description
    </h3>
    <p class="text-sm text-gray-600 leading-relaxed font-medium">
      <%= product.description ? product.description : "Fresh and premium quality sourced directly for your daily needs. Sealed with hygiene and pure freshness to ensure maximum shelf-life and great taste." %>
    </p>
  </div>

  <div>
    <h3 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-3">Select Unit</h3>
    <div class="flex flex-wrap gap-4">
      <div class="border-2 border-[#24963f] bg-emerald-50/30 rounded-2xl px-6 py-3.5 min-w-[120px] text-center shadow-sm">
        <p class="text-xs font-bold text-gray-600 mb-0.5"><%= product.quantity || '1 Unit' %></p>
        <p class="text-base font-black text-black">₹<%= product.discount > 0 ? (product.price - product.discount) : product.price %></p>
      </div>
      <div class="border border-gray-100 bg-gray-50/50 rounded-2xl px-6 py-3.5 min-w-[120px] text-center opacity-40 flex flex-col justify-center">
        <p class="text-[11px] font-medium text-gray-400">Standard Pack</p>
        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mt-0.5">Default</p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between bg-gray-50/50 p-6 rounded-[24px] border border-gray-100 max-w-xl shadow-inner">
    <div>
      <div class="flex items-baseline gap-2.5">
        <% if(product.discount > 0) { %>
          <span class="text-3xl font-black text-black">₹<%= product.price - product.discount %></span>
          <span class="text-sm text-gray-400 line-through font-bold">₹<%= product.price %></span>
        <% } else { %>
          <span class="text-3xl font-black text-black">₹<%= product.price %></span>
        <% } %>
      </div>
      <p class="text-[9px] text-gray-400 font-bold uppercase tracking-wider mt-1">(Inclusive of all taxes)</p>
    </div>

    <div id="action-box-<%= product._id %>" class="flex flex-col items-end shrink-0">
      <% if(product.stock > 0) { %>
        
        <% 
          let detailCartItem = user && user.cart ? user.cart.find(c => c.product && c.product._id.toString() === product._id.toString()) : null; 
        %>

        <% if (detailCartItem) { %>
          <div class="flex items-center bg-[#24963f] text-white rounded-xl overflow-hidden shadow-lg shadow-emerald-900/10 font-black text-sm h-[48px]">
            <button onclick="descreaseQty('<%= product._id %>')" class="px-5 h-full hover:bg-[#1e7e34] transition-colors font-black text-base active:scale-95">-</button>
            <span id="quantityNumber-<%= product._id %>" class="px-2 min-w-[28px] text-center font-black text-sm bg-[#1e7e34]/20 h-full flex items-center justify-center"><%= detailCartItem.quantity %></span>
            <button onclick="increaseQty('<%= product._id %>')" class="px-5 h-full hover:bg-[#1e7e34] transition-colors font-black text-base active:scale-95">+</button>
          </div>
        <% } else { %>
          <button onclick="addToCart('<%= product._id %>', '<%= product.discount > 0 ? (product.price - product.discount) : product.price %>')" 
                  class="bg-[#24963f] hover:bg-[#1e7e34] text-white font-black text-xs px-7 py-3.5 rounded-xl transition-all active:scale-95 shadow-lg shadow-emerald-900/10 flex items-center gap-2 group tracking-wider uppercase">
            <i class="fa-solid fa-basket-shopping text-xs group-hover:animate-bounce"></i> 
            <span>ADD TO BASKET</span>
          </button>
        <% } %>

      <% } else { %>
        <button disabled class="bg-gray-100 border border-gray-200 text-gray-400 font-black text-xs px-8 py-4 rounded-xl cursor-not-allowed uppercase tracking-wider">OUT OF STOCK</button>
      <% } %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-6 pt-4 max-w-xl border-t border-gray-100">
    <div class="flex items-start gap-3">
      <div class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-[#24963f] border border-emerald-100 flex-shrink-0">
        <i class="fa-solid fa-bolt text-xs"></i>
      </div>
      <div>
        <h5 class="text-xs font-black text-gray-900 uppercase tracking-wide">Superfast Delivery</h5>
        <p class="text-[11px] text-gray-500 mt-0.5 leading-relaxed">Directly shipped via local Kush Mart hub nearest to you.</p>
      </div>
    </div>
    <div class="flex items-start gap-3">
      <div class="w-9 h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-[#24963f] border border-emerald-100 flex-shrink-0">
        <i class="fa-solid fa-shield-heart text-xs"></i>
      </div>
      <div>
        <h5 class="text-xs font-black text-gray-900 uppercase tracking-wide">Premium Quality</h5>
        <p class="text-[11px] text-gray-500 mt-0.5 leading-relaxed">100% fresh and hygienic items sourced daily.</p>
      </div>
    </div>
  </div>

</div>
  </main>

  <!-- RELATED PRODUCTS SECTION -->
  <section class="max-w-7xl mx-auto px-6 py-12 border-t border-gray-100 mt-6 select-none">
    <div class="flex items-baseline justify-between mb-8">
      <div>
        <h3 class="text-xl font-black tracking-tight text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-wand-magic-sparkles text-amber-500 text-sm animate-pulse"></i> Suggested Products For You
        </h3>
        <p class="text-xs text-gray-500 font-semibold mt-1">Based on this category and popular fresh items</p>
      </div>
      <a href="/products/allProducts" class="text-xs font-black text-zinc-500 hover:text-[#24963f] transition-colors flex items-center gap-1">
        View Catalogue <i class="fa-solid fa-chevron-right text-[9px] ml-0.5"></i>
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% if (typeof relatedProducts !== 'undefined' && relatedProducts && relatedProducts.length > 0) { %>
        <% relatedProducts.forEach(function(item) { %>
          <div class="product-card group bg-white border border-gray-200/80 rounded-2xl p-4 hover:border-[#24963f]/40 hover:shadow-xl hover:shadow-gray-200/20 transition-all duration-300 flex flex-col justify-between">
            <div>
              <div class="h-36 bg-gray-50/60 border border-gray-100 rounded-xl mb-3.5 overflow-hidden relative flex items-center justify-center transition-all group-hover:bg-opacity-80" style="background-color: <%= item.bgColor || '#f9fafb' %>;">
                <a href="/products/view/<%= item._id %>" class="w-full h-full block flex items-center justify-center p-4">
                  <img src="/uploads/<%= item.image %>" alt="<%= item.name %>" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500" onerror="this.src='/uploads/default-product.png'">
                </a>
                <% if(item.discount > 0) { %>
                  <span class="absolute top-2 left-2 bg-red-500 text-white text-[8px] font-black px-2 py-0.5 rounded-lg shadow-sm">
                    <%= Math.round((item.discount / (item.price + item.discount)) * 100) %>% OFF
                  </span>
                <% } %>
              </div>
              
              <span class="text-[9px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded font-bold uppercase tracking-wider">
                <%= item.category || 'Fresh Farm' %>
              </span>
              
              <h4 class="font-bold text-xs text-gray-800 group-hover:text-[#24963f] mt-1.5 transition-colors line-clamp-1">
                <a href="/products/view/<%= item._id %>" class="hover:underline">
                  <%= item.name %>
                </a>
              </h4>
              <p class="text-[10px] text-gray-400 mt-0.5"><%= item.quantity || 'Pack' %></p>
            </div>
            
            <div class="flex justify-between items-center mt-3 pt-2 border-t border-gray-100">
              <div class="flex flex-col">
                <span class="font-black text-sm text-black">₹<%= item.price %></span>
                <% if(item.discount > 0) { %>
                  <span class="text-[9px] text-gray-400 line-through">₹<%= item.price + item.discount %></span>
                <% } %>
              </div>
              
              <div class="product-action-container" id="action-box-<%= item._id %>">
                <% 
                  let relativeCartItem = user && user.cart ? user.cart.find(c => c.product && c.product._id.toString() === item._id.toString()) : null; 
                %>

                <% if (relativeCartItem) { %>
                  <div class="flex items-center bg-[#24963f]/[0.09] text-black rounded-lg overflow-hidden border border-[#24963f]/20 font-black text-xs">
                    <button onclick="descreaseQty('<%= item._id %>')" class="px-2.5 py-1.5 hover:bg-[#24963f] hover:text-white transition-colors text-xs font-black">-</button>
                    <span id="quantityNumber-<%= item._id %>" class="px-1 min-w-[16px] text-center font-black text-xs"><%= relativeCartItem.quantity %></span>
                    <button onclick="increaseQty('<%= item._id %>')" class="px-2.5 py-1.5 hover:bg-[#24963f] hover:text-white transition-colors text-xs font-black">+</button>
                  </div>
                <% } else { %>
                  <button onclick="addToCart('<%= item._id %>', '<%= item.price %>')" class="text-center text-[10px] font-extrabold px-3 py-1.5 bg-emerald-50 text-[#24963f] border border-[#24963f]/20 rounded-xl hover:bg-[#24963f] hover:text-white transition-all duration-200 shadow-sm">
                    + ADD
                  </button>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center py-6 text-gray-400 text-xs font-semibold">
          No related items found.
        </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/header-scripts') %>
  <%- include('partials/updateQty') %>

  <% if (product.images && product.images.length > 1) { %>
    <script>
      let currentDetailIdx = 0;
      const totalDetailSlides = <%= product.images.length %>;

      function showDetailSlide(index) {
        if (index >= totalDetailSlides) {
          currentDetailIdx = 0;
        } else if (index < 0) {
          currentDetailIdx = totalDetailSlides - 1;
        } else {
          currentDetailIdx = index;
        }

        // Hide all slides, show active
        document.querySelectorAll('.detail-slide').forEach((slide, i) => {
          if (i === currentDetailIdx) {
            slide.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
            slide.classList.add('opacity-100', 'scale-100');
          } else {
            slide.classList.remove('opacity-100', 'scale-100');
            slide.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
          }
        });

        // Update active class on thumbnails
        document.querySelectorAll('.detail-thumb').forEach((thumb, i) => {
          if (i === currentDetailIdx) {
            thumb.classList.remove('border-gray-100');
            thumb.classList.add('border-[#24963f]', 'shadow-md', 'scale-105');
          } else {
            thumb.classList.remove('border-[#24963f]', 'shadow-md', 'scale-105');
            thumb.classList.add('border-gray-100');
          }
        });
      }

      function nextDetailSlide(event) {
        event.stopPropagation();
        showDetailSlide(currentDetailIdx + 1);
      }

      function prevDetailSlide(event) {
        event.stopPropagation();
        showDetailSlide(currentDetailIdx - 1);
      }

      function setDetailSlide(index) {
        showDetailSlide(index);
      }
    </script>
  <% } %>
</body>
</html>