<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> | Apna Mart</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .nav-sticky { position: sticky; top: 0; z-index: 50; }
  </style>
</head>
<body class="bg-white text-gray-900 antialiased">

<%- include('partials/header') %>

  <nav class="max-w-7xl mx-auto px-6 pt-8 text-[10px] text-gray-400 font-bold uppercase tracking-widest">
    <a href="/" class="hover:text-emerald-600">Home</a>
    <span class="mx-2 text-gray-200">/</span>
    <a href="/products/allProducts" class="hover:text-emerald-600 text-gray-500">Products</a>
    <span class="mx-2 text-gray-200">/</span>
    <span class="truncate"><%= product.name %></span>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
    
    <div class="md:col-span-5 flex flex-col items-center justify-center border border-gray-100 rounded-[40px] p-10 relative min-h-[400px] md:min-h-[500px]" style="background-color: <%= product.bgColor || '#f9fafb' %>;">
      <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" class="max-w-full max-h-[400px] object-contain drop-shadow-2xl">
      
      <% if(product.discount > 0) { %>
        <span class="absolute top-6 left-6 bg-red-500 text-white text-[11px] font-black px-4 py-1.5 rounded-lg uppercase tracking-widest shadow-lg">
          <%= Math.round((product.discount / (product.price + product.discount)) * 100) %>% OFF
        </span>
      <% } %>
    </div>

  <div class="md:col-span-7 flex flex-col space-y-8">
      
      <div>
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-900 leading-tight">
          <%= product.name %>
        </h1>
        <p class="text-gray-400 font-bold text-sm mt-2 flex items-center gap-2 uppercase tracking-widest">
          <i class="fa-solid fa-clock text-[#24963f]"></i> Delivery in 10-15 Mins
        </p>
      </div>

      <div>
        <h3 class="text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Select Unit</h3>
        <div class="flex flex-wrap gap-4">
          <div class="border-2 border-[#24963f] bg-emerald-50/50 rounded-2xl px-6 py-4 min-w-[120px] text-center shadow-sm">
            <p class="text-xs font-bold text-gray-600 mb-1"><%= product.quantity %></p>
            <p class="text-lg font-black text-black">₹<%= product.price %></p>
          </div>
          <div class="border border-gray-100 bg-gray-50/50 rounded-2xl px-6 py-4 min-w-[120px] text-center opacity-40">
            <p class="text-xs font-medium text-gray-400 mb-1">2 x <%= product.quantity %></p>
            <p class="text-xs font-bold text-red-400 uppercase tracking-widest">Sold Out</p>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between bg-emerald-50/30 p-6 rounded-[32px] border border-emerald-100/50 max-w-xl">
        <div>
          <div class="flex items-baseline gap-2.5">
            <span class="text-3xl font-black text-black">₹<%= product.price %></span>
            <% if(product.discount > 0) { %>
              <span class="text-sm text-gray-400 line-through font-bold">₹<%= product.price + product.discount %></span>
            <% } %>
          </div>
          <p class="text-[10px] text-emerald-600/60 font-bold uppercase tracking-wider mt-1">(Inclusive of all taxes)</p>
        </div>

        <div class="flex flex-col items-end">
          <% if(product.stock > 0) { %>
            
            <% 
              // चेक कर रहे हैं कि क्या यह स्पेसिफिक प्रोडक्ट यूजर के कार्ट में पहले से है
              let detailCartItem = user && user.cart ? user.cart.find(c => c.product && c.product._id.toString() === product._id.toString()) : null; 
            %>

            <% if (detailCartItem) { %>
              <div class="flex items-center bg-[#24963f] text-white rounded-2xl overflow-hidden shadow-xl shadow-emerald-900/10 font-black text-sm h-[52px]">
                <button onclick="updateQty('<%= product._id %>', 'decrease')" class="px-5 h-full hover:bg-[#1e7e34] transition-colors font-black text-base">-</button>
                <span class="px-2 min-w-[24px] text-center font-black text-sm"><%= detailCartItem.quantity %></span>
                <button onclick="updateQty('<%= product._id %>', 'increase')" class="px-5 h-full hover:bg-[#1e7e34] transition-colors font-black text-base">+</button>
              </div>
            <% } else { %>
              <button onclick="addToCart('<%= product._id %>')" 
                      class="bg-[#24963f] hover:bg-[#1e7e34] text-white font-black text-sm px-8 py-4 rounded-2xl transition-all active:scale-95 shadow-xl shadow-emerald-900/10 flex items-center gap-2 group">
                <i class="fa-solid fa-basket-shopping text-xs group-hover:animate-bounce"></i> 
                <span>ADD TO BASKET</span>
              </button>
            <% } %>

          <% } else { %>
            <button disabled class="bg-gray-200 text-gray-400 font-black text-sm px-10 py-4 rounded-2xl cursor-not-allowed">OUT OF STOCK</button>
          <% } %>
        </div>
        
      </div>

      <div class="grid grid-cols-2 gap-6 pt-4 max-w-xl">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-[#24963f] border border-gray-100">
            <i class="fa-solid fa-bolt text-sm"></i>
          </div>
          <div>
            <h5 class="text-xs font-black text-gray-900 uppercase tracking-wide">Superfast</h5>
            <p class="text-[11px] text-gray-500 mt-1 leading-relaxed">Delivery in minutes, right from your local Apna Mart.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-[#24963f] border border-gray-100">
            <i class="fa-solid fa-shield-heart text-sm"></i>
          </div>
          <div>
            <h5 class="text-xs font-black text-gray-900 uppercase tracking-wide">Best Prices</h5>
            <p class="text-[11px] text-gray-500 mt-1 leading-relaxed">Sourced directly to ensure you get the best deals.</p>
          </div>
        </div>
      </div>

  </div>
  </main>

  <script>
    async function addToCart (productId){
      let res = await fetch(`/users/cart/add-to-cart/${productId}`, {
          method: "POST"
      });
      let data = await res.json();
      alert(data.message); 
      if(data.success){
        location.reload() 
      }
    }
  </script>
  <%- include('partials/header-scripts') %>
</body>
</html>